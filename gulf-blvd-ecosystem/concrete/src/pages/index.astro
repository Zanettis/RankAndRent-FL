---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import LeadForm from '../components/LeadForm.astro';
import CrossLinkWidget from '../components/CrossLinkWidget.astro';
import { SITE_CONFIG } from '../config';

const serviceIcons = [
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v10a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1V10"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8"><rect x="3" y="3" width="18" height="18" rx="2"/><path stroke-linecap="round" stroke-linejoin="round" d="M3 9h18M9 21V9"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8"><circle cx="12" cy="12" r="3"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2z"/><path stroke-linecap="round" stroke-linejoin="round" d="M9 3v18M15 3v18"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>`,
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How much does a concrete pool deck cost in St. Pete Beach?',
      acceptedAnswer: { '@type': 'Answer', text: 'A new concrete pool deck along Gulf Blvd typically costs $8–$18 per square foot depending on finish (brushed, stamped, or decorative), size, and whether the existing surface needs removal. Pool deck resurfacing with an overlay runs $3–$8 per square foot. We provide free written estimates on every job.' },
    },
    {
      '@type': 'Question',
      name: 'Why does concrete deteriorate faster near the Gulf Coast?',
      acceptedAnswer: { '@type': 'Answer', text: 'Salt air causes a chemical reaction with the calcium compounds in concrete, gradually breaking down the surface — a process called salt crystallization. Chloride ions also penetrate the concrete and corrode any embedded steel rebar, causing spalling and cracking. Marine-grade sealing and proper mix design significantly extend concrete life on Gulf Coast properties.' },
    },
    {
      '@type': 'Question',
      name: 'Do you do pool deck resurfacing or only new installs?',
      acceptedAnswer: { '@type': 'Answer', text: 'We do both. If your existing pool deck is structurally sound but looks worn, stained, or cracked, a concrete overlay or resurfacing is a fraction of the cost of a full replacement. We assess the existing surface and give you an honest recommendation on repair vs. replacement.' },
    },
    {
      '@type': 'Question',
      name: 'Can you pour concrete during Florida\'s rainy season?',
      acceptedAnswer: { '@type': 'Answer', text: 'Yes, with proper planning. We monitor weather carefully and schedule pours during dry windows. Florida\'s afternoon rain pattern is predictable — morning pours are typically safe if rain isn\'t in the forecast until evening. Concrete placed and finished before rain begins is not damaged by light rain, provided it has sufficient set time.' },
    },
    {
      '@type': 'Question',
      name: 'Do concrete driveways need to be sealed in Florida?',
      acceptedAnswer: { '@type': 'Answer', text: 'Yes, sealing is especially important for Gulf Blvd properties. Salt air, UV radiation, and Florida\'s wet-dry cycles all degrade concrete. A quality marine-grade sealer applied every 2–4 years dramatically extends the life of your driveway and prevents oil stains, salt crystallization damage, and UV bleaching.' },
    },
    {
      '@type': 'Question',
      name: 'Are concrete foundations hurricane-rated in Florida?',
      acceptedAnswer: { '@type': 'Answer', text: 'All foundations we pour are designed and poured to Florida Building Code standards, which include wind-load requirements for Pinellas County\'s hurricane zone. We use appropriate reinforcement (rebar and mesh), proper mix design, and compressive strength specs to meet or exceed code.' },
    },
    {
      '@type': 'Question',
      name: 'How long before I can drive on a new concrete driveway?',
      acceptedAnswer: { '@type': 'Answer', text: 'We recommend waiting 7 days before driving on a new concrete driveway and 28 days before parking heavy vehicles. In Florida\'s heat and humidity, concrete typically reaches 70% of its design strength within the first week — but the full curing process takes 28 days.' },
    },
    {
      '@type': 'Question',
      name: 'What areas along Gulf Blvd do you serve?',
      acceptedAnswer: { '@type': 'Answer', text: 'We serve all communities along Gulf Boulevard — Indian Rocks Beach, Indian Shores, Redington Shores, Redington Beach, Madeira Beach, Treasure Island, St. Pete Beach, and Clearwater Beach.' },
    },
  ],
};

const testimonials = [
  {
    quote: "Had them pour a new pool deck around our Treasure Island home. Stamped concrete, salt air rated sealer — looked incredible and the crew was professional start to finish.",
    name: "Dave & Kathy R.",
    location: "Treasure Island, FL",
  },
  {
    quote: "Our driveway had serious spalling from years of salt air. They resurfaced it with an overlay and sealed it properly. Looks brand new and they explained every step.",
    name: "Maria L.",
    location: "Indian Rocks Beach, FL",
  },
  {
    quote: "Fair price, showed up when they said, done in two days. The concrete patio is exactly what we wanted for our Gulf Blvd vacation home.",
    name: "Tom S.",
    location: "St. Pete Beach, FL",
  },
];
---

<BaseLayout
  title="Concrete Driveways, Pool Decks & Patios Gulf Blvd FL | Indian Rocks Beach to Clearwater"
  description="Concrete driveways, pool decks, patios, and foundations along Gulf Boulevard — Indian Rocks Beach to Clearwater Beach. Marine-grade materials, licensed & insured. Free estimates."
  aggregateRating={{ ratingValue: "4.9", reviewCount: "81" }}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Hero
    headline="Gulf Blvd's Concrete Contractor — Pool Decks, Driveways & Patios"
    subheadline="Concrete driveways, pool deck resurfacing, patios, and foundations from Indian Rocks Beach to Clearwater Beach. Marine-grade materials rated for Florida's salt air. We show up. We do it right."
    ctaText="Get a Free Quote"
    secondaryCtaText={`Call ${SITE_CONFIG.phone}`}
    secondaryCtaHref={`tel:${SITE_CONFIG.phone}`}
    badges={["Licensed & Insured", "Free Estimates", "Marine-Grade Sealing", "FL Building Code Compliant"]}
  />

  <!-- Trust Bar -->
  <div class="bg-white border-b border-gray-100 shadow-sm">
    <div class="max-w-6xl mx-auto px-4 py-4 flex flex-wrap justify-center gap-x-8 gap-y-2 text-sm text-gray-600">
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        We Pick Up The Phone
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        We Show Up On Time
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        FL Licensed & Insured
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        Free Written Estimates
      </span>
    </div>
  </div>

  <!-- Services -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <h2 class="text-3xl font-bold text-primary text-center mb-4">Our Concrete Services</h2>
    <p class="text-gray-600 text-center max-w-2xl mx-auto mb-10">
      From pool deck resurfacing to hurricane-ready foundations — we cover every concrete need
      along Gulf Boulevard, using materials and mixes designed for Florida's coastal environment.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {SITE_CONFIG.services.map((service, i) => (
        <ServiceCard
          title={service.title}
          description={service.description}
          href={service.href}
          icon={serviceIcons[i] ?? serviceIcons[0]}
        />
      ))}
    </div>
  </section>

  <!-- Pool Deck Pitch -->
  <section class="bg-accent/10 border-y border-accent/20 py-16 px-4">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
      <div>
        <span class="inline-block bg-accent/20 text-primary font-semibold text-sm px-3 py-1 rounded-full mb-4">Gulf Blvd's #1 Concrete Service</span>
        <h2 class="text-3xl font-bold text-primary mb-4">Pool Deck Resurfacing — The Gulf Blvd Difference</h2>
        <p class="text-gray-700 leading-relaxed mb-4">
          Nearly every Gulf Blvd home has a pool. And most pool decks on barrier island properties
          show the same pattern: bleached concrete, salt crystallization damage, and cracked
          joints from decades of Florida sun and salt air. Full replacement costs $15,000–$30,000+.
        </p>
        <p class="text-gray-700 leading-relaxed mb-6">
          We resurface existing pool decks for a fraction of that cost — using marine-grade
          concrete overlays and sealers specifically formulated for coastal Florida environments.
          The result looks new and lasts for years with proper maintenance.
        </p>
        <a href="/services/pool-deck-resurfacing" class="inline-block bg-cta text-white font-bold px-6 py-3 rounded-lg hover:opacity-90 transition-opacity">
          Pool Deck Resurfacing Details →
        </a>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div class="bg-white rounded-xl p-5 shadow-sm text-center">
          <div class="text-3xl font-bold text-primary mb-1">$3–$8</div>
          <div class="text-sm text-gray-600">Per sq ft overlay</div>
        </div>
        <div class="bg-white rounded-xl p-5 shadow-sm text-center">
          <div class="text-3xl font-bold text-primary mb-1">1–2 Days</div>
          <div class="text-sm text-gray-600">Most pool decks</div>
        </div>
        <div class="bg-white rounded-xl p-5 shadow-sm text-center">
          <div class="text-3xl font-bold text-primary mb-1">8 Cities</div>
          <div class="text-sm text-gray-600">Served along Gulf Blvd</div>
        </div>
        <div class="bg-white rounded-xl p-5 shadow-sm text-center">
          <div class="text-3xl font-bold text-primary mb-1">Free</div>
          <div class="text-sm text-gray-600">Written estimates</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Salt Air Section -->
  <section class="max-w-5xl mx-auto px-4 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
      <div>
        <h2 class="text-3xl font-bold text-primary mb-4">Why Gulf Coast Concrete Needs Different Treatment</h2>
        <p class="text-gray-700 leading-relaxed mb-4">
          Salt air isn't just a cosmetic problem. Chloride ions carried in coastal air penetrate
          concrete and corrode embedded steel — causing spalling, cracking, and structural damage
          that accelerates in Florida's wet-dry climate cycle.
        </p>
        <p class="text-gray-700 leading-relaxed mb-4">
          We use concrete mixes with low water-cement ratios for better density, marine-grade
          sealers that block chloride penetration, and stainless or epoxy-coated rebar in
          reinforced work near the coast. This isn't upselling — it's the difference between
          concrete that lasts 30 years and concrete that needs replacement in 10.
        </p>
        <a href="/services/marine-grade-concrete-sealing" class="text-cta font-semibold hover:underline">
          Learn about marine-grade sealing →
        </a>
      </div>
      <div class="space-y-4">
        <div class="flex items-start gap-4 bg-gray-50 rounded-xl p-4">
          <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          </div>
          <div>
            <h3 class="font-bold text-primary mb-1">Salt Crystallization Damage</h3>
            <p class="text-gray-600 text-sm">Salt crystals expand inside concrete pores, causing surface scaling that worsens each season without sealing.</p>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-gray-50 rounded-xl p-4">
          <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <div>
            <h3 class="font-bold text-primary mb-1">Hurricane-Season Prep</h3>
            <p class="text-gray-600 text-sm">Properly poured and cured foundations and slabs are your first line of defense during storm season in Pinellas County.</p>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-gray-50 rounded-xl p-4">
          <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4"/></svg>
          </div>
          <div>
            <h3 class="font-bold text-primary mb-1">UV + Tropical Heat</h3>
            <p class="text-gray-600 text-sm">Florida's UV index is among the highest in the US. We use mixes and sealers rated for long-term UV exposure.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="bg-gray-50 py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-primary text-center mb-10">Why Gulf Blvd Homeowners Choose Us</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="flex justify-center mb-4">
            <div class="w-14 h-14 bg-primary/10 rounded-full flex items-center justify-center">
              <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
          </div>
          <h3 class="font-bold text-primary text-lg mb-2">We Answer the Phone</h3>
          <p class="text-gray-600 text-sm">No voicemail maze. When you call, a real person picks up and gets you scheduled.</p>
        </div>
        <div class="text-center">
          <div class="flex justify-center mb-4">
            <div class="w-14 h-14 bg-primary/10 rounded-full flex items-center justify-center">
              <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
            </div>
          </div>
          <h3 class="font-bold text-primary text-lg mb-2">Coastal Material Expertise</h3>
          <p class="text-gray-600 text-sm">We use mixes, reinforcement, and sealers specifically rated for Gulf Coast salt air — not generic catalog specs.</p>
        </div>
        <div class="text-center">
          <div class="flex justify-center mb-4">
            <div class="w-14 h-14 bg-primary/10 rounded-full flex items-center justify-center">
              <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
              </svg>
            </div>
          </div>
          <h3 class="font-bold text-primary text-lg mb-2">Free Written Estimates</h3>
          <p class="text-gray-600 text-sm">No verbal quotes that change on arrival. Written estimates before any work begins. No surprises.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <h2 class="text-3xl font-bold text-primary text-center mb-4">What Gulf Blvd Homeowners Say</h2>
    <p class="text-gray-600 text-center mb-10">Real customers, real results.</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm flex flex-col gap-4">
          <div class="flex gap-1">
            {Array.from({ length: 5 }).map(() => (
              <svg class="w-4 h-4 fill-yellow-400" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <p class="text-gray-700 text-sm leading-relaxed flex-1">"{t.quote}"</p>
          <div>
            <p class="font-semibold text-primary text-sm">{t.name}</p>
            <p class="text-gray-500 text-xs">{t.location}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Service Areas -->
  <section class="bg-gray-50 py-16 px-4">
    <div class="max-w-6xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-primary mb-4">Serving All of Gulf Boulevard</h2>
      <p class="text-gray-600 max-w-3xl mx-auto mb-10">
        We cover the full Gulf Blvd corridor — from Indian Rocks Beach in the north to
        St. Pete Beach in the south, plus Clearwater Beach. If you're on or near the Gulf, we serve you.
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {SITE_CONFIG.locations.map((loc) => (
          <a
            href={loc.href}
            class="bg-white border border-gray-200 rounded-xl px-4 py-4 text-sm font-semibold text-primary hover:border-accent hover:text-accent transition-all shadow-sm"
          >
            {loc.city}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-4xl mx-auto px-4 py-16">
    <h2 class="text-3xl font-bold text-primary text-center mb-10">Frequently Asked Questions</h2>
    <div class="space-y-4">
      {[
