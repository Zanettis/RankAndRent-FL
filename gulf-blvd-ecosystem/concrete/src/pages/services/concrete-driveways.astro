---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Concrete Driveways',
  name: 'Concrete Driveways — Gulf Blvd, FL',
  description: 'New concrete driveway installation and replacement along Gulf Boulevard, FL. Marine-grade materials, proper reinforcement, and sealing for coastal salt-air environments.',
  provider: { '@type': 'LocalBusiness', name: SITE_CONFIG.name, url: SITE_CONFIG.domain, telephone: SITE_CONFIG.phone },
  areaServed: SITE_CONFIG.locations.map(l => ({ '@type': 'City', name: l.city })),
  offers: { '@type': 'Offer', priceSpecification: { '@type': 'PriceSpecification', minPrice: '4000', maxPrice: '12000', priceCurrency: 'USD' } },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${SITE_CONFIG.domain}/services/` },
    { '@type': 'ListItem', position: 3, name: 'Concrete Driveways', item: `${SITE_CONFIG.domain}/services/concrete-driveways/` },
  ],
};
---

<BaseLayout
  title="Concrete Driveways Gulf Blvd FL | New Installation & Replacement"
  description="Concrete driveway installation and replacement along Gulf Boulevard, FL — Indian Rocks Beach to Clearwater Beach. Marine-grade mix, proper reinforcement, coastal sealing. Free estimates."
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Hero
    headline="Concrete Driveways on Gulf Blvd, FL"
    subheadline="New concrete driveway installation built to handle Florida's coastal salt air, UV, and hurricane-season conditions. Serving Indian Rocks Beach to Clearwater Beach."
    ctaText="Get a Free Estimate"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <a href="/services" class="hover:text-primary">Services</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">Concrete Driveways</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>Concrete Driveways for Gulf Coast Florida Properties</h2>
      <p>
        A concrete driveway on a Gulf Blvd property is exposed to conditions that don't exist
        inland — salt air carrying chloride ions, intense UV radiation, and the wet-dry cycling
        that comes with Florida's rainy season. A driveway poured with the wrong mix or left
        unsealed will show visible deterioration within a few years in this environment.
      </p>

      <h2>What Makes a Coastal Driveway Different</h2>
      <p>
        We use a low water-cement ratio concrete mix that produces denser, less permeable
        concrete — reducing the rate at which chloride ions can penetrate the surface and
        corrode embedded reinforcement. Proper joint spacing and placement prevents random
        cracking from Florida's thermal expansion-contraction cycle. And every driveway we
        pour gets sealed with a marine-grade penetrating sealer that actively blocks
        chloride and moisture ingress.
      </p>

      <h2>Driveway Thickness and Reinforcement</h2>
      <ul>
        <li><strong>Residential driveways:</strong> 4 inches minimum, with wire mesh or #3 rebar on 18-inch grid</li>
        <li><strong>RV and heavy vehicle pads:</strong> 6 inches with #4 rebar</li>
        <li><strong>Edge thickening:</strong> Turned-down edges at perimeter for additional strength</li>
        <li><strong>Subbase:</strong> Compacted limerock or crushed concrete for stability in Florida's variable soils</li>
      </ul>

      <h2>Finish Options</h2>
      <ul>
        <li><strong>Broom finish:</strong> Standard slip-resistant texture — the most common and cost-effective option</li>
        <li><strong>Exposed aggregate:</strong> Decorative stone surface with excellent traction</li>
        <li><strong>Stamped concrete:</strong> Mimics brick, stone, or tile patterns</li>
        <li><strong>Salt finish:</strong> Subtle pebbled texture popular in coastal FL</li>
      </ul>

      <h2>Concrete Driveway Cost on Gulf Blvd</h2>
      <p>
        A standard residential concrete driveway on Gulf Blvd typically costs $8–$15 per square
        foot installed, including subbase preparation, concrete, reinforcement, finishing, and
        initial sealing. A typical 2-car driveway (400–600 sq ft) runs $4,000–$9,000. We provide
        free written estimates with itemized breakdowns before any work begins.
      </p>

      <h2>Serving All of Gulf Boulevard</h2>
      <p>
        We install concrete driveways throughout Indian Rocks Beach, Indian Shores,
        Redington Shores, Redington Beach, Madeira Beach, Treasure Island, St. Pete Beach,
        and Clearwater Beach.
      </p>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-6">Other Services We Offer</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {SITE_CONFIG.services.filter(s => s.href !== '/services/concrete-driveways').slice(0, 3).map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading="Get Your Free Driveway Estimate" />
    </div>
  </div>
</BaseLayout>
