---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Concrete Walkways and Sidewalks',
  name: 'Concrete Walkways & Sidewalks — Gulf Blvd, FL',
  description: 'Concrete walkway and sidewalk installation along Gulf Boulevard, FL. Durable, slip-resistant, and coastal-rated. Licensed and insured. Free estimates.',
  provider: { '@type': 'LocalBusiness', name: SITE_CONFIG.name, url: SITE_CONFIG.domain, telephone: SITE_CONFIG.phone },
  areaServed: SITE_CONFIG.locations.map(l => ({ '@type': 'City', name: l.city })),
  speakable: { '@type': 'SpeakableSpecification', cssSelector: ['h1', '.service-description'] },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${SITE_CONFIG.domain}/services/` },
    { '@type': 'ListItem', position: 3, name: 'Walkways & Sidewalks', item: `${SITE_CONFIG.domain}/services/concrete-walkways-sidewalks/` },
  ],
};
---

<BaseLayout
  title="Concrete Walkways & Sidewalks Gulf Blvd FL | Installation & Repair"
  description="Concrete walkway and sidewalk installation along Gulf Boulevard, FL. Slip-resistant, coastal-rated concrete for barrier island properties. Free estimates."
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Hero
    headline="Concrete Walkways & Sidewalks on Gulf Blvd, FL"
    subheadline="Durable, slip-resistant walkways and sidewalks built for Florida's coastal climate — from property entries to beachside paths."
    ctaText="Get a Free Estimate"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <a href="/services" class="hover:text-primary">Services</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">Walkways & Sidewalks</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>Concrete Walkways for Gulf Blvd Properties</h2>
      <p>
        Concrete walkways on barrier island properties need to handle foot traffic, pool water
        splashing, and persistent moisture — all in a salt-air environment that degrades
        improperly sealed concrete. We pour walkways at the appropriate thickness, with
        control joints at correct intervals to prevent random cracking, and apply marine-grade
        sealer on completion.
      </p>

      <h2>What We Install</h2>
      <ul>
        <li>Property entry walkways and paths</li>
        <li>Pool surround walkways</li>
        <li>Garden and landscape walkways</li>
        <li>Utility and service paths</li>
        <li>HOA and condo sidewalks</li>
      </ul>

      <h2>Finish Options</h2>
      <ul>
        <li><strong>Broom finish:</strong> Slip-resistant, long-lasting, easiest to maintain</li>
        <li><strong>Salt finish:</strong> Subtle pebbly texture popular in coastal FL</li>
        <li><strong>Exposed aggregate:</strong> Natural stone look with excellent traction when wet</li>
        <li><strong>Stamped:</strong> Decorative patterns for higher-end applications</li>
      </ul>

      <h2>Walkway Cost on Gulf Blvd</h2>
      <p>
        Standard concrete walkways run $8–$12 per square foot installed. Stamped or decorative
        finishes cost $14–$20 per square foot. We provide free written estimates after
        measuring your project.
      </p>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-6">Other Services We Offer</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {SITE_CONFIG.services.filter(s => s.href !== '/services/concrete-walkways-sidewalks').slice(0, 3).map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading="Get Your Free Walkway Estimate" />
    </div>
  </div>
</BaseLayout>
