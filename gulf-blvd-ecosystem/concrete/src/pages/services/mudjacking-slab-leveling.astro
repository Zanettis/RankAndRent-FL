---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Slab Leveling',
  name: 'Slab Leveling & Lifting — Gulf Blvd, FL',
  description: 'Restore sunken and uneven concrete slabs without full replacement along Gulf Boulevard, FL. Cost-effective lifting for driveways, pool decks, and patios. Free estimates.',
  provider: { '@type': 'LocalBusiness', name: SITE_CONFIG.name, url: SITE_CONFIG.domain, telephone: SITE_CONFIG.phone },
  areaServed: SITE_CONFIG.locations.map(l => ({ '@type': 'City', name: l.city })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${SITE_CONFIG.domain}/services/` },
    { '@type': 'ListItem', position: 3, name: 'Slab Leveling', item: `${SITE_CONFIG.domain}/services/mudjacking-slab-leveling/` },
  ],
};
---

<BaseLayout
  title="Slab Leveling & Lifting Gulf Blvd FL | Sunken Concrete Repair"
  description="Restore sunken concrete slabs without full replacement along Gulf Boulevard, FL. Mudjacking and foam lifting for driveways, pool decks, and walkways. Free estimates."
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Hero
    headline="Slab Leveling & Lifting on Gulf Blvd, FL"
    subheadline="Sunken driveways, uneven pool decks, and settled walkways restored without the cost of full concrete replacement. Florida's sandy soils cause slab settlement — we fix it."
    ctaText="Get a Free Estimate"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <a href="/services" class="hover:text-primary">Services</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">Slab Leveling & Lifting</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>Why Florida Slabs Sink</h2>
      <p>
        Florida's sandy soils are highly susceptible to erosion and compaction loss.
        Rainwater washes fine particles from under concrete slabs, creating voids that
        allow the slab to settle and crack. This is especially common on barrier island
        properties where the sandy soil profile extends deep and drainage is rapid.
      </p>

      <h2>Slab Leveling Methods</h2>
      <ul>
        <li><strong>Mudjacking (slabjacking):</strong> A cement-sand slurry is pumped under the slab to fill voids and lift the concrete back to grade. Cost-effective and proven for larger slabs.</li>
        <li><strong>Polyurethane foam lifting:</strong> Lightweight expanding foam injected under the slab. Faster, leaves smaller holes, and provides waterproof void fill. Preferred for pool decks and areas with water exposure.</li>
      </ul>

      <h2>When Leveling vs. Replacement Makes Sense</h2>
      <p>
        Slab leveling is appropriate when the concrete itself is in good condition — no
        widespread cracking, no significant spalling — but has settled due to subbase erosion.
        If the concrete is deteriorated throughout, replacement is the better long-term value.
        We assess both options and recommend based on cost-effectiveness.
      </p>

      <h2>Slab Leveling Cost on Gulf Blvd</h2>
      <p>
        Mudjacking and foam lifting typically costs 30–50% of full concrete replacement.
        Exact cost depends on the number of lift points required and the size of the
        settled area. We provide free assessments and written estimates.
      </p>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-6">Other Services We Offer</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {SITE_CONFIG.services.filter(s => s.href !== '/services/mudjacking-slab-leveling').slice(0, 3).map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading="Get Your Free Slab Leveling Assessment" />
    </div>
  </div>
</BaseLayout>
