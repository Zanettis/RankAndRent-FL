---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Concrete Sealing',
  name: 'Marine-Grade Concrete Sealing — Gulf Blvd, FL',
  description: 'Professional concrete sealing with marine-grade products rated for salt air, chloride, and UV exposure. Protects driveways, pool decks, and patios on Gulf Coast properties.',
  provider: { '@type': 'LocalBusiness', name: SITE_CONFIG.name, url: SITE_CONFIG.domain, telephone: SITE_CONFIG.phone },
  areaServed: SITE_CONFIG.locations.map(l => ({ '@type': 'City', name: l.city })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${SITE_CONFIG.domain}/services/` },
    { '@type': 'ListItem', position: 3, name: 'Marine-Grade Concrete Sealing', item: `${SITE_CONFIG.domain}/services/marine-grade-concrete-sealing/` },
  ],
};
---

<BaseLayout
  title="Marine-Grade Concrete Sealing Gulf Blvd FL | Salt Air Protection"
  description="Professional concrete sealing with marine-grade products rated for coastal salt air and UV. Protects driveways, pool decks, and patios along Gulf Boulevard, FL. Free estimates."
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Hero
    headline="Marine-Grade Concrete Sealing on Gulf Blvd, FL"
    subheadline="Standard concrete sealers fail in coastal salt air. We use marine-grade products specifically rated for chloride resistance, UV stability, and Gulf Coast humidity."
    ctaText="Get a Free Estimate"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <a href="/services" class="hover:text-primary">Services</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">Marine-Grade Concrete Sealing</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>Why Standard Concrete Sealers Fail Near the Gulf</h2>
      <p>
        Big-box store concrete sealers are formulated for typical residential conditions.
        On Gulf Blvd, those conditions don't exist. Salt-air carries chloride ions that
        penetrate standard acrylic sealers. UV radiation at Florida's latitude degrades
        most topcoat sealers within 12–18 months. Seasonal humidity cycles cause standard
        sealers to bubble and peel.
      </p>

      <h2>Marine-Grade Sealer Types We Use</h2>
      <ul>
        <li><strong>Penetrating silane/siloxane sealers:</strong> Penetrate deep into the concrete matrix and chemically bond to block chloride and moisture ingress. UV-stable, invisible finish, no surface film to peel. Recommended for driveways and walkways.</li>
        <li><strong>Polyurethane topcoat sealers:</strong> Marine-grade PU formulations rated for UV and chemical resistance. Provides surface sheen and protection for pool decks and patios.</li>
        <li><strong>Epoxy-based penetrating sealers:</strong> For high-traffic surfaces requiring maximum durability and chemical resistance.</li>
      </ul>

      <h2>Recommended Sealing Schedule</h2>
      <p>
        New concrete should be allowed to cure for a minimum of 28 days before sealing.
        Penetrating sealers on coastal properties should be reapplied every 3–5 years.
        Topcoat sealers on pool decks require maintenance recoating every 2–3 years
        depending on UV exposure and foot traffic.
      </p>

      <h2>Sealing Cost on Gulf Blvd</h2>
      <p>
        Concrete sealing costs $0.50–$2.50 per square foot depending on sealer type,
        surface condition, and whether pressure washing and prep work are included.
        We provide free assessments and written estimates.
      </p>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-6">Other Services We Offer</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {SITE_CONFIG.services.filter(s => s.href !== '/services/marine-grade-concrete-sealing').slice(0, 3).map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading="Get Your Free Sealing Estimate" />
    </div>
  </div>
</BaseLayout>
