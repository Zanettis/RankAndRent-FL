---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Concrete Slabs',
  name: 'Concrete Slabs — Gulf Blvd, FL',
  description: 'Concrete slab installation for patios, sheds, and utility pads along Gulf Boulevard, FL. Properly reinforced for Florida soil and coastal conditions. Free estimates.',
  provider: { '@type': 'LocalBusiness', name: SITE_CONFIG.name, url: SITE_CONFIG.domain, telephone: SITE_CONFIG.phone },
  areaServed: SITE_CONFIG.locations.map(l => ({ '@type': 'City', name: l.city })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${SITE_CONFIG.domain}/services/` },
    { '@type': 'ListItem', position: 3, name: 'Concrete Slabs', item: `${SITE_CONFIG.domain}/services/concrete-slabs/` },
  ],
};
---

<BaseLayout
  title="Concrete Slabs Gulf Blvd FL | Patio, Shed & Utility Slab Installation"
  description="Concrete slab installation for patios, sheds, generators, and utility pads along Gulf Boulevard, FL. Properly reinforced for Florida's sandy soils. Free estimates."
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Hero
    headline="Concrete Slabs on Gulf Blvd, FL"
    subheadline="Flat concrete slabs for patios, sheds, generators, and utility equipment — properly prepared, reinforced, and finished for Florida's coastal environment."
    ctaText="Get a Free Estimate"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <a href="/services" class="hover:text-primary">Services</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">Concrete Slabs</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>Concrete Slabs for Gulf Blvd Properties</h2>
      <p>
        A concrete slab is one of the most straightforward concrete projects — and one
        of the most frequently done wrong. On Gulf Blvd properties, poor subbase preparation
        leads to slabs that sink and crack within a few years. Sandy Florida soils require
        proper compaction and sometimes a limerock subbase to provide stable support.
      </p>

      <h2>Common Slab Applications</h2>
      <ul>
        <li>Backyard patio slabs</li>
        <li>Storage shed and workshop foundations</li>
        <li>Generator and HVAC equipment pads</li>
        <li>Outdoor kitchen and grill pads</li>
        <li>Garbage and recycling enclosures</li>
        <li>Pool equipment pads</li>
        <li>Boat trailer and RV parking pads</li>
      </ul>

      <h2>Slab Thickness and Reinforcement</h2>
      <ul>
        <li><strong>Light use (pedestrian/storage):</strong> 3.5–4 inches with wire mesh</li>
        <li><strong>Vehicle traffic:</strong> 5–6 inches with rebar on grid</li>
        <li><strong>Heavy equipment:</strong> 6+ inches, engineered reinforcement as needed</li>
      </ul>

      <h2>Concrete Slab Cost on Gulf Blvd</h2>
      <p>
        Basic concrete slabs run $6–$12 per square foot installed, including subbase
        preparation, concrete, and finishing. Generator and equipment pads often
        include anchor bolt placement as part of the pour. We provide free written
        estimates on all slab projects.
      </p>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-6">Other Services We Offer</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {SITE_CONFIG.services.filter(s => s.href !== '/services/concrete-slabs').slice(0, 3).map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading="Get Your Free Slab Estimate" />
    </div>
  </div>
</BaseLayout>
