---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Concrete Walls',
  name: 'Concrete Walls & Retaining Walls — Gulf Blvd, FL',
  description: 'Concrete retaining walls, garden walls, and privacy walls along Gulf Boulevard, FL. Engineered for Florida soil conditions and hurricane-zone wind loads.',
  provider: { '@type': 'LocalBusiness', name: SITE_CONFIG.name, url: SITE_CONFIG.domain, telephone: SITE_CONFIG.phone },
  areaServed: SITE_CONFIG.locations.map(l => ({ '@type': 'City', name: l.city })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${SITE_CONFIG.domain}/services/` },
    { '@type': 'ListItem', position: 3, name: 'Concrete Walls', item: `${SITE_CONFIG.domain}/services/concrete-walls/` },
  ],
};
---

<BaseLayout
  title="Concrete Walls & Retaining Walls Gulf Blvd FL | Design & Installation"
  description="Concrete retaining walls and garden walls along Gulf Boulevard, FL. Designed for Florida's soil conditions, storm-water drainage, and hurricane-zone wind loads. Free estimates."
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Hero
    headline="Concrete Walls & Retaining Walls on Gulf Blvd, FL"
    subheadline="Engineered concrete retaining walls and garden walls built for Florida's variable soils, storm-water management, and hurricane-zone requirements."
    ctaText="Get a Free Estimate"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <a href="/services" class="hover:text-primary">Services</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">Concrete Walls & Retaining</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>Concrete Walls for Gulf Coast Properties</h2>
      <p>
        Concrete retaining walls on Gulf Blvd properties serve multiple purposes —
        grade management, storm-water control, and landscape definition. On barrier island
        properties where soil is often sandy and drainage is critical, proper wall design
        and drainage provisions are essential.
      </p>

      <h2>Types of Walls We Build</h2>
      <ul>
        <li><strong>Poured concrete retaining walls:</strong> Structural walls for grade changes, typically reinforced with rebar</li>
        <li><strong>Block retaining walls:</strong> Segmental retaining wall systems for landscape applications</li>
        <li><strong>Garden and landscape walls:</strong> Decorative low walls for landscaping, planting beds, and outdoor definition</li>
        <li><strong>Privacy walls:</strong> Concrete or concrete block privacy walls with finish options</li>
      </ul>

      <h2>Florida Design Considerations</h2>
      <p>
        All retaining walls we build include proper drainage provisions — weep holes or
        drainage aggregate behind the wall — to handle Florida's heavy rainfall events.
        Walls over 4 feet in height require engineering review and permits in Pinellas County,
        which we can coordinate.
      </p>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-6">Other Services We Offer</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {SITE_CONFIG.services.filter(s => s.href !== '/services/concrete-walls').slice(0, 3).map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading="Get Your Free Wall Estimate" />
    </div>
  </div>
</BaseLayout>
