---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const city = 'Treasure Island';
const citySlug = 'treasure-island';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: `How much does pool deck resurfacing cost in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Pool deck resurfacing in ${city} typically costs $3–$8 per square foot for a standard overlay system. A 400–600 sq ft pool deck runs $1,500–$5,000. New pool deck installation costs $8–$18 per square foot. We provide free written estimates.` } },
    { '@type': 'Question', name: `Do you work on vacation rental properties in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Yes — vacation rental property maintenance is a significant part of our ${city} work. We offer priority scheduling between guest turnovers and can often complete pool deck resurfacing or driveway sealing within a 2–4 day window. A fresh pool deck directly improves guest ratings and justifies higher nightly rates.` } },
    { '@type': 'Question', name: `What is the best concrete finish for a ${city} pool deck?`, acceptedAnswer: { '@type': 'Answer', text: `For ${city} pool decks, we typically recommend a Kool Deck overlay or a stamped concrete overlay with a UV-stable sealer. Both stay cooler underfoot than plain gray concrete in Florida's summer heat, resist pool water and chlorine, and hold up to the salt-air environment. Travertine and slate stamp patterns are the most popular choices in the Gulf Beaches market.` } },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: `${SITE_CONFIG.domain}/cities/` },
    { '@type': 'ListItem', position: 3, name: city, item: `${SITE_CONFIG.domain}/cities/${citySlug}/` },
  ],
};
---

<BaseLayout
  title={`Concrete Contractor ${city} FL | Pool Decks, Driveways & Patios`}
  description={`Concrete pool decks, driveways, and patios in ${city}, FL. Vacation rental and residential concrete work. Marine-grade materials. Licensed & insured. Free estimates.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Hero
    headline={`Concrete Contractor in ${city}, FL`}
    subheadline={`Pool decks, driveways, and concrete work for ${city} homeowners and vacation rental properties. Licensed & insured. Free written estimates.`}
    ctaText="Get a Free Estimate"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">{city}</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>Concrete Services in {city}, FL</h2>
      <p>
        {city} is a high-traffic barrier island community south of Madeira Beach with a
        strong mix of residential and vacation rental properties along Gulf Blvd and its
        side streets. The combination of intense sun, salt air, and year-round pool use
        means concrete surfaces on {city} properties degrade faster than almost anywhere
        in Pinellas County — making regular maintenance and quality resurfacing critical
        for preserving property value and rental income.
      </p>

      <h2>Services We Provide in {city}</h2>
      <ul>
        <li><a href="/services/pool-deck-resurfacing">Pool Deck Resurfacing</a> — Kool Deck and overlay systems for rental and residential properties</li>
        <li><a href="/services/concrete-driveways">Concrete Driveways</a> — New driveway installation and replacement with coastal sealing</li>
        <li><a href="/services/decorative-concrete">Decorative & Stamped Concrete</a> — Travertine and slate patterns popular on Gulf Beaches properties</li>
        <li><a href="/services/concrete-repair">Concrete Repair</a> — Fast-turnaround crack and spalling repair for rental properties</li>
        <li><a href="/services/marine-grade-concrete-sealing">Marine-Grade Sealing</a> — Penetrating sealers for all concrete surfaces</li>
        <li><a href="/services/concrete-overlay">Concrete Overlay</a> — Transform worn pool decks and patios without full replacement</li>
      </ul>

      <h2>Pool Deck Work for {city} Vacation Rentals</h2>
      <p>
        {city} has one of the highest concentrations of short-term vacation rentals on the
        Gulf Beaches corridor. A cracked or stained pool deck shows up immediately in
        guest photos — and guest photos drive reviews. We work around rental turnover
        schedules and provide priority booking for landlords and property managers who
        need work completed quickly between guests.
      </p>
    </div>

    <div class="mt-12">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {SITE_CONFIG.services.slice(0, 6).map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-8">Frequently Asked Questions — {city}</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((item) => (
          <details class="border border-gray-200 rounded-xl overflow-hidden group">
            <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold text-primary hover:bg-gray-50 list-none">
              {item.name}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">{item.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading={`Get a Free Estimate in ${city}`} />
    </div>
  </div>
</BaseLayout>
