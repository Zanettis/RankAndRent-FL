---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const city = 'Clearwater Beach';
const citySlug = 'clearwater-beach';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: `How much does pool deck resurfacing cost in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Pool deck resurfacing in ${city} typically costs $3–$8 per square foot for a standard overlay. A 400–600 sq ft pool deck runs $1,500–$5,000. New pool deck installation costs $8–$18 per square foot. We provide free written estimates after reviewing your existing surface.` } },
    { '@type': 'Question', name: `Do you work on commercial concrete in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Yes — we handle concrete work for commercial properties, hotel pool decks, condo association walkways, and mixed-use properties in ${city}. We provide written proposals for board review and can accommodate phased project scheduling to minimize disruption.` } },
    { '@type': 'Question', name: `How long does concrete last on ${city} properties?`, acceptedAnswer: { '@type': 'Answer', text: `Properly installed and sealed concrete in ${city} lasts 25–35 years for driveways and structural slabs. Pool decks face more wear from UV, pool chemicals, and foot traffic — typically needing resurfacing every 8–15 years. Marine-grade sealing every 3–5 years is the single most effective way to extend concrete life in coastal Florida.` } },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: `${SITE_CONFIG.domain}/cities/` },
    { '@type': 'ListItem', position: 3, name: city, item: `${SITE_CONFIG.domain}/cities/${citySlug}/` },
  ],
};
---

<BaseLayout
  title={`Concrete Contractor ${city} FL | Pool Decks, Driveways & Patios`}
  description={`Concrete pool decks, driveways, and patios in ${city}, FL. Marine-grade materials for coastal salt air. Licensed & insured. Free estimates.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Hero
    headline={`Concrete Contractor in ${city}, FL`}
    subheadline={`Pool decks, driveways, patios, and foundations in ${city} — marine-grade materials, licensed & insured, free written estimates.`}
    ctaText="Get a Free Estimate"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">{city}</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>Concrete Services in {city}, FL</h2>
      <p>
        {city} is the northernmost community on the Gulf Beaches barrier island and one
        of the most visited beach destinations in Florida — with a dense mix of hotels,
        condominiums, vacation rentals, and residential properties along Gulf Blvd and
        Mandalay Ave. The high volume of foot traffic on pool decks and walkways, combined
        with the Gulf's salt-air environment, makes concrete maintenance particularly
        critical in {city}. We serve residential, condo association, and commercial
        properties throughout the barrier island.
      </p>

      <h2>Services We Provide in {city}</h2>
      <ul>
        <li><a href="/services/pool-deck-resurfacing">Pool Deck Resurfacing</a> — Complete resurfacing for residential and commercial pool decks</li>
        <li><a href="/services/concrete-driveways">Concrete Driveways</a> — New installation and replacement with coastal sealing</li>
        <li><a href="/services/concrete-patios">Concrete Patios & Outdoor Living</a> — Stamped and brushed finishes for Gulf-front properties</li>
        <li><a href="/services/marine-grade-concrete-sealing">Marine-Grade Sealing</a> — Salt air protection for all concrete types</li>
        <li><a href="/services/concrete-repair">Concrete Repair & Restoration</a> — Crack repair, spalling, and surface restoration</li>
        <li><a href="/services/concrete-overlay">Concrete Overlay</a> — Restore tired pool decks and walkways without full replacement</li>
      </ul>

      <h2>Pool Deck Resurfacing in {city}</h2>
      <p>
        {city}'s pool decks take the hardest hit of any community on our service area —
        high tourist foot traffic, intense Florida UV, pool water exposure, and Gulf salt
        air create a punishing environment. A properly installed overlay system with a
        UV-stable topcoat sealer can restore a bleached, scaled pool deck and hold its
        appearance for 8–12 years with proper maintenance. We install Kool Deck overlays
        and custom stamped systems rated for the coastal Florida environment.
      </p>
    </div>

    <div class="mt-12">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {SITE_CONFIG.services.slice(0, 6).map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-8">Frequently Asked Questions — {city}</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((item) => (
          <details class="border border-gray-200 rounded-xl overflow-hidden group">
            <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold text-primary hover:bg-gray-50 list-none">
              {item.name}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">{item.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading={`Get a Free Estimate in ${city}`} />
    </div>
  </div>
</BaseLayout>
