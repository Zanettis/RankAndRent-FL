---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const city = 'Redington Shores';
const citySlug = 'redington-shores';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: `How much does pool deck resurfacing cost in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Pool deck resurfacing in ${city} typically costs $3–$8 per square foot for a standard overlay system. A 400–600 sq ft pool deck runs $1,500–$5,000. New pool deck installation costs $8–$18 per square foot. We provide free written estimates after measuring your specific project.` } },
    { '@type': 'Question', name: `Does salt air damage concrete faster in ${city} than inland areas?`, acceptedAnswer: { '@type': 'Answer', text: `Yes — ${city}'s Gulf-front location means significantly higher chloride exposure than inland Pinellas County. Chloride ions penetrate unsealed concrete and corrode rebar, causing cracking and spalling within 5–10 years without proper sealing. Marine-grade penetrating sealers applied every 3–5 years dramatically extend concrete life.` } },
    { '@type': 'Question', name: `Can you repair settled concrete slabs in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Yes — slab settlement is common in ${city} due to the sandy barrier island soil profile. We use polyurethane foam lifting (preferred for areas near water) and traditional mudjacking to restore settled pool decks, driveways, and walkways without full replacement.` } },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: `${SITE_CONFIG.domain}/cities/` },
    { '@type': 'ListItem', position: 3, name: city, item: `${SITE_CONFIG.domain}/cities/${citySlug}/` },
  ],
};
---

<BaseLayout
  title={`Concrete Contractor ${city} FL | Pool Decks, Driveways & Patios`}
  description={`Concrete pool decks, driveways, and patios in ${city}, FL. Marine-grade coastal materials rated for Gulf Blvd salt air. Licensed & insured. Free estimates.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Hero
    headline={`Concrete Contractor in ${city}, FL`}
    subheadline={`Pool decks, driveways, patios, and concrete repair in ${city} — marine-grade materials, licensed & insured, free written estimates.`}
    ctaText="Get a Free Estimate"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">{city}</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>Concrete Services in {city}, FL</h2>
      <p>
        {city} sits between Indian Shores and Redington Beach on Gulf Blvd — a quiet
        residential beach community with a high concentration of Gulf-front and Gulf-view
        homes. Like all barrier island communities in Pinellas County, {city} properties
        face accelerated concrete degradation from salt-air chloride exposure and intense
        UV. Pool cages and screened lanais are nearly universal here, meaning pool deck
        concrete sees heavy seasonal use year-round.
      </p>

      <h2>Services We Provide in {city}</h2>
      <ul>
        <li><a href="/services/pool-deck-resurfacing">Pool Deck Resurfacing</a> — Overlay systems rated for coastal salt air and pool chemical exposure</li>
        <li><a href="/services/concrete-driveways">Concrete Driveways</a> — New installation and replacement with marine-grade sealing</li>
        <li><a href="/services/concrete-patios">Concrete Patios & Outdoor Living</a> — Brushed, stamped, and colored concrete options</li>
        <li><a href="/services/marine-grade-concrete-sealing">Marine-Grade Sealing</a> — Penetrating silane/siloxane and topcoat systems</li>
        <li><a href="/services/concrete-repair">Concrete Repair</a> — Crack injection, spalling repair, and surface restoration</li>
        <li><a href="/services/mudjacking-slab-leveling">Slab Leveling</a> — Foam lifting and mudjacking for settled barrier island slabs</li>
      </ul>

      <h2>Marine-Grade Sealing in {city}</h2>
      <p>
        Unsealed concrete on {city} properties typically shows visible salt scaling and
        surface deterioration within 3–5 years. Our marine-grade penetrating sealers —
        silane/siloxane blends rated for coastal chloride environments — block ion
        penetration at the pore level rather than sitting on top as a film. This is
        the only sealing approach that provides meaningful protection in Gulf-front conditions.
      </p>
    </div>

    <div class="mt-12">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {SITE_CONFIG.services.slice(0, 6).map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-8">Frequently Asked Questions — {city}</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((item) => (
          <details class="border border-gray-200 rounded-xl overflow-hidden group">
            <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold text-primary hover:bg-gray-50 list-none">
              {item.name}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">{item.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading={`Get a Free Estimate in ${city}`} />
    </div>
  </div>
</BaseLayout>
