---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const city = 'Redington Beach';
const citySlug = 'redington-beach';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: `How much does a concrete patio cost in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Concrete patio installation in ${city} typically costs $6–$10 per square foot for a brushed or broom finish. Stamped and decorative concrete runs $12–$20 per square foot. Most patios in the 200–400 sq ft range run $2,000–$6,000 installed. We provide free written estimates.` } },
    { '@type': 'Question', name: `How often should I seal my concrete in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `In ${city}'s coastal salt-air environment, we recommend resealing with a penetrating silane/siloxane sealer every 3–5 years. Pool deck topcoat sealers may need refreshing every 2–3 years depending on traffic. Signs that resealing is needed: water no longer beads on the surface, white salt haze appearing on the surface.` } },
    { '@type': 'Question', name: `Do you handle concrete work for condo associations in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Yes — we work with HOAs and condo associations in ${city} on pool deck resurfacing, walkway repairs, and parking area restoration. We provide written proposals suitable for board review and can accommodate phased project scheduling.` } },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: `${SITE_CONFIG.domain}/cities/` },
    { '@type': 'ListItem', position: 3, name: city, item: `${SITE_CONFIG.domain}/cities/${citySlug}/` },
  ],
};
---

<BaseLayout
  title={`Concrete Contractor ${city} FL | Pool Decks, Patios & Driveways`}
  description={`Concrete pool decks, patios, and driveways in ${city}, FL. Marine-grade coastal materials for Gulf Blvd barrier island properties. Licensed & insured. Free estimates.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Hero
    headline={`Concrete Contractor in ${city}, FL`}
    subheadline={`Pool decks, patios, and driveways in ${city} — coastal-grade materials, licensed & insured, free written estimates.`}
    ctaText="Get a Free Estimate"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">{city}</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>Concrete Services in {city}, FL</h2>
      <p>
        {city} is one of the smallest municipalities on Gulf Blvd — a tight-knit residential
        community between Redington Shores and Madeira Beach. Despite its size, {city} has
        a high density of Gulf-front homes with pool cages and outdoor living areas that
        require consistent concrete maintenance. The town's close proximity to the Gulf
        means all concrete work must account for salt-air chloride exposure and the
        intensified UV environment of a barrier island.
      </p>

      <h2>Services We Provide in {city}</h2>
      <ul>
        <li><a href="/services/pool-deck-resurfacing">Pool Deck Resurfacing</a> — Overlay and Kool Deck systems for aged pool decks</li>
        <li><a href="/services/concrete-patios">Concrete Patios & Outdoor Living</a> — Stamped and colored finishes for outdoor entertaining</li>
        <li><a href="/services/concrete-driveways">Concrete Driveways</a> — New installation with proper coastal sealing</li>
        <li><a href="/services/marine-grade-concrete-sealing">Marine-Grade Sealing</a> — Penetrating and topcoat systems for salt air</li>
        <li><a href="/services/concrete-repair">Concrete Repair</a> — Crack repair and spalling restoration</li>
        <li><a href="/services/decorative-concrete">Decorative & Stamped Concrete</a> — Travertine and slate patterns for pool decks and patios</li>
      </ul>

      <h2>Decorative Concrete for {city} Properties</h2>
      <p>
        Stamped concrete is particularly popular in {city} — travertine and slate patterns
        give pool decks and patios a high-end look at significantly lower cost than
        natural stone. We use UV-stable color hardeners and topcoat sealers formulated
        for coastal Florida's intense sun and salt air, so the color holds for years
        rather than fading within the first season.
      </p>
    </div>

    <div class="mt-12">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {SITE_CONFIG.services.slice(0, 6).map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-8">Frequently Asked Questions — {city}</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((item) => (
          <details class="border border-gray-200 rounded-xl overflow-hidden group">
            <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold text-primary hover:bg-gray-50 list-none">
              {item.name}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">{item.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading={`Get a Free Estimate in ${city}`} />
    </div>
  </div>
</BaseLayout>
