---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const city = 'St. Pete Beach';
const citySlug = 'st-pete-beach';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: `How much does a concrete driveway cost in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Concrete driveway installation in ${city} typically costs $8–$15 per square foot. A standard 2-car driveway (400–600 sq ft) runs $4,000–$10,000 depending on finish and site prep required. We provide free written estimates after measuring your specific project.` } },
    { '@type': 'Question', name: `Do you need a permit for concrete work in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Most structural concrete work in ${city} (Pinellas County) requires permits — including driveway replacement and new pool deck installation. We handle permit applications and coordinate required inspections. All work is performed to Florida Building Code standards.` } },
    { '@type': 'Question', name: `Can you match existing concrete in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Exact color matching on aged concrete is difficult, but we can get very close using integral colorants or surface-applied color hardeners. For repairs, we typically recommend a full overlay of the affected section or the entire surface to ensure a consistent appearance — especially on pool decks and patios where a patch repair would be visible.` } },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: `${SITE_CONFIG.domain}/cities/` },
    { '@type': 'ListItem', position: 3, name: city, item: `${SITE_CONFIG.domain}/cities/${citySlug}/` },
  ],
};
---

<BaseLayout
  title={`Concrete Contractor ${city} FL | Driveways, Pool Decks & Patios`}
  description={`Concrete driveways, pool decks, patios, and foundations in ${city}, FL. Marine-grade coastal materials. Licensed & insured. Free estimates.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Hero
    headline={`Concrete Contractor in ${city}, FL`}
    subheadline={`Pool decks, driveways, patios, and foundations in ${city} — marine-grade materials rated for Gulf Coast salt air. Licensed & insured. Free written estimates.`}
    ctaText="Get a Free Estimate"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">{city}</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>Concrete Services in {city}, FL</h2>
      <p>
        {city} is the southernmost community on the Gulf Beaches barrier island, anchored
        by the historic Don CeSar hotel and a dense mix of residential, condo, and vacation
        rental properties along Gulf Blvd and its beach side streets. With a permanent
        population that swells seasonally and a robust short-term rental market, {city}
        properties face year-round concrete wear from heavy foot traffic, UV exposure, and
        the constant salt-air environment of the Gulf of Mexico.
      </p>

      <h2>Services We Provide in {city}</h2>
      <ul>
        <li><a href="/services/pool-deck-resurfacing">Pool Deck Resurfacing</a> — Overlay systems and new installations for residential and rental properties</li>
        <li><a href="/services/concrete-driveways">Concrete Driveways</a> — New installation and replacement with marine-grade sealing</li>
        <li><a href="/services/concrete-patios">Concrete Patios & Outdoor Living</a> — Stamped, colored, and brushed finish options</li>
        <li><a href="/services/marine-grade-concrete-sealing">Marine-Grade Sealing</a> — Salt air chloride protection for all concrete surfaces</li>
        <li><a href="/services/concrete-repair">Concrete Repair & Restoration</a> — Crack repair, spalling, and surface restoration</li>
        <li><a href="/services/concrete-foundations">Concrete Foundations</a> — Hurricane-ready foundations to FL Building Code</li>
      </ul>

      <h2>Concrete Driveways in {city}</h2>
      <p>
        Concrete driveways are among the most common projects we handle in {city}. The
        combination of sandy subbase, seasonal flooding near the Gulf, and salt-spray
        exposure accelerates driveway deterioration. We pour with reinforced concrete
        using a proper subbase compaction, expansion joints placed for Florida's
        climate, and seal immediately after cure with a penetrating marine-grade sealer.
      </p>
    </div>

    <div class="mt-12">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {SITE_CONFIG.services.slice(0, 6).map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-8">Frequently Asked Questions — {city}</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((item) => (
          <details class="border border-gray-200 rounded-xl overflow-hidden group">
            <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold text-primary hover:bg-gray-50 list-none">
              {item.name}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">{item.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading={`Get a Free Estimate in ${city}`} />
    </div>
  </div>
</BaseLayout>
