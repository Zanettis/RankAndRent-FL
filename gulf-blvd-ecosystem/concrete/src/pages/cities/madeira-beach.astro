---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const city = 'Madeira Beach';
const citySlug = 'madeira-beach';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: `How much does pool deck resurfacing cost in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Pool deck resurfacing in ${city} typically costs $3–$8 per square foot for standard overlay systems. A typical pool deck of 400–600 sq ft runs $1,500–$5,000 for resurfacing. New pool deck installation costs $8–$18 per square foot. We provide free written estimates.` } },
    { '@type': 'Question', name: `Do vacation rental properties in ${city} need concrete work?`, acceptedAnswer: { '@type': 'Answer', text: `Vacation rental properties in ${city} benefit significantly from pool deck and patio updates — guests paying $400–$700+/night expect pristine outdoor areas. A resurfaced pool deck and fresh sealed patio can improve guest reviews and justify higher nightly rates. We offer priority scheduling for rental property owners.` } },
    { '@type': 'Question', name: `Can you repair hurricane-damaged concrete in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Yes. After storm events, we assess concrete damage including cracked slabs, displaced pavers (where concrete borders are needed), and foundation damage. We prioritize emergency calls in ${city} after named storms.` } },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: `${SITE_CONFIG.domain}/cities/` },
    { '@type': 'ListItem', position: 3, name: city, item: `${SITE_CONFIG.domain}/cities/${citySlug}/` },
  ],
};
---

<BaseLayout
  title={`Concrete Contractor ${city} FL | Pool Decks, Driveways & Patios`}
  description={`Concrete pool decks, driveways, and patios in ${city}, FL. Vacation rental and residential concrete work along Gulf Blvd. Marine-grade materials. Free estimates.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Hero
    headline={`Concrete Contractor in ${city}, FL`}
    subheadline={`Pool decks, driveways, and concrete work for ${city} homeowners and vacation rental properties. Licensed & insured. Free written estimates.`}
    ctaText="Get a Free Estimate"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">{city}</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>Concrete Services in {city}, FL</h2>
      <p>
        {city} is one of the most visited and highest-demand rental markets on the Gulf Blvd
        corridor, known for John's Pass Village and a dense concentration of Gulf-front
        vacation properties. The combination of heavy foot traffic on pool decks and
        constant salt-air exposure makes concrete maintenance particularly important for
        {city} property owners — especially those managing rental income properties.
      </p>

      <h2>Services We Provide in {city}</h2>
      <ul>
        <li><a href="/services/pool-deck-resurfacing">Pool Deck Resurfacing</a> — Complete pool deck overlays and new installations for rental and residential properties</li>
        <li><a href="/services/concrete-driveways">Concrete Driveways</a> — New driveways and driveway replacement with coastal sealing</li>
        <li><a href="/services/decorative-concrete">Decorative & Stamped Concrete</a> — Stamped travertine and slate patterns popular in the Gulf Beaches market</li>
        <li><a href="/services/concrete-repair">Concrete Repair</a> — Fast turnaround crack repair and surface restoration for rental properties</li>
        <li><a href="/services/marine-grade-concrete-sealing">Marine-Grade Sealing</a> — Salt air protection for all concrete surfaces</li>
        <li><a href="/services/concrete-overlay">Concrete Overlay</a> — Transform worn pool decks and patios without full replacement</li>
      </ul>

      <h2>Concrete Work for {city} Vacation Rentals</h2>
      <p>
        Vacation rental guests in {city} notice the condition of pool decks and patios
        immediately — it's reflected in reviews. A cracked, stained pool deck means
        lower ratings and lower booking rates. We offer priority scheduling for rental
        property owners between guest turnovers.
      </p>
    </div>

    <div class="mt-12">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {SITE_CONFIG.services.slice(0, 6).map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-8">Frequently Asked Questions — {city}</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((item) => (
          <details class="border border-gray-200 rounded-xl overflow-hidden group">
            <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold text-primary hover:bg-gray-50 list-none">
              {item.name}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">{item.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading={`Get a Free Estimate in ${city}`} />
    </div>
  </div>
</BaseLayout>
