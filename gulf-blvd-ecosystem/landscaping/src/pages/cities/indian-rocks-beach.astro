---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const city = 'Indian Rocks Beach';
const citySlug = 'indian-rocks-beach';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: `What landscaping services are most popular in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `${city} vacation rental owners most commonly request lawn care maintenance contracts, post-storm cleanup, and tropical landscape design. Gulf-front properties need salt-tolerant species like Bougainvillea, Plumbago, and Beach Sunflower. Year-round mowing contracts are in high demand from property managers who need reliable service between guest stays.` } },
    { '@type': 'Question', name: `Do you offer priority landscaping service for vacation rentals in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Yes. ${city} has one of the highest vacation rental concentrations on Gulf Blvd. We offer priority scheduling for property managers — post-storm cleanup between guest stays, weekly mowing tied to check-in/check-out cycles, and curb appeal refreshes before peak season. Contact us before storm season to set up a priority response agreement.` } },
    { '@type': 'Question', name: `What grass type is common in ${city} and how should it be maintained?`, acceptedAnswer: { '@type': 'Answer', text: `St. Augustine grass is the dominant turf in ${city}. It requires mowing at 3.5–4 inches — never shorter, which causes scalping and weakens roots in the sandy coastal soil. Year-round mowing is necessary in Pinellas County's subtropical climate. During the June–September Pinellas fertilizer blackout, no nitrogen or phosphorus applications are permitted. We schedule fertilizer treatments in early March and October/November.` } },
    { '@type': 'Question', name: `How do you design landscapes for Gulf-front properties in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Gulf-front properties in ${city} require a salt-tolerant species palette. We conduct a site assessment that maps salt spray intensity by zone — Gulf-facing beds require highly salt-tolerant species (Bougainvillea, Lantana, Beach Sunflower), while street-facing and shaded areas can use broader species selections. We also evaluate HOA guidelines for properties in managed communities before specifying any plants.` } },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: `${SITE_CONFIG.domain}/cities/` },
    { '@type': 'ListItem', position: 3, name: city, item: `${SITE_CONFIG.domain}/cities/${citySlug}/` },
  ],
};
---

<BaseLayout
  title={`Landscaping ${city} FL | Vacation Rental Lawn Care & Tropical Design`}
  description={`Professional landscaping in ${city}, FL. Year-round lawn care for vacation rentals, tropical salt-tolerant design for Gulf-front properties. Priority post-storm cleanup. Licensed & insured. Free estimates.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Hero
    headline={`Landscaping in ${city}, FL — Year-Round, Vacation Rental Ready`}
    subheadline={`Lawn maintenance, tropical landscape design, and post-storm cleanup in ${city}. Priority scheduling for property managers. Free estimates.`}
    ctaText="Get a Free Estimate"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">{city}</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>Landscaping in {city}, FL</h2>
      <p>
        {city} sits at the northern gateway of the Gulf Boulevard corridor — a barrier island
        community with a high concentration of vacation rentals, Gulf-front homes, and the
        salt spray conditions that make standard landscaping practices fail. What works
        inland in Pinellas County often fails within a season on {city}'s Gulf-facing properties.
      </p>
      <p>
        We specialize in the two things {city} property owners need most: reliable year-round
        lawn maintenance (especially critical for rental properties between guest stays) and
        landscape design that uses species actually proven to handle constant salt exposure.
        We've worked Gulf-front properties here long enough to know which species survive
        and which ones look great at the nursery and fail by October.
      </p>

      <h2>Services Available in {city}</h2>
      <ul>
        <li><a href="/services/lawn-care">Lawn Care & Grass Cutting</a> — Year-round St. Augustine maintenance with priority rental property scheduling</li>
        <li><a href="/services/landscape-design">Landscape Design & Installation</a> — Salt-tolerant tropical plantings for Gulf-front and near-beach properties</li>
        <li><a href="/services/hurricane-storm-prep">Hurricane & Storm Prep</a> — Pre-season prep and post-storm cleanup before guest arrivals</li>
        <li><a href="/services/irrigation-systems">Irrigation Systems</a> — Installation, repair, and SWFWMD-compliant programming</li>
        <li><a href="/services/mulching-ground-cover">Mulching & Ground Cover</a> — Storm-resistant rubber mulch and pine bark for coastal beds</li>
      </ul>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-6">Our Services</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {SITE_CONFIG.services.map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-8">Frequently Asked Questions — {city}</h2>
      <div class="space-y-4">
        {[
          { q: `What landscaping services are most popular in ${city}?`, a: `Lawn maintenance contracts, post-storm cleanup, and tropical landscape design for Gulf-front properties. Bougainvillea, Plumbago, and Beach Sunflower are our most-installed species on the Gulf-facing side.` },
          { q: `Do you offer priority landscaping service for vacation rentals in ${city}?`, a: `Yes — we offer priority scheduling for property managers. Post-storm cleanup between guest stays, weekly mowing tied to check-in/check-out cycles, and pre-season curb appeal refreshes.` },
          { q: `What grass type is common in ${city} and how should it be maintained?`, a: `St. Augustine grass dominates ${city}. Mow at 3.5–4 inches — never scalp. No nitrogen/phosphorus fertilizer June–September (Pinellas blackout). Fertilize in March and October/November.` },
          { q: `How do you design landscapes for Gulf-front properties in ${city}?`, a: `We map salt spray intensity by zone — Gulf-facing beds get highly salt-tolerant species (Bougainvillea, Lantana, Beach Sunflower), shaded areas get broader selections. We review HOA guidelines before specifying.` },
        ].map(({ q, a }) => (
          <details class="border border-gray-200 rounded-xl overflow-hidden group">
            <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold text-primary hover:bg-gray-50 list-none">
              {q}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">{a}</div>
          </details>
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading={`Get a Free Estimate in ${city}`} />
    </div>
  </div>
</BaseLayout>
