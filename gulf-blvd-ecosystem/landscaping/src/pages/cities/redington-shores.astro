---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const city = 'Redington Shores';
const citySlug = 'redington-shores';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: `How do you design landscapes for canal-front properties in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `${city} has a significant number of canal-front properties, which present a dual landscaping challenge: the street-facing side needs standard Gulf Blvd salt-tolerant species, while the canal-facing rear needs plants that tolerate both salt air and periodic flooding or high water table. We design separate planting zones for each exposure — Mangrove-compatible species near the water's edge, and a tropical ornamental palette for the drier street side. Canal-side beds also benefit from ground covers that stabilize soil near the water.` } },
    { '@type': 'Question', name: `What grass grows best in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `St. Augustine grass is the standard turf in ${city} and the most appropriate for the coastal soil and climate conditions. It requires mowing at 3.5–4 inches — scalping causes root stress in the sandy soil. During Pinellas County's fertilizer blackout (June 1–September 30), no nitrogen or phosphorus applications are permitted. St. Augustine in ${city} is also vulnerable to chinch bug damage in dry, hot summer conditions — early detection and treatment are key.` } },
    { '@type': 'Question', name: `Do you offer irrigation installation for ${city} canal-front homes?`, acceptedAnswer: { '@type': 'Answer', text: `Yes. Canal-front properties in ${city} require careful irrigation zone design — the canal-side areas often have higher natural moisture and need different zone timing than the street-facing side. We design systems with separate zones for each distinct area, program for SWFWMD compliance, and include the rain sensor and backflow preventer required by Pinellas County code.` } },
    { '@type': 'Question', name: `How do you prepare a ${city} landscape for hurricane season?`, acceptedAnswer: { '@type': 'Answer', text: `Pre-season prep in ${city} focuses on reducing wind resistance and securing loose materials. We trim dead fronds from palms (never green), cut back ornamentals like Bougainvillea and Bird of Paradise to reduce canopy size, assess mulch type (replacing fine shredded wood with pine bark nuggets or rubber mulch if needed), and identify any potted plants or planters that should be moved inside before a named storm. Book in April or May — pre-season slots fill by mid-May.` } },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: `${SITE_CONFIG.domain}/cities/` },
    { '@type': 'ListItem', position: 3, name: city, item: `${SITE_CONFIG.domain}/cities/${citySlug}/` },
  ],
};
---

<BaseLayout
  title={`Landscaping ${city} FL | Canal-Front Landscape Design & Lawn Maintenance`}
  description={`Professional landscaping in ${city}, FL. Dual-zone design for canal-front properties, St. Augustine lawn maintenance, irrigation, hurricane prep. Licensed & insured. Free estimates.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Hero
    headline={`Landscaping in ${city}, FL — Canal-Front & Gulf Coast Specialists`}
    subheadline={`Dual-zone landscape design for ${city}'s canal-front properties. Street-facing tropical plantings and canal-side water-tolerant species. Year-round maintenance. Free estimates.`}
    ctaText="Get a Free Estimate"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">{city}</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>Landscaping in {city}, FL</h2>
      <p>
        {city} has a high proportion of canal-front properties — homes with a street-facing
        front yard and a canal-facing back that presents two completely different planting
        environments. The front needs Gulf Blvd salt-tolerant species that handle coastal
        breezes and reflected heat from the road. The canal side needs plants that can handle
        occasional high water tables, periodic flooding, and the additional moisture that
        proximity to water creates.
      </p>
      <p>
        We treat these as separate design zones on every {city} canal-front property. A
        single uniform plant palette that works on one side will fail on the other. Our
        site assessments map each distinct microclimate before we specify anything.
      </p>

      <h2>Services Available in {city}</h2>
      <ul>
        <li><a href="/services/lawn-care">Lawn Care & Grass Cutting</a> — Year-round St. Augustine maintenance calibrated for coastal sandy soil</li>
        <li><a href="/services/landscape-design">Landscape Design & Installation</a> — Dual-zone design for canal-front properties, salt-tolerant street-side palette</li>
        <li><a href="/services/hurricane-storm-prep">Hurricane & Storm Prep</a> — Pre-season hardening and post-storm debris removal</li>
        <li><a href="/services/irrigation-systems">Irrigation Systems</a> — Separate zone design for street-facing and canal-facing areas</li>
        <li><a href="/services/mulching-ground-cover">Mulching & Ground Cover</a> — Salt-tolerant ground covers for canal-side beds</li>
      </ul>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-6">Our Services</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {SITE_CONFIG.services.map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-8">Frequently Asked Questions — {city}</h2>
      <div class="space-y-4">
        {[
          { q: `How do you design landscapes for canal-front properties in ${city}?`, a: `We design separate planting zones for each exposure. Street-facing: Gulf salt-tolerant ornamentals. Canal-facing: species tolerant of higher moisture, flooding, and salt air. Canal-side beds also benefit from ground covers that stabilize soil near the water.` },
          { q: `What grass grows best in ${city}?`, a: `St. Augustine grass — mow at 3.5–4 inches, never scalp. No nitrogen/phosphorus June 1–September 30 (Pinellas blackout). Watch for chinch bugs in dry hot summers — early detection is key.` },
          { q: `Do you offer irrigation installation for ${city} canal-front homes?`, a: `Yes — we design separate irrigation zones for street-facing and canal-side areas. Canal zones often need different timing due to higher natural moisture. Rain sensor and backflow preventer included as required by Pinellas County code.` },
          { q: `How do you prepare a ${city} landscape for hurricane season?`, a: `Trim dead palm fronds (never green), cut back Bougainvillea and Bird of Paradise canopy, assess and replace fine mulch with pine bark or rubber. Book April or May — pre-season slots fill by mid-May.` },
        ].map(({ q, a }) => (
          <details class="border border-gray-200 rounded-xl overflow-hidden group">
            <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold text-primary hover:bg-gray-50 list-none">
              {q}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">{a}</div>
          </details>
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading={`Get a Free Estimate in ${city}`} />
    </div>
  </div>
</BaseLayout>
