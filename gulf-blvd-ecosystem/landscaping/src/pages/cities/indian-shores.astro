---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const city = 'Indian Shores';
const citySlug = 'indian-shores';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: `Do you offer year-round lawn maintenance contracts in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Yes. ${city} is primarily a permanent resident community with larger lots than many Gulf Blvd municipalities — ideal for year-round maintenance contracts. We offer weekly and bi-weekly mowing contracts that include edging, blowing, and periodic bed maintenance. Long-term contract clients in ${city} get priority scheduling during storm season.` } },
    { '@type': 'Question', name: `How often should I fertilize my lawn in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Pinellas County's fertilizer blackout runs June 1 through September 30 — no nitrogen or phosphorus applications during the rainy season. For St. Augustine grass in ${city}, we recommend a slow-release application in early March (pre-rainy season), and a second application in October or November (post-blackout, before winter). This two-application schedule is sufficient for most ${city} lawns.` } },
    { '@type': 'Question', name: `What is causing brown patches in my ${city} lawn?`, acceptedAnswer: { '@type': 'Answer', text: `Brown patches in ${city} St. Augustine lawns are most commonly caused by: chinch bugs (hot, sunny areas that dry out quickly), brown patch fungus (over-watered areas, evening irrigation), or salt burn (near-beach properties after storm events). Chinch bugs are the most common summer culprit. We assess your lawn and provide a treatment recommendation — don't apply pesticides before identifying the actual cause.` } },
    { '@type': 'Question', name: `Can you install an irrigation system for my ${city} home?`, acceptedAnswer: { '@type': 'Answer', text: `Yes. We install complete irrigation systems in ${city} programmed for SWFWMD compliance — twice per week, no irrigation between 10am and 4pm. All systems include a rain sensor (required by Pinellas County code) and backflow preventer. ${city}'s sandy soils require careful zone timing to achieve the 4–6 inch soil penetration that St. Augustine roots need without over-saturating.` } },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: `${SITE_CONFIG.domain}/cities/` },
    { '@type': 'ListItem', position: 3, name: city, item: `${SITE_CONFIG.domain}/cities/${citySlug}/` },
  ],
};
---

<BaseLayout
  title={`Landscaping ${city} FL | Year-Round Lawn Maintenance & Irrigation`}
  description={`Professional landscaping in ${city}, FL. Year-round lawn maintenance contracts, irrigation installation, tropical design. Pinellas County fertilizer schedule compliance. Licensed & insured. Free estimates.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Hero
    headline={`Landscaping in ${city}, FL — Year-Round Maintenance Contracts`}
    subheadline={`Reliable lawn care, irrigation, and landscape maintenance for ${city} homeowners. Long-term contracts welcome. SWFWMD compliant. Free estimates.`}
    ctaText="Get a Free Estimate"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">{city}</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>Landscaping in {city}, FL</h2>
      <p>
        {city} is one of the quieter residential communities on Gulf Blvd — a tight-knit town
        where most properties are permanent residences rather than vacation rentals. Lots tend
        to be slightly larger than the communities to the north, and homeowners here are more
        likely to want long-term relationships with a reliable landscaper than one-off services.
      </p>
      <p>
        We serve {city} with year-round lawn maintenance contracts, irrigation installation and
        repair, and tropical landscape design for both Gulf-facing and canal-side properties.
        Long-term contract clients in {city} receive priority scheduling during hurricane season
        — an important benefit in a community where storm cleanup demand spikes significantly.
      </p>

      <h2>Services Available in {city}</h2>
      <ul>
        <li><a href="/services/lawn-care">Lawn Care & Grass Cutting</a> — Weekly and bi-weekly contracts for St. Augustine lawns</li>
        <li><a href="/services/landscape-design">Landscape Design & Installation</a> — Tropical design for Gulf-facing and canal-front properties</li>
        <li><a href="/services/hurricane-storm-prep">Hurricane & Storm Prep</a> — Pre-season prep and post-storm debris removal</li>
        <li><a href="/services/irrigation-systems">Irrigation Systems</a> — New installation and repair, SWFWMD-compliant programming</li>
        <li><a href="/services/mulching-ground-cover">Mulching & Ground Cover</a> — Annual mulch refresh and salt-tolerant ground cover installation</li>
      </ul>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-6">Our Services</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {SITE_CONFIG.services.map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-8">Frequently Asked Questions — {city}</h2>
      <div class="space-y-4">
        {[
          { q: `Do you offer year-round lawn maintenance contracts in ${city}?`, a: `Yes — weekly and bi-weekly mowing contracts that include edging, blowing, and periodic bed maintenance. Long-term contract clients get priority scheduling during storm season.` },
          { q: `How often should I fertilize my lawn in ${city}?`, a: `Pinellas blackout runs June 1–September 30: no nitrogen or phosphorus. For St. Augustine, apply slow-release in early March and again in October/November. Two applications per year is sufficient for most ${city} lawns.` },
          { q: `What is causing brown patches in my ${city} lawn?`, a: `Most commonly chinch bugs (dry sunny areas), brown patch fungus (over-watered/evening irrigation), or salt burn near the beach after storms. Chinch bugs are the most common summer culprit — always identify the cause before treating.` },
          { q: `Can you install an irrigation system for my ${city} home?`, a: `Yes — complete installations programmed for SWFWMD compliance. Rain sensor and backflow preventer included (both required by Pinellas County code). Sandy soils require careful zone timing for proper root penetration.` },
        ].map(({ q, a }) => (
          <details class="border border-gray-200 rounded-xl overflow-hidden group">
            <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold text-primary hover:bg-gray-50 list-none">
              {q}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">{a}</div>
          </details>
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading={`Get a Free Estimate in ${city}`} />
    </div>
  </div>
</BaseLayout>
