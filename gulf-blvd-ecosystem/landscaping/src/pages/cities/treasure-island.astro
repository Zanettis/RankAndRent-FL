---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const city = 'Treasure Island';
const citySlug = 'treasure-island';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: `Do you manage HOA landscape maintenance contracts in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Yes. ${city} has a large number of condo associations and HOA-managed communities — some of the largest on the Gulf Blvd corridor. We bid on and manage multi-year HOA landscape maintenance contracts that include mowing of common areas, bed maintenance, mulching, irrigation maintenance, and seasonal plant programs. We provide written monthly reports and documentation suitable for HOA board meetings, property management companies, and insurance records.` } },
    { '@type': 'Question', name: `What is a typical HOA landscape maintenance budget for a ${city} condo complex?`, acceptedAnswer: { '@type': 'Answer', text: `HOA landscape maintenance budgets for ${city} condo complexes typically range from $6,000 to $25,000 per year depending on the property size, number of common area beds, irrigation complexity, and service frequency. We provide detailed line-item proposals formatted for HOA budget review. We're experienced working within multi-year contracts and HOA procurement processes.` } },
    { '@type': 'Question', name: `Can you redesign the common area landscaping for a ${city} condo association?`, acceptedAnswer: { '@type': 'Answer', text: `Yes. Complete landscape redesigns for ${city} condo common areas are a core part of our work. We provide design proposals with species lists, cost estimates, and phasing options (full installation vs. phased over multiple seasons). All species we specify are salt-tolerant, low-maintenance relative to ornamental alternatives, and compliant with Pinellas County's invasive species regulations. We handle HOA architectural review approval as part of the project.` } },
    { '@type': 'Question', name: `How do you handle post-storm landscape cleanup for a large ${city} condo complex?`, acceptedAnswer: { '@type': 'Answer', text: `For HOA clients with existing contracts, post-storm cleanup is prioritized. We deploy larger crews to ${city} condo properties within 24–48 hours of storm clearance. Cleanup includes debris removal, salt burn assessment of common area plants, irrigation system inspection, and re-mulching of washed-out beds. We provide written damage documentation suitable for insurance claims, which many ${city} condo associations require for their property insurance reporting.` } },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: `${SITE_CONFIG.domain}/cities/` },
    { '@type': 'ListItem', position: 3, name: city, item: `${SITE_CONFIG.domain}/cities/${citySlug}/` },
  ],
};
---

<BaseLayout
  title={`Landscaping ${city} FL | HOA Condo Landscape Maintenance & Design`}
  description={`Professional landscaping in ${city}, FL. HOA and condo association landscape maintenance contracts, common area redesign, post-storm cleanup with insurance documentation. Licensed & insured. Free estimates.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Hero
    headline={`Landscaping in ${city}, FL — HOA & Condo Landscape Specialists`}
    subheadline={`Multi-year HOA landscape maintenance contracts for ${city} condo associations. Common area redesign, post-storm cleanup, board-ready documentation. Free estimates.`}
    ctaText="Get a Free Estimate"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">{city}</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>Landscaping in {city}, FL</h2>
      <p>
        {city} has one of the largest concentrations of condo associations and HOA-managed
        properties on the Gulf Blvd corridor. Commercial and residential properties here operate
        within HOA governance structures where landscape decisions require board approval,
        maintenance documentation, and multi-year contract frameworks — not the informal
        agreements that work for single-family homeowners.
      </p>
      <p>
        We work within HOA processes. We provide written proposals formatted for board review,
        phased installation options to fit annual budget cycles, monthly maintenance reports
        that property managers can use directly, and post-storm damage documentation formatted
        for insurance claims. If your {city} condo association is looking for a landscaping
        partner — not just a vendor — we'd like to talk.
      </p>

      <h2>Services Available in {city}</h2>
      <ul>
        <li><a href="/services/lawn-care">Lawn Care & Grass Cutting</a> — HOA common area mowing, year-round residential maintenance</li>
        <li><a href="/services/landscape-design">Landscape Design & Installation</a> — Common area redesign with HOA approval support</li>
        <li><a href="/services/hurricane-storm-prep">Hurricane & Storm Prep</a> — Pre-season hardening and priority post-storm cleanup with insurance documentation</li>
        <li><a href="/services/irrigation-systems">Irrigation Systems</a> — Multi-zone irrigation for large condo properties, repair and installation</li>
        <li><a href="/services/mulching-ground-cover">Mulching & Ground Cover</a> — Common area mulching and ground cover programs</li>
      </ul>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-6">Our Services</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {SITE_CONFIG.services.map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-8">Frequently Asked Questions — {city}</h2>
      <div class="space-y-4">
        {[
          { q: `Do you manage HOA landscape maintenance contracts in ${city}?`, a: `Yes — we bid on and manage multi-year HOA contracts. Mowing, bed maintenance, mulching, irrigation maintenance, seasonal plant programs. Monthly written reports suitable for HOA board meetings and property management companies.` },
          { q: `What is a typical HOA landscape maintenance budget for a ${city} condo complex?`, a: `Typically $6,000–$25,000 per year depending on property size, common area beds, irrigation complexity, and service frequency. We provide detailed line-item proposals formatted for HOA budget review.` },
          { q: `Can you redesign the common area landscaping for a ${city} condo association?`, a: `Yes — full common area redesigns with species lists, cost estimates, and phasing options. All species are salt-tolerant, low-maintenance, and compliant with Pinellas invasive species regulations. HOA architectural review handling included.` },
          { q: `How do you handle post-storm landscape cleanup for a large ${city} condo complex?`, a: `HOA contract clients get priority response — larger crews within 24–48 hours of storm clearance. Debris removal, salt burn assessment, irrigation inspection, re-mulching. Written damage documentation for insurance claims included.` },
        ].map(({ q, a }) => (
          <details class="border border-gray-200 rounded-xl overflow-hidden group">
            <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold text-primary hover:bg-gray-50 list-none">
              {q}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">{a}</div>
          </details>
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading={`Get a Free Estimate in ${city}`} />
    </div>
  </div>
</BaseLayout>
