---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import LeadForm from '../components/LeadForm.astro';
import CrossLinkWidget from '../components/CrossLinkWidget.astro';
import { SITE_CONFIG } from '../config';

const serviceIcons = [
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12a9 9 0 1018 0 9 9 0 00-18 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 3c0 0-3 4-3 9s3 9 3 9M12 3c0 0 3 4 3 9s-3 9-3 9M3 12h18"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 2c0 0-4 5-4 10a4 4 0 008 0C16 7 12 2 12 2z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 12v10"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8"><circle cx="12" cy="12" r="3"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>`,
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How much does lawn care cost on Gulf Blvd, FL?',
      acceptedAnswer: { '@type': 'Answer', text: 'Lawn care on Gulf Blvd typically ranges from $40 to $150 per visit depending on lot size, grass type, and services included (mowing only vs. mowing, edging, and blowing). Most residential properties on the Gulf Blvd corridor fall in the $60–$100 range per visit. We provide free estimates before any work begins.' },
    },
    {
      '@type': 'Question',
      name: 'What type of grass is best for Gulf Blvd properties?',
      acceptedAnswer: { '@type': 'Answer', text: 'St. Augustine grass dominates Gulf Blvd for good reason — it tolerates salt air, moderate shade, and Florida\'s subtropical humidity far better than Bermuda or Zoysia. It spreads by stolons, requires mowing at 3.5–4 inches (never scalp it), and performs well with twice-weekly irrigation on the SWFWMD schedule. It is the right choice for almost every property on the corridor.' },
    },
    {
      '@type': 'Question',
      name: 'Do you handle landscaping for HOA condo complexes on Gulf Blvd?',
      acceptedAnswer: { '@type': 'Answer', text: 'Yes. We work with HOA boards and property management companies for condo complexes throughout the Gulf Blvd corridor. We\'re experienced with HOA approval processes for landscape redesigns and can provide written specifications and plant lists that meet association requirements. We also offer multi-unit maintenance contracts for consistent service.' },
    },
    {
      '@type': 'Question',
      name: 'How do I prepare my Gulf Blvd landscape for hurricane season?',
      acceptedAnswer: { '@type': 'Answer', text: 'Pre-season preparation should be done in April or May — at least 6 weeks before June 1st. Key steps include trimming palm fronds (dead fronds only — never remove green fronds), cutting back overgrown ornamentals to reduce wind resistance, securing or raking back loose mulch (it becomes airborne above 45 mph), and staking or moving potted plants. We offer a dedicated hurricane landscape prep service.' },
    },
    {
      '@type': 'Question',
      name: 'What plants survive salt spray on beachfront properties?',
      acceptedAnswer: { '@type': 'Answer', text: 'The most reliably salt-tolerant ornamentals for Gulf Blvd beachfront properties are Bougainvillea, Ixora, Plumbago, Lantana, Sago Palm, and Croton. For ground covers, Asiatic jasmine, perennial peanut (Arachis glabrata), and Beach Sunflower all handle salt spray well. We design planting schemes specifically around your sun exposure, HOA rules, and salt spray intensity.' },
    },
    {
      '@type': 'Question',
      name: 'Do you install and repair irrigation systems on Gulf Blvd?',
      acceptedAnswer: { '@type': 'Answer', text: 'Yes — new installation, repair, and SWFWMD-compliant scheduling. Pinellas County requires rain sensors on all new irrigation systems, and we install smart controllers with ET-based scheduling that automatically adjusts for rainfall. We also repair common issues on the corridor: broken heads from mowing equipment, corroded fittings from salt air, and cracked PVC lines from sandy soil movement.' },
    },
    {
      '@type': 'Question',
      name: 'Do you offer landscaping service for vacation rental properties?',
      acceptedAnswer: { '@type': 'Answer', text: 'Absolutely. We work with property managers and Airbnb hosts throughout Indian Rocks Beach, Treasure Island, Madeira Beach, and St. Pete Beach. We offer priority scheduling for vacation rentals — post-storm cleanup between guest stays and pre-season prep before summer rental season. Consistent curb appeal is critical for rental reviews, and we understand the turnaround timeline.' },
    },
    {
      '@type': 'Question',
      name: 'What is SWFWMD and how does it affect lawn watering schedules?',
      acceptedAnswer: { '@type': 'Answer', text: 'SWFWMD stands for Southwest Florida Water Management District — locals call it "Swiftmud." It sets mandatory irrigation restrictions for Pinellas County: typically twice per week on an odd/even day schedule based on your address, with no watering between 10am and 4pm. Violations carry fines. All irrigation systems we install include rain sensors (required by Pinellas County code) and are programmed for SWFWMD compliance from day one.' },
    },
  ],
};

const testimonials = [
  {
    quote: "They completely redesigned our front yard after Hurricane Idalia — all salt-tolerant plants, Bougainvillea, Ixora. A year later it still looks incredible.",
    name: "Sandra K.",
    location: "Indian Rocks Beach, FL",
  },
  {
    quote: "Best lawn service on the corridor. They know St. Augustine grass here isn't like the rest of Florida — they actually know what they're doing.",
    name: "Mike T.",
    location: "Madeira Beach, FL",
  },
  {
    quote: "I manage six vacation rentals on Treasure Island and Gulf Blvd Landscaping does all the grounds. Reliable, professional, never a complaint from a guest.",
    name: "Rachel H.",
    location: "Treasure Island, FL",
  },
];
---

<BaseLayout
  title="Landscaping Gulf Blvd FL | Lawn Care, Design & Hurricane Prep | Indian Rocks Beach to St. Pete Beach"
  description="Professional lawn care, landscape design, irrigation, hurricane prep, and mulching along Gulf Boulevard, FL. St. Augustine grass specialists. Salt-tolerant tropical plantings. Licensed & insured. Free estimates."
  aggregateRating={{ ratingValue: "4.9", reviewCount: "73" }}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Hero
    headline="Gulf Blvd's Landscaping Experts — Year-Round, Hurricane Ready"
    subheadline="Lawn care, tropical landscape design, irrigation, and storm prep from Indian Rocks Beach to St. Pete Beach. St. Augustine grass specialists. We answer the phone."
    ctaText="Get a Free Quote"
    secondaryCtaText={`Call ${SITE_CONFIG.phone}`}
    secondaryCtaHref={`tel:${SITE_CONFIG.phone}`}
    badges={["Licensed & Insured", "Free Estimates", "Hurricane Season Ready", "St. Augustine Specialists"]}
  />

  <!-- Trust Bar -->
  <div class="bg-white border-b border-gray-100 shadow-sm">
    <div class="max-w-6xl mx-auto px-4 py-4 flex flex-wrap justify-center gap-x-8 gap-y-2 text-sm text-gray-600">
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        We Pick Up The Phone
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        Year-Round Lawn Care
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        FL Licensed & Insured
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        Free Written Estimates
      </span>
    </div>
  </div>

  <!-- Services -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <h2 class="text-3xl font-bold text-primary text-center mb-4">Our Landscaping Services</h2>
    <p class="text-gray-600 text-center max-w-2xl mx-auto mb-10">
      From weekly lawn maintenance to full tropical landscape design and hurricane storm prep —
      we cover every landscaping need along Gulf Boulevard, with crews who understand Florida's
      coastal conditions, salt air, and St. Augustine grass.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {SITE_CONFIG.services.map((service, i) => (
        <ServiceCard
          title={service.title}
          description={service.description}
          href={service.href}
          icon={serviceIcons[i] ?? serviceIcons[0]}
        />
      ))}
    </div>
  </section>

  <!-- Hurricane Season Prep Pitch -->
  <section class="bg-accent/10 border-y border-accent/20 py-16 px-4">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
      <div>
        <span class="inline-block bg-accent/20 text-primary font-semibold text-sm px-3 py-1 rounded-full mb-4">Hurricane Season Starts June 1st</span>
        <h2 class="text-3xl font-bold text-primary mb-4">Is Your Gulf Blvd Landscape Ready for Hurricane Season?</h2>
        <p class="text-gray-700 leading-relaxed mb-4">
          Loose mulch becomes a projectile above 45 mph winds. Overgrown Bougainvillea catches wind like a sail.
          An untrimmed palm with a heavy frond load can fail onto a roof or pool cage.
          On Gulf Blvd — where properties sit tight against the water — one poorly prepared yard
          can mean thousands in property damage.
        </p>
        <p class="text-gray-700 leading-relaxed mb-6">
          We recommend booking pre-season landscape prep in April or May — at least 6 weeks before
          June 1st. Our crews trim palms, cut back ornamentals, secure mulch beds, and remove anything
          that could become a wind hazard. Post-storm cleanup is available 24/7 after major events.
        </p>
        <a href="/services/hurricane-storm-prep" class="inline-block bg-cta text-white font-bold px-6 py-3 rounded-lg hover:opacity-90 transition-opacity">
          Book Hurricane Prep →
        </a>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div class="bg-white rounded-xl p-5 shadow-sm text-center">
          <div class="text-3xl font-bold text-primary mb-1">May–Nov</div>
          <div class="text-sm text-gray-600">Hurricane season window</div>
        </div>
        <div class="bg-white rounded-xl p-5 shadow-sm text-center">
          <div class="text-3xl font-bold text-primary mb-1">St. Augustine</div>
          <div class="text-sm text-gray-600">FL's #1 grass type</div>
        </div>
        <div class="bg-white rounded-xl p-5 shadow-sm text-center">
          <div class="text-3xl font-bold text-primary mb-1">8 Cities</div>
          <div class="text-sm text-gray-600">Served along Gulf Blvd</div>
        </div>
        <div class="bg-white rounded-xl p-5 shadow-sm text-center">
          <div class="text-3xl font-bold text-primary mb-1">Year-Round</div>
          <div class="text-sm text-gray-600">Lawn maintenance</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Salt & Sandy Soil Environmental Section -->
  <section class="max-w-5xl mx-auto px-4 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
      <div>
        <h2 class="text-3xl font-bold text-primary mb-4">Salt Spray and Sandy Soil Challenge Gulf Blvd Landscapes</h2>
        <p class="text-gray-700 leading-relaxed mb-4">
          Most landscapers from inland Florida plant species that fail within a season on the Gulf Blvd
          corridor. Salt spray causes osmotic stress that looks like drought damage — brown tips, wilting,
          leaf drop — even in well-watered plants. Sandy barrier island soil drains so fast that irrigation
          timing and species selection are critical.
        </p>
        <p class="text-gray-700 leading-relaxed mb-4">
          We design exclusively with salt-tolerant tropical species proven to thrive in beachfront conditions:
          <strong>Bougainvillea, Ixora, Plumbago, Sago Palm, Croton,</strong> and <strong>Bird of Paradise.</strong>
          Every design accounts for your HOA guidelines, Pinellas County's invasive plant restrictions,
          and SWFWMD irrigation rules.
        </p>
        <a href="/services/landscape-design" class="text-cta font-semibold hover:underline">
          See our tropical design services →
        </a>
      </div>
      <div class="space-y-4">
        <div class="flex items-start gap-4 bg-gray-50 rounded-xl p-4">
          <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 2c0 0-4 5-4 10a4 4 0 008 0C16 7 12 2 12 2z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 12v10"/></svg>
          </div>
          <div>
            <h3 class="font-bold text-primary mb-1">Salt-Tolerant Plant Selection</h3>
            <p class="text-gray-600 text-sm">We specify species by salt spray intensity zone — Gulf-front, canal-front, or street-facing — so your plants actually survive.</p>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-gray-50 rounded-xl p-4">
          <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
          </div>
          <div>
            <h3 class="font-bold text-primary mb-1">SWFWMD-Compliant Irrigation</h3>
            <p class="text-gray-600 text-sm">All irrigation systems include rain sensors (required by Pinellas County) and are scheduled to the SWFWMD odd/even watering calendar.</p>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-gray-50 rounded-xl p-4">
          <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
          </div>
          <div>
            <h3 class="font-bold text-primary mb-1">HOA Approval Support</h3>
            <p class="text-gray-600 text-sm">We provide written plant lists and design specs in the format most HOA boards require for approval — reducing delays on your project.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="bg-gray-50 py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-primary text-center mb-10">Why Gulf Blvd Homeowners Choose Us</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="flex justify-center mb-4">
            <div class="w-14 h-14 bg-primary/10 rounded-full flex items-center justify-center">
              <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
          </div>
          <h3 class="font-bold text-primary text-lg mb-2">We Answer the Phone</h3>
          <p class="text-gray-600 text-sm">No voicemail maze, no unanswered texts. A real person picks up and gets you scheduled — especially after storms when you need fast service.</p>
        </div>
        <div class="text-center">
          <div class="flex justify-center mb-4">
            <div class="w-14 h-14 bg-primary/10 rounded-full flex items-center justify-center">
              <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
            </div>
          </div>
          <h3 class="font-bold text-primary text-lg mb-2">FL-Specific Expertise</h3>
          <p class="text-gray-600 text-sm">We know St. Augustine grass, SWFWMD restrictions, Pinellas County fertilizer blackout periods, and which tropical species actually survive salt spray on the Gulf.</p>
        </div>
        <div class="text-center">
          <div class="flex justify-center mb-4">
            <div class="w-14 h-14 bg-primary/10 rounded-full flex items-center justify-center">
              <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
              </svg>
            </div>
          </div>
          <h3 class="font-bold text-primary text-lg mb-2">Free Written Estimates</h3>
          <p class="text-gray-600 text-sm">No verbal quotes that change on arrival. We provide written estimates before any work begins, including a full plant list and scope for design projects.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <h2 class="text-3xl font-bold text-primary text-center mb-4">What Gulf Blvd Homeowners Say</h2>
    <p class="text-gray-600 text-center mb-10">Real customers, real results.</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm flex flex-col gap-4">
          <div class="flex gap-1">
            {Array.from({ length: 5 }).map(() => (
              <svg class="w-4 h-4 fill-yellow-400" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <p class="text-gray-700 text-sm leading-relaxed flex-1">"{t.quote}"</p>
          <div>
            <p class="font-semibold text-primary text-sm">{t.name}</p>
            <p class="text-gray-500 text-xs">{t.location}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Service Areas -->
  <section class="bg-gray-50 py-16 px-4">
    <div class="max-w-6xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-primary mb-4">Serving All of Gulf Boulevard</h2>
      <p class="text-gray-600 max-w-3xl mx-auto mb-10">
        We cover the full stretch of Gulf Blvd — from Indian Rocks Beach in the north to St. Pete Beach
        in the south. If you're on or near the Gulf in Pinellas County, we serve you.
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {SITE_CONFIG.locations.map((loc) => (
          <a
            href={loc.href}
            class="bg-white border border-gray-200 rounded-xl px-4 py-4 text-sm font-semibold text-primary hover:border-accent hover:text-accent transition-all shadow-sm"
          >
            {loc.city}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-4xl mx-auto px-4 py-16">
    <h2 class="text-3xl font-bold text-primary text-center mb-10">Frequently Asked Questions</h2>
    <div class="space-y-4">
      {[
        {
          q: "How much does lawn care cost on Gulf Blvd, FL?",
          a: "Lawn care on Gulf Blvd typically ranges from $40 to $150 per visit depending on lot size, grass type, and services included. Most residential properties fall in the $60–$100 range per visit. We provide free estimates before any work begins."
        },
        {
          q: "What type of grass is best for Gulf Blvd properties?",
          a: "St. Augustine grass is the right choice for almost every property on the corridor — it tolerates salt air, moderate shade, and Florida's subtropical humidity far better than Bermuda or Zoysia. Mow at 3.5–4 inches and never scalp it."
        },
        {
          q: "Do you handle landscaping for HOA condo complexes?",
          a: "Yes. We work with HOA boards and property management companies throughout the corridor. We provide plant lists and written specs in the format most associations require, and offer multi-unit maintenance contracts."
        },
        {
          q: "How do I prepare my Gulf Blvd landscape for hurricane season?",
          a: "Book in April or May — at least 6 weeks before June 1st. We trim palms (dead fronds only), cut back ornamentals, secure loose mulch, and remove anything that could become a wind hazard."
        },
        {
          q: "What plants survive salt spray on beachfront properties?",
          a: "The most reliably salt-tolerant species for Gulf Blvd are Bougainvillea, Ixora, Plumbago, Lantana, Sago Palm, and Croton. For ground covers: Asiatic jasmine, perennial peanut, and Beach Sunflower all handle salt spray well."
        },
        {
          q: "What is SWFWMD and how does it affect my lawn watering?",
