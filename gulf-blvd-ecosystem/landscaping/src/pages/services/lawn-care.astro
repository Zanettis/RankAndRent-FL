---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'LawnCareService',
  name: 'Lawn Care & Grass Cutting — Gulf Blvd, FL',
  description: 'Weekly and bi-weekly mowing for St. Augustine, Zoysia, and Bahia grass. Edging, blowing, and year-round lawn maintenance for Gulf Blvd coastal properties.',
  provider: { '@type': 'LocalBusiness', name: SITE_CONFIG.name, url: SITE_CONFIG.domain, telephone: SITE_CONFIG.phone },
  areaServed: SITE_CONFIG.locations.map(l => ({ '@type': 'City', name: l.city })),
  offers: { '@type': 'Offer', priceSpecification: { '@type': 'PriceSpecification', minPrice: '40', maxPrice: '150', priceCurrency: 'USD' } },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${SITE_CONFIG.domain}/services/` },
    { '@type': 'ListItem', position: 3, name: 'Lawn Care', item: `${SITE_CONFIG.domain}/services/lawn-care/` },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'How often should St. Augustine grass be mowed on Gulf Blvd?', acceptedAnswer: { '@type': 'Answer', text: 'During the growing season (spring through early fall), St. Augustine grass typically needs mowing every 7–10 days. In winter it slows down but does not go fully dormant in Gulf Coast FL — plan for every 14 days year-round. Never cut more than one-third of the blade height in a single mowing.' } },
    { '@type': 'Question', name: 'What height should St. Augustine grass be cut to?', acceptedAnswer: { '@type': 'Answer', text: 'St. Augustine grass should be maintained at 3.5 to 4 inches. Cutting below 3 inches scalps the lawn, exposes the soil, stresses the grass, and creates conditions for fungal disease during Florida\'s rainy season. Higher mowing height also improves drought tolerance and reduces weed pressure.' } },
    { '@type': 'Question', name: 'When is Pinellas County\'s fertilizer blackout period?', acceptedAnswer: { '@type': 'Answer', text: 'Pinellas County\'s fertilizer ordinance prohibits applying nitrogen or phosphorus fertilizer from June 1st through September 30th. This is the rainy season blackout — fertilizer applied during this period washes into waterways during summer storms. We schedule fertilizer applications in early spring (March–May) and fall (October–November) to stay compliant.' } },
    { '@type': 'Question', name: 'How much does lawn care cost on Gulf Blvd, FL?', acceptedAnswer: { '@type': 'Answer', text: 'Lawn care on Gulf Blvd typically ranges from $40 to $150 per visit depending on lot size, grass type, and services included. Most residential properties on the corridor fall in the $60–$100 range per visit. Monthly maintenance contracts are available at a discounted per-visit rate. We provide free estimates.' } },
  ],
};
---

<BaseLayout
  title="Lawn Care Gulf Blvd FL | St. Augustine Grass Mowing & Maintenance"
  description="Weekly and bi-weekly lawn mowing for St. Augustine grass along Gulf Boulevard, FL. Edging, blowing, year-round maintenance. Pinellas County fertilizer blackout compliant. Free estimates."
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Hero
    headline="Lawn Care on Gulf Blvd, FL — St. Augustine Specialists"
    subheadline="Year-round mowing, edging, and lawn maintenance for Gulf Blvd properties. We know St. Augustine grass — proper mowing height, fertilizer timing, and coastal soil conditions."
    ctaText="Get a Free Estimate"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <a href="/services" class="hover:text-primary">Services</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">Lawn Care</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>St. Augustine Grass Is the Standard on Gulf Blvd</h2>
      <p>
        St. Augustine grass (<em>Stenotaphrum secundatum</em>) dominates Gulf Blvd for good reason.
        It tolerates salt air, moderate shade, and the subtropical humidity of Gulf Coast Florida
        far better than Bermuda or Zoysia. It spreads by stolons — thick above-ground runners —
        and recovers quickly from damage when maintained correctly.
      </p>
      <p>
        The key word is <em>correctly</em>. St. Augustine is unforgiving of scalping. Cut it below
        3 inches and you expose the crown, stress the root system, and create conditions for
        fungal diseases like gray leaf spot and brown patch during Florida's rainy season. We maintain
        every lawn at 3.5–4 inches, with sharp blades changed regularly to prevent tearing.
      </p>

      <h2>Year-Round Lawn Care Schedule</h2>
      <p>
        Unlike northern states, Gulf Coast Florida has no winter dormancy. St. Augustine slows
        in December and January but never stops growing entirely. Our lawn care schedule adjusts
        by season:
      </p>
      <ul>
        <li><strong>Spring (March–May):</strong> Every 7–10 days. Heavy growth period. Pre-season fertilizer application (before the June 1st blackout).</li>
        <li><strong>Summer (June–September):</strong> Every 7–10 days. Fastest growth. No nitrogen or phosphorus fertilizer per Pinellas County ordinance.</li>
        <li><strong>Fall (October–November):</strong> Every 10–14 days. Slowing growth. Fall fertilizer window — potassium application helps root development before winter.</li>
        <li><strong>Winter (December–February):</strong> Every 14 days. Minimal growth. Inspection focus on chinch bug and fungal disease signs.</li>
      </ul>

      <h2>Pinellas County Fertilizer Blackout Period</h2>
      <p>
        Pinellas County's fertilizer ordinance prohibits applying nitrogen or phosphorus from
        June 1st through September 30th. Fertilizer applied during summer storms washes directly
        into Tampa Bay and the Gulf — the ordinance exists to protect water quality. Violations
        carry fines. We schedule every fertilizer application to stay within the compliant windows.
      </p>

      <h2>Lawn Care Pricing on Gulf Blvd</h2>
      <p>
        Lawn care pricing ranges from $40 to $150 per visit depending on lot size, services included,
        and frequency. Most residential properties on the Gulf Blvd corridor fall in the $60–$100
        per-visit range. Monthly maintenance contracts include mowing, edging, blowing, and
        seasonal service reminders at a discounted per-visit rate.
      </p>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-6">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {[
          { q: 'How often should St. Augustine grass be mowed on Gulf Blvd?', a: 'Every 7–10 days in the growing season (spring through early fall). In winter, every 14 days. Never cut more than one-third of the blade height in a single mowing.' },
          { q: 'What height should St. Augustine grass be cut to?', a: 'St. Augustine should be maintained at 3.5 to 4 inches. Cutting below 3 inches scalps the lawn, stresses the grass, and creates conditions for fungal disease in Florida\'s rainy season.' },
          { q: 'When is Pinellas County\'s fertilizer blackout?', a: 'June 1st through September 30th. No nitrogen or phosphorus fertilizer during this period — county ordinance. We schedule spring and fall applications to stay compliant.' },
          { q: 'How much does lawn care cost on Gulf Blvd, FL?', a: '$40 to $150 per visit depending on lot size and services. Most residential properties fall in the $60–$100 range. Monthly contracts are available at a discounted rate.' },
        ].map(({ q, a }) => (
          <details class="border border-gray-200 rounded-xl overflow-hidden group">
            <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold text-primary hover:bg-gray-50 list-none">
              {q}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">{a}</div>
          </details>
        ))}
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-6">Other Services We Offer</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {SITE_CONFIG.services.filter(s => s.href !== '/services/lawn-care').slice(0, 3).map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading="Get Your Free Lawn Care Estimate" />
    </div>
  </div>
</BaseLayout>
