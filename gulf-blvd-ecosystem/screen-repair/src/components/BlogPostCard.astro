---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
}

const { title, description, pubDate, slug } = Astro.props;
const formattedDate = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' }).format(pubDate);
---

<article class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow group">
  <div class="p-6">
    <time class="text-xs text-gray-500 font-medium uppercase tracking-wide" datetime={pubDate.toISOString()}>
      {formattedDate}
    </time>
    <h2 class="text-lg font-bold text-primary mt-2 mb-3 group-hover:text-accent transition-colors leading-snug">
      <a href={`/blog/${slug}`}>{title}</a>
    </h2>
    <p class="text-gray-600 text-sm leading-relaxed mb-4">{description}</p>
    <a
      href={`/blog/${slug}`}
      class="text-cta font-semibold text-sm hover:underline flex items-center gap-1"
    >
      Read Article <span aria-hidden="true">→</span>
    </a>
  </div>
</article>
