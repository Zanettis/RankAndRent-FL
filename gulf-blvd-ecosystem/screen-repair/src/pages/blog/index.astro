---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Screen Repair Blog | Tips for Gulf Blvd Homeowners"
  description="Expert pool cage and screen repair advice for Gulf Blvd homeowners — Indian Rocks Beach to St. Pete Beach. Learn about coastal mesh selection, storm prep, and more."
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <div class="mb-10">
      <h1 class="text-4xl font-bold text-primary mb-4">Screen Repair Blog</h1>
      <p class="text-gray-600 text-lg">
        Expert advice from our Gulf Blvd screen repair crew — covering everything from choosing
        the right mesh for coastal environments to protecting your pool cage before storm season.
      </p>
    </div>

    {posts.length === 0 ? (
      <p class="text-gray-500">No posts yet. Check back soon!</p>
    ) : (
      <div class="grid gap-6">
        {posts.map((post) => (
          <BlogPostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.slug}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
