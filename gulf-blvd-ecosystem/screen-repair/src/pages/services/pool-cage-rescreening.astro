---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Pool Cage Rescreening',
  name: 'Full Pool Cage Rescreening — Gulf Blvd, FL',
  description: 'Complete pool enclosure rescreening along Gulf Boulevard, FL. Coastal-grade 18×14 and 20×20 mesh. Licensed and insured. Free estimates.',
  provider: { '@type': 'LocalBusiness', name: SITE_CONFIG.name, url: SITE_CONFIG.domain, telephone: SITE_CONFIG.phone },
  areaServed: SITE_CONFIG.locations.map(l => ({ '@type': 'City', name: l.city })),
  offers: { '@type': 'Offer', priceSpecification: { '@type': 'PriceSpecification', minPrice: '1200', maxPrice: '3500', priceCurrency: 'USD' } },
  speakable: { '@type': 'SpeakableSpecification', cssSelector: ['h1', '.service-description'] },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${SITE_CONFIG.domain}/services/` },
    { '@type': 'ListItem', position: 3, name: 'Pool Cage Rescreening', item: `${SITE_CONFIG.domain}/services/pool-cage-rescreening/` },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'How much does full pool cage rescreening cost along Gulf Blvd?', acceptedAnswer: { '@type': 'Answer', text: 'Full pool cage rescreening typically costs $1,200–$3,500 along Gulf Boulevard, depending on cage size, mesh type selected, and frame condition. We provide free on-site estimates so you know the exact price before any commitment.' } },
    { '@type': 'Question', name: 'What mesh type is best for a Gulf Coast pool cage?', acceptedAnswer: { '@type': 'Answer', text: 'For Gulf Coast environments, we recommend 20×20 no-see-um mesh for maximum insect protection, or 18×14 standard mesh for better airflow. Both are treated for UV resistance. We also offer pet screen (7× stronger) for households with dogs or cats.' } },
    { '@type': 'Question', name: 'How long does pool cage rescreening take?', acceptedAnswer: { '@type': 'Answer', text: "Most standard pool cage rescreening jobs take 1–2 days. Larger cages or those requiring frame repairs may take an additional day. We'll give you an accurate timeline when we assess your cage during the free estimate." } },
  ],
};
---

<BaseLayout
  title="Pool Cage Rescreening Gulf Blvd FL | Full Enclosure Replacement"
  description="Full pool cage rescreening along Gulf Boulevard, FL — Indian Rocks Beach to St. Pete Beach. Coastal-grade mesh, licensed & insured, free estimates."
  aggregateRating={{ ratingValue: '4.9', reviewCount: '94' }}
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Hero
    headline="Full Pool Cage Rescreening on Gulf Blvd, FL"
    subheadline="Complete pool enclosure rescreening using coastal-grade mesh rated for salt air, UV, and Florida humidity. Serving Indian Rocks Beach to St. Pete Beach."
    ctaText="Get a Free Estimate"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <a href="/services" class="hover:text-primary">Services</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">Pool Cage Rescreening</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>When Is Full Pool Cage Rescreening the Right Choice?</h2>
      <p>
        Individual panel repair is the right call when damage is isolated. But when 30% or more
        of your panels are torn, sagging, or pulling away from the spline — or when your existing
        mesh is yellowed and brittle from UV degradation — a full rescreen is the more cost-effective
        solution. It also gives you a uniform appearance and consistent mesh tension across the
        entire enclosure.
      </p>

      <h2>Our Rescreening Process</h2>
      <p>
        We start by removing all existing screen panels and inspecting the aluminum frame for
        corrosion, bent sections, and fastener condition. We identify and replace any rusted
        steel screws with Nylo-Tec or stainless fasteners before installing new mesh.
        New screen is pulled tight and splined into each channel by hand — no shortcuts, no
        loose mesh that will sag or rattle in the first Gulf breeze.
      </p>

      <h2>Mesh Options We Offer</h2>
      <ul>
        <li><strong>18×14 Standard Fiberglass Mesh</strong> — Good airflow, adequate insect barrier for most species. Most common choice for pool cages.</li>
        <li><strong>20×20 No-See-Um Mesh</strong> — Finer weave that blocks tiny biting midges (no-see-ums) common in coastal FL. Slightly reduced airflow.</li>
        <li><strong>Pet Screen</strong> — Heavy-duty vinyl-coated polyester, 7× stronger than standard. Ideal for households with dogs or cats.</li>
        <li><strong>Solar Screen</strong> — Reduces sun glare and heat load in the pool area while maintaining insect protection.</li>
      </ul>

      <h2>Pool Cage Rescreening Cost on Gulf Blvd</h2>
      <p>
        Full pool cage rescreening along Gulf Boulevard typically runs $1,200–$3,500 depending
        on cage size (square footage of screen area), mesh type selected, and whether frame
        repairs or fastener replacement are needed. We always provide a written, itemized estimate
        before starting any work.
      </p>

      <h2>Serving All of Gulf Blvd</h2>
      <p>
        We rescreen pool cages throughout Indian Rocks Beach, Indian Shores, Redington Shores,
        Redington Beach, Madeira Beach, Treasure Island, St. Pete Beach, and Clearwater Beach.
        If you're on or near Gulf Boulevard in Pinellas County, we serve you.
      </p>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-6">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {[
          { q: 'How much does full pool cage rescreening cost along Gulf Blvd?', a: 'Full pool cage rescreening typically costs $1,200–$3,500 along Gulf Boulevard, depending on cage size, mesh type selected, and frame condition. We provide free on-site estimates so you know the exact price before any commitment.' },
          { q: 'What mesh type is best for a Gulf Coast pool cage?', a: 'For Gulf Coast environments, we recommend 20×20 no-see-um mesh for maximum insect protection, or 18×14 standard mesh for better airflow. Both are treated for UV resistance. We also offer pet screen (7× stronger) for households with dogs or cats.' },
          { q: 'How long does pool cage rescreening take?', a: "Most standard pool cage rescreening jobs take 1–2 days. Larger cages or those requiring frame repairs may take an additional day. We'll give you an accurate timeline when we assess your cage during the free estimate." },
        ].map(({ q, a }) => (
          <details class="border border-gray-200 rounded-xl overflow-hidden group">
            <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold text-primary hover:bg-gray-50 list-none">
              {q}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">{a}</div>
          </details>
        ))}
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-6">Other Services We Offer</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {SITE_CONFIG.services.filter(s => s.href !== '/services/pool-cage-rescreening').slice(0, 3).map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading="Get Your Free Pool Cage Rescreening Estimate" />
    </div>
  </div>
</BaseLayout>
