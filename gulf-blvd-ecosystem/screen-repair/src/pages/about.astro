---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadForm from '../components/LeadForm.astro';
import { SITE_CONFIG } from '../config';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE_CONFIG.name,
  url: SITE_CONFIG.domain,
  logo: `${SITE_CONFIG.domain}/favicon.svg`,
  foundingDate: '2018',
  telephone: SITE_CONFIG.phone,
  email: SITE_CONFIG.email,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Indian Rocks Beach',
    addressRegion: 'FL',
    postalCode: '33785',
    addressCountry: 'US',
  },
  description: 'Locally owned screen repair company serving Gulf Boulevard from Indian Rocks Beach to St. Pete Beach since 2018. Licensed, insured, and trusted by homeowners and vacation rental managers.',
};
---

<BaseLayout
  title="About Gulf Blvd Screen Repair | Local Screen Experts Since 2018"
  description="Locally owned pool cage and screen repair company serving Gulf Boulevard, FL since 2018. Licensed, insured, and trusted by homeowners and Airbnb property managers across the Gulf Beaches."
>
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

  <!-- Hero -->
  <section class="bg-primary text-white py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">About Gulf Blvd Screen Repair</h1>
      <p class="text-xl text-white/85 max-w-2xl mx-auto">Your Local Screen Repair Specialists — Serving Gulf Boulevard Since 2018</p>
    </div>
  </section>

  <!-- Our Story -->
  <section class="max-w-4xl mx-auto px-4 py-16">
    <h2 class="text-3xl font-bold text-primary mb-8">Our Story</h2>
    <div class="prose prose-lg max-w-none prose-headings:text-primary text-gray-700 space-y-5">
      <p>
        Gulf Blvd Screen Repair was founded in 2018 by a team of Gulf Beaches locals who grew
        tired of watching neighbors struggle to get reliable screen repair done. The pattern was
        always the same — call three contractors, get one callback, schedule a job, wait at home
        all day for someone who never showed. For a service that's essential in coastal Florida,
        the level of professionalism was unacceptably low.
      </p>
      <p>
        We set out to fix that. From day one, our commitment has been simple: answer the phone,
        show up when we say we will, and do the work right using materials actually rated for
        our Gulf Coast environment. Not generic hardware store mesh that fades and tears
        in eighteen months. Not steel screws that rust out in the salt air and compromise your
        entire frame. Real coastal-grade materials, installed correctly, with a crew that takes
        pride in the work.
      </p>
      <p>
        Today we serve homeowners, condo associations, and vacation rental property managers
        throughout Indian Rocks Beach, Indian Shores, Redington Shores, Redington Beach,
        Madeira Beach, Treasure Island, St. Pete Beach, and Clearwater Beach. We've built
        our reputation one repair at a time — and that reputation depends entirely on doing
        the job right and treating every customer the way we'd want to be treated ourselves.
      </p>
    </div>
  </section>

  <!-- Why We're Different -->
  <section class="bg-gray-50 py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-primary text-center mb-10">Why We're Different</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white rounded-xl p-6 shadow-sm text-center">
          <div class="flex justify-center mb-4">
            <div class="w-14 h-14 bg-primary/10 rounded-full flex items-center justify-center">
              <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
          </div>
          <h3 class="font-bold text-primary text-lg mb-3">We Actually Pick Up</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            The #1 complaint about screen repair contractors is that they don't answer or return calls.
            We pick up. If we miss you, we call back within the hour — not in three days.
          </p>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm text-center">
          <div class="flex justify-center mb-4">
            <div class="w-14 h-14 bg-primary/10 rounded-full flex items-center justify-center">
              <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
            </div>
          </div>
          <h3 class="font-bold text-primary text-lg mb-3">Coastal Material Expertise</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            We know the difference between mesh that lasts 18 months and mesh that lasts 10 years
            on the Gulf Coast. Every material we install is chosen specifically for salt air, UV,
            and humidity exposure.
          </p>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm text-center">
          <div class="flex justify-center mb-4">
            <div class="w-14 h-14 bg-primary/10 rounded-full flex items-center justify-center">
              <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
              </svg>
            </div>
          </div>
          <h3 class="font-bold text-primary text-lg mb-3">Honest, Written Estimates</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            We provide written estimates before any work begins. What we quote is what you pay —
            no verbal ballparks that turn into surprise invoices, no pressure upsells.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Credentials -->
  <section class="max-w-4xl mx-auto px-4 py-16">
    <h2 class="text-3xl font-bold text-primary text-center mb-10">Credentials & Insurance</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">
      <div class="flex flex-col items-center gap-3">
        <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center">
          <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
          </svg>
        </div>
        <h3 class="font-bold text-primary">FL Licensed Contractor</h3>
        <p class="text-gray-600 text-sm">Florida-licensed for screen enclosure work. Fully compliant with Pinellas County requirements.</p>
      </div>
      <div class="flex flex-col items-center gap-3">
        <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center">
          <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
        </div>
        <h3 class="font-bold text-primary">Fully Insured</h3>
        <p class="text-gray-600 text-sm">Full general liability and workers' compensation coverage on every job. You are protected.</p>
      </div>
      <div class="flex flex-col items-center gap-3">
        <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center">
          <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
        </div>
        <h3 class="font-bold text-primary">Free Written Estimates</h3>
        <p class="text-gray-600 text-sm">No obligation. No verbal quotes that change on arrival. Written estimates, always.</p>
      </div>
    </div>
  </section>

  <!-- Service Area -->
  <section class="max-w-4xl mx-auto px-4 py-16 text-center">
    <h2 class="text-3xl font-bold text-primary mb-4">Our Service Area</h2>
    <p class="text-gray-600 max-w-2xl mx-auto mb-8">
      We serve the full Gulf Boulevard corridor and surrounding beach communities in Pinellas County.
    </p>
    <div class="flex flex-wrap justify-center gap-3">
      {SITE_CONFIG.locations.map((loc) => (
        <a href={loc.href} class="bg-primary/10 text-primary font-semibold px-4 py-2 rounded-full text-sm hover:bg-primary/20 transition-colors">
          {loc.city}
        </a>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-primary py-16 px-4 text-center text-white">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl font-bold mb-4">Ready to Get Started?</h2>
      <p class="text-white/85 text-lg mb-8">
        Contact us today for a free, no-obligation written estimate. We'll come to your property,
        assess your screens, and give you a clear price — no pressure, no surprises.
      </p>
      <a
        href="/contact"
        class="inline-block bg-white text-primary font-bold text-lg px-8 py-4 rounded-xl hover:bg-gray-100 transition-colors"
      >
        Get Your Free Estimate
      </a>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-16">
    <LeadForm heading="Or Send Us a Message" />
  </section>
</BaseLayout>
