---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import LeadForm from '../components/LeadForm.astro';
import { SITE_CONFIG } from '../config';

const serviceIcons = [
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8"><rect x="3" y="3" width="18" height="18" rx="2"/><path stroke-linecap="round" stroke-linejoin="round" d="M3 9h18M9 21V9"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v10a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1V10"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8"><circle cx="12" cy="8" r="4"/><path stroke-linecap="round" stroke-linejoin="round" d="M6 20v-2a6 6 0 0112 0v2"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2z"/><path stroke-linecap="round" stroke-linejoin="round" d="M9 3v18M15 3v18"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8"><circle cx="12" cy="12" r="3"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>`,
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How much does pool cage rescreening cost in St. Pete Beach?',
      acceptedAnswer: { '@type': 'Answer', text: 'Pool cage rescreening along Gulf Blvd typically costs $1,200–$3,500 for a standard cage, depending on size, mesh type, and condition of the frame. Individual panel repairs run $75–$200 per panel. We provide free on-site estimates so you know the exact price before any work begins.' },
    },
    {
      '@type': 'Question',
      name: 'How long does pool cage rescreening take?',
      acceptedAnswer: { '@type': 'Answer', text: 'A full pool cage rescreening typically takes 1–2 days depending on cage size. Individual panel repairs can often be completed the same day. We schedule around your needs and work efficiently to minimize disruption to your pool use.' },
    },
    {
      '@type': 'Question',
      name: 'Why do pool cage screens fail faster near the Gulf?',
      acceptedAnswer: { '@type': 'Answer', text: 'Salt air from the Gulf of Mexico accelerates corrosion of both the screen mesh and the steel fasteners holding the frame together. UV exposure from Florida\'s intense sun degrades standard fiberglass mesh in 5–8 years. We use coastal-grade materials and Nylo-Tec or stainless fasteners to extend the life of your repair.' },
    },
    {
      '@type': 'Question',
      name: 'Can you do screen repair after a tropical storm or hurricane?',
      acceptedAnswer: { '@type': 'Answer', text: 'Yes — storm damage screen repair is one of our most common emergency services. After a storm hits along Gulf Blvd, we prioritize calls from Indian Rocks Beach, Madeira Beach, Treasure Island, and St. Pete Beach. The sooner you call, the faster we can get your pool cage secured and mosquito-free again.' },
    },
    {
      '@type': 'Question',
      name: 'Do I need to rescreen the whole cage if only a few panels are damaged?',
      acceptedAnswer: { '@type': 'Answer', text: 'Not necessarily. If the frame is in good condition and the damage is limited to a few panels, individual panel repair is a cost-effective option. We\'ll assess the condition of all panels and the frame during your free estimate and give you an honest recommendation — repair vs. full rescreen.' },
    },
    {
      '@type': 'Question',
      name: 'Do you serve Airbnb and vacation rental properties on Gulf Blvd?',
      acceptedAnswer: { '@type': 'Answer', text: 'Absolutely. We work with property managers and Airbnb hosts throughout Indian Rocks Beach, Treasure Island, Madeira Beach, and St. Pete Beach. We understand that fast turnaround is critical for rental properties — a torn screen means bad reviews and lost bookings. We offer priority scheduling for rental properties.' },
    },
    {
      '@type': 'Question',
      name: 'What is pet screen and is it worth the extra cost?',
      acceptedAnswer: { '@type': 'Answer', text: 'Pet screen is a heavy-duty vinyl-coated polyester mesh that is 7× stronger than standard fiberglass mesh. It\'s designed to resist punctures and tearing from dog and cat claws. If you have pets, it\'s almost always worth the extra $1–2 per square foot — it will outlast standard screen by years in a home with animals.' },
    },
    {
      '@type': 'Question',
      name: 'What areas along Gulf Blvd do you serve?',
      acceptedAnswer: { '@type': 'Answer', text: 'We serve all communities along Gulf Boulevard from Indian Rocks Beach and Indian Shores through Redington Shores, Redington Beach, Madeira Beach, Treasure Island, and St. Pete Beach, as well as Clearwater Beach to the north.' },
    },
  ],
};

const testimonials = [
  {
    quote: "Called on a Monday after the storm and they were at my house by Wednesday. Rescreened the entire cage in one day. These guys are the real deal.",
    name: "Mike T.",
    location: "St. Pete Beach, FL",
  },
  {
    quote: "I manage three Airbnbs on Gulf Blvd. Having a reliable screen repair company that actually shows up on time is worth its weight in gold. Highly recommend.",
    name: "Sarah K.",
    location: "Madeira Beach, FL",
  },
  {
    quote: "They replaced all the rusted screws on my cage and patched three panels for a fair price. Couldn't believe how fast they finished. Great work.",
    name: "Robert & Linda M.",
    location: "Indian Rocks Beach, FL",
  },
];
---

<BaseLayout
  title="Pool Cage & Screen Repair Gulf Blvd FL | Indian Rocks Beach to St. Pete Beach"
  description="Pool cage rescreening, lanai screen repair, and panel replacement along Gulf Boulevard — Indian Rocks Beach to St. Pete Beach. Licensed & insured. Free estimates."
  aggregateRating={{ ratingValue: "4.9", reviewCount: "94" }}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Hero
    headline="Gulf Blvd's Most Trusted Pool Cage & Screen Repair"
    subheadline="Pool cage rescreening, lanai screen repair, and panel replacement from Indian Rocks Beach to St. Pete Beach. We answer the phone. We show up on time. We fix it right."
    ctaText="Get a Free Quote"
    secondaryCtaText={`Call ${SITE_CONFIG.phone}`}
    secondaryCtaHref={`tel:${SITE_CONFIG.phone}`}
    badges={["Licensed & Insured", "Free Estimates", "Storm Damage Experts", "Airbnb-Ready Turnaround"]}
  />

  <!-- Trust Bar -->
  <div class="bg-white border-b border-gray-100 shadow-sm">
    <div class="max-w-6xl mx-auto px-4 py-4 flex flex-wrap justify-center gap-x-8 gap-y-2 text-sm text-gray-600">
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        We Pick Up The Phone
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        We Show Up On Time
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        FL Licensed & Insured
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        Free Written Estimates
      </span>
    </div>
  </div>

  <!-- Services -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <h2 class="text-3xl font-bold text-primary text-center mb-4">Our Screen Repair Services</h2>
    <p class="text-gray-600 text-center max-w-2xl mx-auto mb-10">
      From full pool cage rescreening to storm damage emergency repairs — we cover every screen
      repair need along Gulf Boulevard, using materials rated for Florida's coastal salt-air environment.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {SITE_CONFIG.services.map((service, i) => (
        <ServiceCard
          title={service.title}
          description={service.description}
          href={service.href}
          icon={serviceIcons[i] ?? serviceIcons[0]}
        />
      ))}
    </div>
  </section>

  <!-- Airbnb / Vacation Rental Pitch -->
  <section class="bg-accent/10 border-y border-accent/20 py-16 px-4">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
      <div>
        <span class="inline-block bg-accent/20 text-primary font-semibold text-sm px-3 py-1 rounded-full mb-4">For Airbnb & Vacation Rental Owners</span>
        <h2 class="text-3xl font-bold text-primary mb-4">Don't Lose 5-Star Reviews Over a Torn Screen</h2>
        <p class="text-gray-700 leading-relaxed mb-4">
          A guest paying $400–$700 per night in St. Pete Beach or Treasure Island expects a
          mosquito-free pool area. One torn screen panel means bugs in the lanai, bad reviews,
          and lost future bookings — often hundreds of dollars in damage for a $100 repair.
        </p>
        <p class="text-gray-700 leading-relaxed mb-6">
          We work with property managers all along Gulf Blvd and offer priority scheduling between
          guest check-outs and check-ins. Fast, clean, reliable — we treat your rental property
          like our own.
        </p>
        <a href="/contact" class="inline-block bg-cta text-white font-bold px-6 py-3 rounded-lg hover:opacity-90 transition-opacity">
          Schedule Fast Turnaround Repair →
        </a>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div class="bg-white rounded-xl p-5 shadow-sm text-center">
          <div class="text-3xl font-bold text-primary mb-1">Same Day</div>
          <div class="text-sm text-gray-600">Panel repairs available</div>
        </div>
        <div class="bg-white rounded-xl p-5 shadow-sm text-center">
          <div class="text-3xl font-bold text-primary mb-1">1–2 Days</div>
          <div class="text-sm text-gray-600">Full cage rescreening</div>
        </div>
        <div class="bg-white rounded-xl p-5 shadow-sm text-center">
          <div class="text-3xl font-bold text-primary mb-1">8 Cities</div>
          <div class="text-sm text-gray-600">Served along Gulf Blvd</div>
        </div>
        <div class="bg-white rounded-xl p-5 shadow-sm text-center">
          <div class="text-3xl font-bold text-primary mb-1">24h</div>
          <div class="text-sm text-gray-600">Response guarantee</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Salt Air / Storm Damage Awareness -->
  <section class="max-w-5xl mx-auto px-4 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
      <div>
        <h2 class="text-3xl font-bold text-primary mb-4">Salt Air Destroys More Than Your Screens</h2>
        <p class="text-gray-700 leading-relaxed mb-4">
          The real danger for Gulf Blvd pool cages isn't the screen mesh — it's the fasteners.
          Standard steel screws corrode rapidly in our coastal salt air environment. Once they rust,
          the entire frame can become structurally compromised. In a tropical storm, that means
          your cage can become a projectile.
        </p>
        <p class="text-gray-700 leading-relaxed mb-4">
          During every screen repair job, we inspect your fasteners and can replace rusted steel
          screws with <strong>Nylo-Tec or stainless steel fasteners</strong> rated for coastal environments.
          This one upgrade can add years to the life of your cage.
        </p>
        <a href="/services/screw-fastener-replacement" class="text-cta font-semibold hover:underline">
          Learn about fastener replacement →
        </a>
      </div>
      <div class="space-y-4">
        <div class="flex items-start gap-4 bg-gray-50 rounded-xl p-4">
          <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          </div>
          <div>
            <h3 class="font-bold text-primary mb-1">Storm Damage Repair</h3>
            <p class="text-gray-600 text-sm">Tropical storms can blow out multiple panels at once. We offer emergency response after major weather events.</p>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-gray-50 rounded-xl p-4">
          <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <div>
            <h3 class="font-bold text-primary mb-1">Coastal-Grade Materials</h3>
            <p class="text-gray-600 text-sm">We stock 18×14 and 20×20 mesh plus pet screen, all rated for Gulf Coast UV and humidity.</p>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-gray-50 rounded-xl p-4">
          <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4"/></svg>
          </div>
          <div>
            <h3 class="font-bold text-primary mb-1">Rust-Proof Fasteners</h3>
            <p class="text-gray-600 text-sm">Nylo-Tec and stainless screws replace corroded steel fasteners before they compromise your frame.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="bg-gray-50 py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-primary text-center mb-10">Why Gulf Blvd Homeowners Choose Us</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="flex justify-center mb-4">
            <div class="w-14 h-14 bg-primary/10 rounded-full flex items-center justify-center">
              <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
          </div>
          <h3 class="font-bold text-primary text-lg mb-2">We Answer the Phone</h3>
          <p class="text-gray-600 text-sm">No voicemail maze, no unanswered texts. When you call us, a real person picks up and gets you scheduled.</p>
        </div>
        <div class="text-center">
          <div class="flex justify-center mb-4">
            <div class="w-14 h-14 bg-primary/10 rounded-full flex items-center justify-center">
              <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
            </div>
          </div>
          <h3 class="font-bold text-primary text-lg mb-2">Coastal Material Expertise</h3>
          <p class="text-gray-600 text-sm">We only use materials rated for Gulf Coast conditions — not generic hardware store mesh that fails in 18 months.</p>
        </div>
        <div class="text-center">
          <div class="flex justify-center mb-4">
            <div class="w-14 h-14 bg-primary/10 rounded-full flex items-center justify-center">
              <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
              </svg>
            </div>
          </div>
          <h3 class="font-bold text-primary text-lg mb-2">Free Written Estimates</h3>
          <p class="text-gray-600 text-sm">No verbal quotes that change on arrival. We provide written estimates before any work begins. No surprises.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <h2 class="text-3xl font-bold text-primary text-center mb-4">What Gulf Blvd Homeowners Say</h2>
    <p class="text-gray-600 text-center mb-10">Real customers, real results.</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm flex flex-col gap-4">
          <div class="flex gap-1">
            {Array.from({ length: 5 }).map(() => (
              <svg class="w-4 h-4 fill-yellow-400" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <p class="text-gray-700 text-sm leading-relaxed flex-1">"{t.quote}"</p>
          <div>
            <p class="font-semibold text-primary text-sm">{t.name}</p>
            <p class="text-gray-500 text-xs">{t.location}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Service Areas -->
  <section class="bg-gray-50 py-16 px-4">
    <div class="max-w-6xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-primary mb-4">Serving All of Gulf Boulevard</h2>
      <p class="text-gray-600 max-w-3xl mx-auto mb-10">
        We cover the full stretch of Gulf Blvd — from Indian Rocks Beach in the north to St. Pete Beach
        in the south, plus Clearwater Beach. If you're on or near the Gulf, we serve you.
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {SITE_CONFIG.locations.map((loc) => (
          <a
            href={loc.href}
            class="bg-white border border-gray-200 rounded-xl px-4 py-4 text-sm font-semibold text-primary hover:border-accent hover:text-accent transition-all shadow-sm"
          >
            {loc.city}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-4xl mx-auto px-4 py-16">
    <h2 class="text-3xl font-bold text-primary text-center mb-10">Frequently Asked Questions</h2>
    <div class="space-y-4">
      {[
        {
          q: "How much does pool cage rescreening cost in St. Pete Beach?",
          a: "Pool cage rescreening along Gulf Blvd typically costs $1,200–$3,500 for a standard cage, depending on size, mesh type, and condition of the frame. Individual panel repairs run $75–$200 per panel. We provide free on-site estimates so you know the exact price before any work begins."
        },
        {
          q: "How long does pool cage rescreening take?",
          a: "A full pool cage rescreening typically takes 1–2 days depending on cage size. Individual panel repairs can often be completed the same day. We schedule around your needs and work efficiently to minimize disruption to your pool use."
        },
        {
          q: "Why do pool cage screens fail faster near the Gulf?",
          a: "Salt air from the Gulf of Mexico accelerates corrosion of both the screen mesh and the steel fasteners holding the frame together. UV exposure from Florida's intense sun degrades standard fiberglass mesh in 5–8 years. We use coastal-grade materials and Nylo-Tec or stainless fasteners to extend the life of your repair."
        },
        {
          q: "Can you do screen repair after a tropical storm or hurricane?",
          a: "Yes — storm damage screen repair is one of our most common emergency services. After a storm hits along Gulf Blvd, we prioritize calls from Indian Rocks Beach, Madeira Beach, Treasure Island, and St. Pete Beach. The sooner you call, the faster we can get your pool cage secured and mosquito-free again."
        },
        {
          q: "Do I need to rescreen the whole cage if only a few panels are damaged?",
          a: "Not necessarily. If the frame is in good condition and the damage is limited to a few panels, individual panel repair is a cost-effective option. We'll assess the condition of all panels and the frame during your free estimate and give you an honest recommendation — repair vs. full rescreen."
        },
        {
          q: "Do you serve Airbnb and vacation rental properties on Gulf Blvd?",
          a: "Absolutely. We work with property managers and Airbnb hosts throughout Indian Rocks Beach, Treasure Island, Madeira Beach, and St. Pete Beach. We offer priority scheduling for rental properties with fast turnaround between guest check-outs and check-ins."
        },
      ].map(({ q, a }) => (
        <details class="border border-gray-200 rounded-xl overflow-hidden group">
          <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold text-primary hover:bg-gray-50 list-none">
            {q}
            <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
