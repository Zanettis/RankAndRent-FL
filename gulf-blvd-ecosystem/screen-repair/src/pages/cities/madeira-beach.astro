---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const city = 'Madeira Beach';
const citySlug = 'madeira-beach';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: `How much does pool cage rescreening cost in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Pool cage rescreening in ${city} typically costs $1,200–$3,500 depending on cage size, mesh type, and frame condition. Individual panel repairs run $75–$200 per panel. We provide free on-site estimates and only recommend what you actually need.` } },
    { '@type': 'Question', name: `Do you serve vacation rental properties in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Yes — ${city} has a high concentration of vacation rentals on and near Gulf Blvd. We offer priority scheduling for Airbnb hosts and property managers to turn around repairs between guest stays quickly.` } },
    { '@type': 'Question', name: `Can you repair screen damage from a tropical storm in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Yes. Storm damage screen repair is a major part of our work in ${city}. We prioritize Gulf Blvd properties after tropical events and can handle everything from a few blown panels to a full cage rescreen after severe storm damage.` } },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: `${SITE_CONFIG.domain}/cities/` },
    { '@type': 'ListItem', position: 3, name: city, item: `${SITE_CONFIG.domain}/cities/${citySlug}/` },
  ],
};
---

<BaseLayout
  title={`Screen Repair ${city} FL | Pool Cage & Lanai Rescreening`}
  description={`Pool cage rescreening and lanai screen repair in ${city}, FL. Storm damage repair, pet screen installation, and fastener replacement along Gulf Blvd. Free estimates.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Hero
    headline={`Pool Cage & Screen Repair in ${city}, FL`}
    subheadline={`Reliable screen repair for ${city} homeowners and vacation rental properties along Gulf Blvd. Pool cage rescreening, storm damage repair, and lanai screening — done right.`}
    ctaText="Get a Free Estimate"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">{city}</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>Screen Repair in {city}, FL</h2>
      <p>
        {city} is one of the most visited beach communities on the Gulf Blvd corridor,
        known for John's Pass Village and a dense mix of residential and vacation rental
        properties directly on the Gulf. Like all barrier island communities in Pinellas County,
        {city} properties face significant salt air exposure that accelerates screen and
        fastener degradation.
      </p>

      <h2>Services We Provide in {city}</h2>
      <ul>
        <li><a href="/services/pool-cage-rescreening">Full Pool Cage Rescreening</a> — Complete rescreen with coastal-grade 18×14 or 20×20 mesh</li>
        <li><a href="/services/screen-panel-repair">Individual Panel Repair</a> — Fix blown or torn panels without a full rescreen</li>
        <li><a href="/services/lanai-porch-screening">Lanai & Porch Screening</a> — Mosquito-free outdoor living for Gulf Blvd properties</li>
        <li><a href="/services/storm-damage-repair">Storm Damage Repair</a> — Emergency response after tropical storms and hurricanes</li>
        <li><a href="/services/pet-screen-installation">Pet Screen Installation</a> — 7× stronger than standard, ideal for dog households</li>
        <li><a href="/services/screw-fastener-replacement">Fastener Replacement</a> — Nylo-Tec and stainless screws to prevent structural corrosion</li>
      </ul>

      <h2>Best Pool Cage Rescreening in {city}</h2>
      <p>
        The best pool cage rescreening in {city} uses coastal-grade mesh and rust-resistant
        fasteners — not generic materials from a big-box store. We stock materials specifically
        rated for Gulf Coast UV and salt air exposure, and our crews are experienced with the
        aluminum frame systems common on {city} properties.
      </p>
    </div>

    <div class="mt-12">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {SITE_CONFIG.services.slice(0, 6).map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-8">Frequently Asked Questions — {city}</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((item) => (
          <details class="border border-gray-200 rounded-xl overflow-hidden group">
            <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold text-primary hover:bg-gray-50 list-none">
              {item.name}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">{item.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading={`Get a Free Estimate in ${city}`} />
    </div>
  </div>
</BaseLayout>
