---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const city = 'Indian Shores';
const citySlug = 'indian-shores';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: `Do you offer porch screening services in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Yes — porch and lanai screening is one of our core services in ${city}. We install and rescreen porch enclosures using coastal-grade 18×14 or 20×20 mesh that blocks both standard mosquitoes and the tiny no-see-ums common on Pinellas barrier islands. Free estimates available.` } },
    { '@type': 'Question', name: `How much does screen repair cost in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Individual panel repairs in ${city} typically run $75–$200 per panel. Full pool cage or porch rescreening costs $800–$3,500 depending on size. We provide written estimates before any work begins.` } },
    { '@type': 'Question', name: `Do you serve ${city} for storm damage repair?`, acceptedAnswer: { '@type': 'Answer', text: `Yes. ${city} is directly on the Gulf Blvd corridor and is one of the areas we serve after tropical storms and hurricanes. Call us immediately after a storm to get on our priority scheduling list.` } },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: `${SITE_CONFIG.domain}/cities/` },
    { '@type': 'ListItem', position: 3, name: city, item: `${SITE_CONFIG.domain}/cities/${citySlug}/` },
  ],
};
---

<BaseLayout
  title={`Screen Repair ${city} FL | Porch Screening & Pool Cage Repair`}
  description={`Porch screening, pool cage repair, and lanai rescreening in ${city}, FL. Gulf Blvd service area. Licensed & insured. Free estimates. Storm damage and pet screen available.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Hero
    headline={`Pool Cage & Screen Repair in ${city}, FL`}
    subheadline={`Trusted screen repair for ${city} homeowners. Porch screening, pool cage rescreening, and storm damage repair along Gulf Blvd — using materials rated for Pinellas County coastal conditions.`}
    ctaText="Get a Free Estimate"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">{city}</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>Screen Repair in {city}, FL</h2>
      <p>
        {city} is a small residential community on the Gulf Blvd barrier island between Indian Rocks
        Beach and Redington Shores. With direct Gulf of Mexico frontage, {city} homeowners deal with
        the same accelerated screen and fastener degradation common to all Gulf Beaches communities.
      </p>

      <h2>Services We Provide in {city}</h2>
      <ul>
        <li><a href="/services/lanai-porch-screening">Porch & Lanai Screening</a> — Keep no-see-ums and mosquitoes out of your outdoor living space</li>
        <li><a href="/services/pool-cage-rescreening">Full Pool Cage Rescreening</a> — Complete enclosure rescreen with coastal mesh</li>
        <li><a href="/services/screen-panel-repair">Individual Panel Repair</a> — Fast fixes for torn or damaged panels</li>
        <li><a href="/services/storm-damage-repair">Storm Damage Repair</a> — Emergency response after tropical weather</li>
        <li><a href="/services/pet-screen-installation">Pet Screen Installation</a> — 7× stronger mesh for dog and cat households</li>
        <li><a href="/services/screw-fastener-replacement">Fastener Replacement</a> — Nylo-Tec and stainless screws for structural longevity</li>
      </ul>
    </div>

    <div class="mt-12">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {SITE_CONFIG.services.slice(0, 6).map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-8">Frequently Asked Questions — {city}</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((item) => (
          <details class="border border-gray-200 rounded-xl overflow-hidden group">
            <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold text-primary hover:bg-gray-50 list-none">
              {item.name}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">{item.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading={`Get a Free Estimate in ${city}`} />
    </div>
  </div>
</BaseLayout>
