---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const city = 'Clearwater Beach';
const citySlug = 'clearwater-beach';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: `Do you offer pool cage rescreening in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Yes — we serve ${city} and the Clearwater Beach area for pool cage rescreening, lanai screen repair, panel replacement, and storm damage repair. Free estimates available.` } },
    { '@type': 'Question', name: `How much does pool cage repair cost in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Pool cage rescreening in ${city} typically costs $1,200–$3,500 for a full rescreen. Individual panel repairs run $75–$200 per panel. We provide free, written estimates before any work begins.` } },
    { '@type': 'Question', name: `What mesh do you recommend for ${city} pool cages?`, acceptedAnswer: { '@type': 'Answer', text: `For ${city}'s Gulf Coast environment, we recommend coastal-grade 18×14 or 20×20 no-see-um mesh. The 20×20 weave blocks the tiny biting midges common in Pinellas County beach communities while maintaining airflow.` } },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: `${SITE_CONFIG.domain}/cities/` },
    { '@type': 'ListItem', position: 3, name: city, item: `${SITE_CONFIG.domain}/cities/${citySlug}/` },
  ],
};
---

<BaseLayout
  title={`Screen Repair ${city} FL | Pool Cage & Lanai Rescreening`}
  description={`Pool cage rescreening and lanai screen repair in ${city}, FL. Licensed & insured. Storm damage repair, pet screen, and Nylo-Tec fastener replacement. Free estimates.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Hero
    headline={`Pool Cage & Screen Repair in ${city}, FL`}
    subheadline={`Reliable screen repair for ${city} homeowners. Pool cage rescreening, lanai screening, storm damage repair — using coastal-grade materials rated for Pinellas County's beach environment.`}
    ctaText="Get a Free Estimate"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">{city}</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>Screen Repair in {city}, FL</h2>
      <p>
        {city} is one of Florida's most visited beach destinations and home to a large permanent
        residential community with many waterfront properties featuring pool cages and screened lanais.
        Located north of the main Gulf Blvd corridor, {city} faces the same salt air challenges
        as the barrier island communities to the south.
      </p>

      <h2>Services Available in {city}</h2>
      <ul>
        <li><a href="/services/pool-cage-rescreening">Full Pool Cage Rescreening</a> — Complete rescreen with coastal-grade mesh</li>
        <li><a href="/services/screen-panel-repair">Individual Panel Repair</a> — Fast, affordable single-panel fixes</li>
        <li><a href="/services/lanai-porch-screening">Lanai & Porch Screening</a> — Keep mosquitoes and no-see-ums out</li>
        <li><a href="/services/storm-damage-repair">Storm Damage Repair</a> — Emergency response after tropical weather</li>
        <li><a href="/services/pet-screen-installation">Pet Screen Installation</a> — Heavy-duty mesh for dog and cat households</li>
        <li><a href="/services/screw-fastener-replacement">Fastener Replacement</a> — Coastal-rated Nylo-Tec and stainless screws</li>
      </ul>
    </div>

    <div class="mt-12">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {SITE_CONFIG.services.slice(0, 6).map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-8">Frequently Asked Questions — {city}</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((item) => (
          <details class="border border-gray-200 rounded-xl overflow-hidden group">
            <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold text-primary hover:bg-gray-50 list-none">
              {item.name}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">{item.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading={`Get a Free Estimate in ${city}`} />
    </div>
  </div>
</BaseLayout>
