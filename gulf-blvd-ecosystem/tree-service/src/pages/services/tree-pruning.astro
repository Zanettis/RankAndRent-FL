---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Tree Pruning',
  name: 'Tree Pruning — Gulf Blvd, FL',
  description: 'Structural and health pruning by ISA-certified arborists along Gulf Boulevard, FL. Removes deadwood, crossing branches, and storm-vulnerable growth in Florida\'s subtropical coastal species.',
  provider: { '@type': 'LocalBusiness', name: SITE_CONFIG.name, url: SITE_CONFIG.domain, telephone: SITE_CONFIG.phone },
  areaServed: SITE_CONFIG.locations.map(l => ({ '@type': 'City', name: l.city })),
  offers: { '@type': 'Offer', priceSpecification: { '@type': 'PriceSpecification', minPrice: '150', maxPrice: '900', priceCurrency: 'USD' } },
  speakable: { '@type': 'SpeakableSpecification', cssSelector: ['h1', '.service-description'] },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${SITE_CONFIG.domain}/services/` },
    { '@type': 'ListItem', position: 3, name: 'Tree Pruning', item: `${SITE_CONFIG.domain}/services/tree-pruning/` },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'What is the difference between tree trimming and tree pruning?', acceptedAnswer: { '@type': 'Answer', text: 'Trimming primarily addresses aesthetics and size — reducing canopy bulk and keeping trees within bounds. Pruning is more targeted: it addresses specific structural or health concerns, such as removing dead limbs, correcting co-dominant leads, removing crossing branches, or improving the branch architecture of young trees. Both require different skill levels; pruning should always be done by a certified arborist.' } },
    { '@type': 'Question', name: 'Why do Live Oaks on Gulf Blvd need professional pruning?', acceptedAnswer: { '@type': 'Answer', text: 'Live Oaks develop complex branch structures over decades. Incorrect pruning — including topping or removing major scaffold branches — permanently damages the tree\'s storm resistance and health. ISA-certified arborists prune Live Oaks to ISA standards, removing only what is necessary and making cuts that allow the tree to close properly.' } },
    { '@type': 'Question', name: 'How often should I have my trees pruned on Gulf Blvd?', acceptedAnswer: { '@type': 'Answer', text: 'Most mature trees along Gulf Blvd benefit from a professional inspection and targeted pruning every 2–3 years. Young trees may need annual structural pruning in the first 5 years to develop a strong branch architecture. Palm frond removal is typically done annually.' } },
  ],
};
---

<BaseLayout
  title="Tree Pruning Gulf Blvd FL | ISA-Certified Arborists | Structural & Health Pruning"
  description="Structural and health tree pruning by ISA-certified arborists along Gulf Boulevard, FL. Deadwood removal, storm-vulnerable branch correction, and Live Oak pruning. Free estimates."
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Hero
    headline="Professional Tree Pruning on Gulf Blvd — ISA Standards, Every Job"
    subheadline="Structural and health pruning for Live Oak, Sabal Palm, and other coastal FL species. Certified arborists serving Indian Rocks Beach to St. Pete Beach."
    ctaText="Get a Free Estimate"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <a href="/services" class="hover:text-primary">Services</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">Tree Pruning</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>Why Pruning Matters More Than Trimming for Gulf Blvd Trees</h2>
      <p>
        Tree trimming reduces size. Tree pruning improves structure and long-term health. On Gulf
        Blvd's coastal properties, proper pruning is especially critical: trees under salt air stress
        and in sandy soils need strong branch architecture to resist storm loads over their lifetimes.
        A poorly pruned tree isn't just ugly — it's a future liability.
      </p>

      <h2>Types of Pruning We Perform</h2>
      <ul>
        <li><strong>Crown Cleaning:</strong> Removal of dead, dying, diseased, and crossing branches. The foundation of any good pruning program.</li>
        <li><strong>Structural Pruning:</strong> Corrects form in young trees by selecting dominant leads and spacing scaffold branches for long-term strength.</li>
        <li><strong>Crown Lifting:</strong> Raises the lower canopy to improve clearance over walkways, driveways, and sightlines while maintaining the tree's natural form.</li>
        <li><strong>Deadwood Removal:</strong> Removes dead branches that are storm projectiles and disease entry points. Critical before hurricane season.</li>
      </ul>

      <h2>ISA Certification — Why It Matters Here</h2>
      <p>
        Florida's subtropical species don't respond to pruning the same way as temperate species
        commonly covered in general arboriculture training. ISA certification ensures our arborists
        are trained in the specific biology of Live Oak, Sabal Palm, Slash Pine, and other Gulf
        Coast species — including how and where to make cuts that heal properly in our hot, humid
        climate.
      </p>
      <p>
        We never top trees. Topping is not a recognized pruning technique — it permanently damages
        the tree's structure, triggers vigorous but weakly attached regrowth, and accelerates decay
        at the cut surfaces.
      </p>

      <h2>Pruning Costs on Gulf Blvd</h2>
      <p>
        Structural and health pruning typically costs $150–$900 per tree depending on size, species,
        and the extent of work needed. We provide free on-site estimates and always explain which
        specific cuts are being made and why before we start.
      </p>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-6">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {[
          { q: 'What is the difference between tree trimming and tree pruning?', a: 'Trimming primarily addresses aesthetics and size. Pruning is more targeted: it addresses structural or health concerns, such as removing dead limbs, correcting co-dominant leads, or improving branch architecture of young trees. Pruning should always be done by a certified arborist.' },
          { q: 'Why do Live Oaks on Gulf Blvd need professional pruning?', a: 'Live Oaks develop complex branch structures over decades. Incorrect pruning permanently damages storm resistance and health. ISA-certified arborists prune Live Oaks to ISA standards, removing only what is necessary and making cuts that allow the tree to close properly.' },
          { q: 'How often should I have my trees pruned on Gulf Blvd?', a: 'Most mature trees benefit from a professional inspection and targeted pruning every 2–3 years. Young trees may need annual structural pruning in the first 5 years. Palm frond removal is typically done annually.' },
        ].map(({ q, a }) => (
          <details class="border border-gray-200 rounded-xl overflow-hidden group">
            <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold text-primary hover:bg-gray-50 list-none">
              {q}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">{a}</div>
          </details>
        ))}
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-6">Other Services We Offer</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {SITE_CONFIG.services.filter(s => s.href !== '/services/tree-pruning').slice(0, 3).map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading="Get Your Free Tree Pruning Estimate" />
    </div>
  </div>
</BaseLayout>
