---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Emergency Tree Service',
  name: '24/7 Emergency Tree Service — Gulf Blvd, FL',
  description: '24/7 emergency tree service after hurricanes and tropical storms along Gulf Boulevard, FL. We prioritize trees fallen on structures. Same-day response for life-safety situations.',
  provider: { '@type': 'LocalBusiness', name: SITE_CONFIG.name, url: SITE_CONFIG.domain, telephone: SITE_CONFIG.phone },
  areaServed: SITE_CONFIG.locations.map(l => ({ '@type': 'City', name: l.city })),
  offers: { '@type': 'Offer', priceSpecification: { '@type': 'PriceSpecification', minPrice: '500', maxPrice: '3000', priceCurrency: 'USD' } },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${SITE_CONFIG.domain}/services/` },
    { '@type': 'ListItem', position: 3, name: 'Emergency Tree Service', item: `${SITE_CONFIG.domain}/services/emergency-tree-service/` },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'How quickly can you respond after a hurricane on Gulf Blvd?', acceptedAnswer: { '@type': 'Answer', text: 'For trees fallen on structures or blocking safe access, we target a 2–4 hour response time during daylight hours. For storm debris and non-structural damage, we work the full Gulf Blvd corridor and typically reach all customers within 24–48 hours after a named storm. Call as soon as conditions are safe — our schedule fills fast after major events.' } },
    { '@type': 'Question', name: 'Should I document storm tree damage for my homeowner\'s insurance?', acceptedAnswer: { '@type': 'Answer', text: 'Yes — document everything before any cleanup begins. Photograph the fallen tree from multiple angles, showing the damage to your structure. Get a written estimate from us before any work starts. Most Florida homeowner\'s insurance policies cover tree removal when a fallen tree damages a covered structure, but the burden of proof is on you — photos and a written estimate are your evidence.' } },
    { '@type': 'Question', name: 'Is it safe to approach a tree that has fallen near power lines?', acceptedAnswer: { '@type': 'Answer', text: 'No. Stay well clear of any tree in contact with or near power lines — assume all downed lines are energized. Contact Duke Energy or TECO to de-energize the lines before anyone approaches. We will not begin work on a tree entangled with live power lines until the utility has confirmed de-energization.' } },
  ],
};
---

<BaseLayout
  title="24/7 Emergency Tree Service Gulf Blvd FL | Hurricane Storm Damage Response"
  description="24/7 emergency tree service after hurricanes and tropical storms along Gulf Boulevard, FL. We prioritize trees on structures. Fast response from Indian Rocks Beach to St. Pete Beach."
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Hero
    headline="24/7 Emergency Tree Service on Gulf Blvd — We're There After the Storm"
    subheadline="Immediate response for storm-downed trees after hurricanes and tropical storms. We prioritize trees fallen on structures. Call us now — our schedule fills fast after major storms."
    ctaText={`Call Now: ${SITE_CONFIG.phone}`}
    ctaHref={`tel:${SITE_CONFIG.phone}`}
    secondaryCtaText="Request Online"
    secondaryCtaHref="/contact"
    badges={["24/7 Emergency Line", "Hurricane Response", "Same-Day for Structural Falls", "Gulf Blvd Corridor"]}
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <a href="/services" class="hover:text-primary">Services</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">Emergency Tree Service</span>
    </nav>

    <!-- Emergency callout box -->
    <div class="bg-red-50 border-2 border-red-300 rounded-2xl p-6 mb-12 text-center">
      <h2 class="text-2xl font-bold text-red-800 mb-2">Storm Emergency?</h2>
      <p class="text-red-700 mb-4">Call us now — 24/7 for trees fallen on structures.</p>
      <a href={`tel:${SITE_CONFIG.phone}`} class="inline-block bg-red-600 text-white font-bold text-xl px-8 py-4 rounded-xl hover:bg-red-700 transition-colors">
        {SITE_CONFIG.phone}
      </a>
    </div>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>What to Do After a Hurricane Damages Your Trees</h2>
      <p>
        First priority is safety. Stay inside until authorities confirm conditions are safe.
        Do not approach trees in contact with power lines — assume all downed lines are energized.
        Once it's safe to go outside, assess your property from a distance before approaching.
      </p>
      <p>
        When you call us, tell us immediately if a tree has fallen on your structure — that
        determines our dispatch priority. Trees fallen on occupied structures or blocking
        emergency access get first response. Storm debris and hanging limbs are addressed
        in the following 24–48 hours as we work down the corridor.
      </p>

      <h2>Insurance Documentation — Do This Before Cleanup</h2>
      <p>
        Before we begin work, take photographs of the fallen tree and the damage to your property.
        Photograph from multiple angles. A written estimate from us before work starts is typically
        required for Florida homeowner's insurance claims. We provide written estimates — ask for
        one specifically for insurance purposes.
      </p>
      <p>
        Most Florida homeowner's policies cover tree removal costs when a fallen tree damages
        a covered structure (roof, fence, pool cage). Tree removal from yards without structural
        damage is typically not covered unless debris blocks a driveway or access.
      </p>

      <h2>After the Immediate Emergency</h2>
      <p>
        Once the emergency is resolved, consider a post-storm tree inspection. Storms stress trees
        that look intact — splitting root systems, weakened attachment points, and internal decay
        revealed by the storm can make a "surviving" tree more dangerous than the one that fell.
        Our ISA-certified arborists can assess your remaining trees and identify future risks.
      </p>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-6">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {[
          { q: 'How quickly can you respond after a hurricane on Gulf Blvd?', a: 'For trees fallen on structures or blocking safe access, we target a 2–4 hour response during daylight hours. For storm debris and non-structural damage, we typically reach all Gulf Blvd customers within 24–48 hours after a named storm. Call as soon as conditions are safe — our schedule fills fast.' },
          { q: 'Should I document storm tree damage for my homeowner\'s insurance?', a: 'Yes — document everything before cleanup begins. Photograph the fallen tree from multiple angles showing damage to your structure. Get a written estimate from us before any work starts. Most FL homeowner\'s insurance policies cover tree removal when a fallen tree damages a covered structure.' },
          { q: 'Is it safe to approach a tree that has fallen near power lines?', a: 'No. Stay well clear of any tree in contact with or near power lines — assume all downed lines are energized. Contact Duke Energy or TECO to de-energize the lines. We will not begin work on a tree entangled with live power lines until the utility confirms de-energization.' },
        ].map(({ q, a }) => (
          <details class="border border-gray-200 rounded-xl overflow-hidden group">
            <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold text-primary hover:bg-gray-50 list-none">
              {q}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">{a}</div>
          </details>
        ))}
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-6">Other Services We Offer</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {SITE_CONFIG.services.filter(s => s.href !== '/services/emergency-tree-service').slice(0, 3).map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading="Need Emergency Tree Service? Tell Us What Happened" />
    </div>
  </div>
</BaseLayout>
