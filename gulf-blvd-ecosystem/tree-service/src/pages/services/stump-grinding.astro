---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Stump Grinding',
  name: 'Stump Grinding — Gulf Blvd, FL',
  description: 'Complete stump grinding and removal along Gulf Boulevard, FL. Ground 6–12 inches below grade. Sandy coastal soil makes grinding fast. No regrowth, no tripping hazards near pools or walkways.',
  provider: { '@type': 'LocalBusiness', name: SITE_CONFIG.name, url: SITE_CONFIG.domain, telephone: SITE_CONFIG.phone },
  areaServed: SITE_CONFIG.locations.map(l => ({ '@type': 'City', name: l.city })),
  offers: { '@type': 'Offer', priceSpecification: { '@type': 'PriceSpecification', minPrice: '100', maxPrice: '600', priceCurrency: 'USD' } },
  speakable: { '@type': 'SpeakableSpecification', cssSelector: ['h1', '.service-description'] },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${SITE_CONFIG.domain}/services/` },
    { '@type': 'ListItem', position: 3, name: 'Stump Grinding', item: `${SITE_CONFIG.domain}/services/stump-grinding/` },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'How much does stump grinding cost on Gulf Blvd, FL?', acceptedAnswer: { '@type': 'Answer', text: 'Stump grinding on Gulf Blvd typically costs $100–$600 depending on stump diameter, root flare size, and location. Sandy coastal soil makes grinding faster than clay or rocky soils. Pricing is usually calculated per inch of diameter at ground level. We provide free estimates and offer bundle discounts when combined with tree removal.' } },
    { '@type': 'Question', name: 'How deep do you grind the stump?', acceptedAnswer: { '@type': 'Answer', text: 'We grind stumps 6–12 inches below grade as standard. If you\'re planning to replant with a Sabal Palm or other tree species, we can go deeper to ensure adequate space for the root ball. Stumps near pool decks and walkways are ground flush to surface and below to eliminate tripping hazards.' } },
    { '@type': 'Question', name: 'Will the stump grow back after grinding?', acceptedAnswer: { '@type': 'Answer', text: 'Grinding destroys the cambium layer of the stump, which prevents regrowth. Some species like Sea Grape may sprout from remaining lateral roots — we can treat roots with a stump killer application if regrowth is a concern. This is typically not necessary for most species.' } },
  ],
};
---

<BaseLayout
  title="Stump Grinding Gulf Blvd FL | Fast Coastal Stump Removal"
  description="Professional stump grinding along Gulf Boulevard, FL. Sandy coastal soil makes grinding fast. Ground 6–12 inches below grade. Free estimates — bundle with tree removal for discount."
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Hero
    headline="Stump Grinding on Gulf Blvd — Fast, Clean, Complete"
    subheadline="Complete stump removal ground 6–12 inches below grade. Sandy coastal soil, quick turnaround. No regrowth, no tripping hazards. Indian Rocks Beach to St. Pete Beach."
    ctaText="Get a Free Estimate"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <a href="/services" class="hover:text-primary">Services</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">Stump Grinding</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>Why Stump Grinding Matters on Gulf Blvd Properties</h2>
      <p>
        A stump left in the ground doesn't just look bad — it creates tripping hazards on walkways
        near pools, interferes with lawn equipment, and can harbor insects. On Gulf Blvd's barrier
        island properties where lots are tight and outdoor living areas are constantly in use,
        removing stumps completely is the right call.
      </p>

      <h2>The Coastal Soil Advantage</h2>
      <p>
        Gulf Blvd properties sit on barrier island sandy soil — much easier to grind through than
        the clay or rock-mixed soils found inland. This means our stump grinding jobs on Gulf
        Boulevard are typically faster than comparable jobs elsewhere, which keeps costs lower.
        We pass that efficiency on to our customers.
      </p>

      <h2>Stump Depth and Replanting</h2>
      <p>
        Standard stump grinding depth is 6–12 inches below grade — deep enough to prevent regrowth
        and eliminate surface hazards. If you're planning to replant with a Sabal Palm, Live Oak,
        or other species, let us know and we'll grind deeper to give the new root ball adequate space.
        For stumps near pool decks, walkways, or driveways, we grind flush to surface and slightly
        below to eliminate trip hazards entirely.
      </p>

      <h2>Stump Grinding Cost on Gulf Blvd</h2>
      <p>
        Stump grinding on Gulf Boulevard typically costs $100–$600 depending on stump diameter,
        root flare complexity, and access. Pricing is usually calculated per inch of diameter at
        ground level — a 12" stump is significantly faster to grind than a 36" Live Oak base
        with widespread surface roots. We offer bundle pricing when stump grinding is combined
        with tree removal on the same visit.
      </p>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-6">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {[
          { q: 'How much does stump grinding cost on Gulf Blvd, FL?', a: 'Stump grinding on Gulf Blvd typically costs $100–$600 depending on stump diameter and location. Sandy coastal soil makes grinding faster. We offer bundle discounts when combined with tree removal.' },
          { q: 'How deep do you grind the stump?', a: 'We grind stumps 6–12 inches below grade as standard. For replanting with Sabal Palm or other species, we can grind deeper. Near pool decks and walkways, we grind flush and below to eliminate tripping hazards.' },
          { q: 'Will the stump grow back after grinding?', a: 'Grinding destroys the cambium layer, preventing regrowth. Some species like Sea Grape may sprout from lateral roots — we can treat with a stump killer if needed. Typically not necessary for most species.' },
        ].map(({ q, a }) => (
          <details class="border border-gray-200 rounded-xl overflow-hidden group">
            <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold text-primary hover:bg-gray-50 list-none">
              {q}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">{a}</div>
          </details>
        ))}
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-6">Other Services We Offer</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {SITE_CONFIG.services.filter(s => s.href !== '/services/stump-grinding').slice(0, 3).map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading="Get Your Free Stump Grinding Estimate" />
    </div>
  </div>
</BaseLayout>
