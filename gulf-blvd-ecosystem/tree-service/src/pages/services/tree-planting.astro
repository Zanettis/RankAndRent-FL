---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Tree Planting',
  name: 'Tree Planting — Gulf Blvd, FL',
  description: 'Expert selection and planting of salt-tolerant Florida-native species along Gulf Boulevard, FL. Sabal Palm, Live Oak, Sea Grape, Slash Pine. Right tree, right place, right care.',
  provider: { '@type': 'LocalBusiness', name: SITE_CONFIG.name, url: SITE_CONFIG.domain, telephone: SITE_CONFIG.phone },
  areaServed: SITE_CONFIG.locations.map(l => ({ '@type': 'City', name: l.city })),
  offers: { '@type': 'Offer', priceSpecification: { '@type': 'PriceSpecification', minPrice: '300', maxPrice: '2000', priceCurrency: 'USD' } },
  speakable: { '@type': 'SpeakableSpecification', cssSelector: ['h1', '.service-description'] },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${SITE_CONFIG.domain}/services/` },
    { '@type': 'ListItem', position: 3, name: 'Tree Planting', item: `${SITE_CONFIG.domain}/services/tree-planting/` },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'What trees are best for Gulf Blvd, FL properties?', acceptedAnswer: { '@type': 'Answer', text: 'The best trees for Gulf Blvd\'s salt air and sandy soils are: Sabal Palm (Florida\'s state tree — salt tolerant and hurricane resistant when established), Live Oak (most hurricane-resistant native tree — slow growing but long-lived), Sea Grape (fast-growing, excellent salt spray tolerance, beach-appropriate aesthetics), and Slash Pine (fast-growing FL native, good for larger lots). Avoid Australian Pine and Melaleuca — both are invasive species listed as prohibited by Florida DEP.' } },
    { '@type': 'Question', name: 'When is the best time to plant trees in Florida?', acceptedAnswer: { '@type': 'Answer', text: 'Fall through early spring (October through March) is the ideal planting window in Florida. This avoids the intense summer heat and the risk of planting right before hurricane season. New trees are particularly vulnerable in their first 2 years — establishing them before summer heat and storm season significantly improves survival rates.' } },
    { '@type': 'Question', name: 'Can I plant a Sabal Palm to replace a removed tree in Pinellas County?', acceptedAnswer: { '@type': 'Answer', text: 'Yes — planting a Sabal Palm (Florida\'s state tree) is often specifically encouraged as a replacement under Pinellas County\'s tree mitigation requirements. When a permit is required to remove a protected tree, planting a replacement Sabal Palm or Live Oak is frequently part of the mitigation condition. We can advise on mitigation requirements when we handle your removal permit.' } },
  ],
};
---

<BaseLayout
  title="Tree Planting Gulf Blvd FL | Salt-Tolerant Florida Native Species"
  description="Expert tree planting and species selection for Gulf Blvd, FL properties. Salt-tolerant Florida natives: Sabal Palm, Live Oak, Sea Grape, Slash Pine. Right tree, right place. Free estimates."
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Hero
    headline="Tree Planting on Gulf Blvd — Right Tree, Right Place"
    subheadline="Expert species selection and planting of salt-tolerant Florida natives for Gulf Coast barrier island properties. Sabal Palm, Live Oak, Sea Grape, Slash Pine."
    ctaText="Get a Free Consultation"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <a href="/services" class="hover:text-primary">Services</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">Tree Planting</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>Species Selection Matters Most on Gulf Blvd</h2>
      <p>
        Planting the wrong tree in a Gulf Blvd coastal environment means watching it struggle,
        die, or become a hazard. Salt spray from the Gulf, shallow sandy soil with low organic
        matter, and the constant threat of hurricane winds create a challenging environment.
        The right species not only survive — they thrive and become assets to the property.
      </p>

      <h2>Best Trees for Gulf Blvd Properties</h2>
      <p><strong>Sabal Palm (<em>Sabal palmetto</em>) — Florida's State Tree</strong><br />
      Excellent salt tolerance, moderate drought resistance once established, and good hurricane
      resistance when properly maintained. Avoid over-trimming — keep all green fronds.
      Height at maturity: 40–70 ft.</p>

      <p><strong>Live Oak (<em>Quercus virginiana</em>)</strong><br />
      The most hurricane-resistant native tree in Florida when properly pruned and structurally
      sound. Slow-growing but exceptionally long-lived. Creates dense canopy that significantly
      increases property value. Requires patience — a 5-year-old Live Oak is 10–15 feet tall.
      Height at maturity: 40–80 ft.</p>

      <p><strong>Sea Grape (<em>Coccoloba uvifera</em>)</strong><br />
      Fast-growing, excellent salt spray and wind tolerance, beach-appropriate aesthetics.
      Can be pruned into small tree form or allowed to grow as large shrub/multi-trunk tree.
      Produces edible grape-like clusters in late summer. Height: 15–25 ft.</p>

      <p><strong>Slash Pine (<em>Pinus elliottii</em>)</strong><br />
      Fast-growing Florida native, good for larger lots where height is desirable. Moderate
      salt tolerance. Requires annual crown cleaning to reduce hurricane vulnerability — deadwood
      in Slash Pine becomes projectiles in storms. Best for lots with more space from structures.
      Height at maturity: 60–100 ft.</p>

      <h2>Trees to Avoid on Gulf Blvd</h2>
      <ul>
        <li><strong>Australian Pine (<em>Casuarina equisetifolia</em>):</strong> Listed as a Category I invasive species by the Florida Invasive Species Council. Prohibited by Florida DEP. Illegal to plant — do not install.</li>
        <li><strong>Melaleuca (<em>Melaleuca quinquenervia</em>):</strong> Also Category I invasive. Prohibited to plant under Florida law.</li>
        <li><strong>Royal Palm:</strong> Beautiful but vulnerable to lethal yellowing disease and salt stress without proper care. High maintenance in our environment.</li>
      </ul>

      <h2>Best Planting Time in Florida</h2>
      <p>
        Plant trees from October through March — after summer heat and before the next hurricane
        season. New trees in their first two years are especially vulnerable to storm stress.
        Establishing root systems in cooler, wetter weather significantly improves survival rates
        before the first summer and storm season they face.
      </p>

      <h2>Tree Planting Costs on Gulf Blvd</h2>
      <p>
        Tree planting costs range from $300 to $2,000 depending on species, tree size at planting,
        and installation complexity. Sabal Palms transplant well at larger sizes and cost more
        than seedlings but establish much faster. Live Oaks are typically planted small and are
        less expensive. All pricing includes proper hole preparation, soil amendment for barrier
        island sandy soils, and post-planting care instructions.
      </p>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-6">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {[
          { q: 'What trees are best for Gulf Blvd, FL properties?', a: 'Best choices: Sabal Palm (FL state tree — salt tolerant, hurricane resistant), Live Oak (most hurricane-resistant native, slow growing), Sea Grape (fast-growing, excellent salt spray tolerance), and Slash Pine (fast-growing native). Avoid Australian Pine and Melaleuca — both are invasive and prohibited by Florida DEP.' },
          { q: 'When is the best time to plant trees in Florida?', a: 'Fall through early spring (October–March) is the ideal planting window. This avoids intense summer heat and establishes root systems before hurricane season. New trees in their first two years are especially vulnerable to storm stress.' },
          { q: 'Can I plant a Sabal Palm to replace a removed tree in Pinellas County?', a: 'Yes — planting a Sabal Palm or Live Oak is often specifically required as a mitigation condition when a permit is issued for removing a protected tree in Pinellas County. We advise on mitigation requirements when we handle your removal permit.' },
        ].map(({ q, a }) => (
          <details class="border border-gray-200 rounded-xl overflow-hidden group">
            <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold text-primary hover:bg-gray-50 list-none">
              {q}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">{a}</div>
          </details>
        ))}
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-6">Other Services We Offer</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {SITE_CONFIG.services.filter(s => s.href !== '/services/tree-planting').slice(0, 3).map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading="Get Your Free Tree Planting Consultation" />
    </div>
  </div>
</BaseLayout>
