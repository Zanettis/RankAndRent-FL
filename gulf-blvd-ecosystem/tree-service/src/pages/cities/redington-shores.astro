---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const city = 'Redington Shores';
const citySlug = 'redington-shores';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: `How much does tree removal cost in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Tree removal in ${city} typically ranges from $400 to $2,500 depending on tree size, species, and access. ${city} has more lot depth than communities further north — on open lots with no obstructions, felling is possible, which reduces cost compared to rigging. Pinellas County permit fees may apply. Free on-site estimates available.` } },
    { '@type': 'Question', name: `Do you offer emergency tree service in ${city} after a storm?`, acceptedAnswer: { '@type': 'Answer', text: `Yes — 24/7 emergency tree service in ${city} after hurricanes and tropical storms. Trees on structures or blocking access get priority response. Call as soon as conditions are safe.` } },
    { '@type': 'Question', name: `Can you clear trees for a pool addition or home expansion in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Yes — we regularly work with ${city} homeowners on lot clearing for pool additions, lanai expansions, and construction projects. We assess which trees can be removed under Pinellas County's permit process and identify any protected species that require mitigation. We handle the permit paperwork and coordinate with your contractor's timeline.` } },
    { '@type': 'Question', name: `Do I need a permit to remove a tree in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Yes. ${city} falls under Pinellas County's tree ordinance, which requires permits for most removals — particularly for Live Oak, Sabal Palm, and other protected species. We handle all permit paperwork as part of our service.` } },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: `${SITE_CONFIG.domain}/cities/` },
    { '@type': 'ListItem', position: 3, name: city, item: `${SITE_CONFIG.domain}/cities/${citySlug}/` },
  ],
};
---

<BaseLayout
  title={`Tree Service ${city} FL | Tree Removal, Clearing & Storm Response`}
  description={`Professional tree removal, lot clearing, and emergency storm tree service in ${city}, FL. Larger lots — felling and rigging options. ISA-certified arborists. Free estimates.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Hero
    headline={`Tree Service in ${city}, FL — Removal, Clearing & Storm Response`}
    subheadline={`Tree removal, lot clearing for additions, and 24/7 emergency storm service in ${city}. More lot depth means more options — we match the right approach to your specific property.`}
    ctaText="Get a Free Estimate"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">{city}</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>Tree Service in {city}, FL</h2>
      <p>
        {city} sits mid-corridor on Gulf Boulevard with a mix of residential properties that
        tend to have a bit more lot depth than the communities at the north end of the barrier
        island chain. That matters for tree removal: on lots with sufficient clearance from
        structures and property lines, felling is an option — which reduces the time, equipment,
        and cost compared to full rigging operations.
      </p>
      <p>
        We assess every job individually. When felling is safe, we fell. When rigging is required
        — near pool cages, structures, or neighboring property — we rig. The goal is always the
        safest, most efficient approach for your specific property.
      </p>

      <h2>Pool Additions and Home Expansions in {city}</h2>
      <p>
        {city} is an active market for pool additions and lanai expansions — projects that often
        require removing trees to create space. We work regularly with homeowners and contractors
        on pre-construction clearing. We handle the Pinellas County permit process for any
        protected species and advise on mitigation planting when required.
      </p>

      <h2>Services Available in {city}</h2>
      <ul>
        <li><a href="/services/tree-removal">Tree Removal</a> — Felling or rigging based on site conditions — we pick the right approach</li>
        <li><a href="/services/tree-trimming">Tree Trimming</a> — Crown reduction and deadwood removal for hurricane season</li>
        <li><a href="/services/tree-pruning">Tree Pruning</a> — ISA-certified structural pruning for Live Oak and coastal species</li>
        <li><a href="/services/stump-grinding">Stump Grinding</a> — Complete stump removal for pool and construction clearance</li>
        <li><a href="/services/emergency-tree-service">Emergency Tree Service</a> — 24/7 storm response</li>
        <li><a href="/services/land-clearing">Land Clearing</a> — Pre-construction lot clearing with permit coordination</li>
        <li><a href="/services/tree-planting">Tree Planting</a> — FL-native replacement species after construction</li>
      </ul>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-6">Our Services</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {SITE_CONFIG.services.slice(0, 6).map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-8">Frequently Asked Questions — {city}</h2>
      <div class="space-y-4">
        {[
          { q: `How much does tree removal cost in ${city}?`, a: `Tree removal in ${city} ranges from $400 to $2,500. On open lots, felling reduces cost vs. rigging. Pinellas County permit fees may apply. Free on-site estimates available.` },
          { q: `Do you offer emergency tree service in ${city} after a storm?`, a: `Yes — 24/7 emergency service after hurricanes and tropical storms. Trees on structures get priority response. Call as soon as conditions are safe.` },
          { q: `Can you clear trees for a pool addition in ${city}?`, a: `Yes — we work with homeowners on pre-construction clearing. We handle Pinellas County permits, identify protected species, and coordinate with your contractor's timeline.` },
          { q: `Do I need a permit to remove a tree in ${city}?`, a: `Yes. Pinellas County's tree ordinance requires permits for most removals, especially Live Oak and Sabal Palm. We handle all permit paperwork as part of our service.` },
        ].map(({ q, a }) => (
          <details class="border border-gray-200 rounded-xl overflow-hidden group">
            <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold text-primary hover:bg-gray-50 list-none">
              {q}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">{a}</div>
          </details>
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading={`Get a Free Estimate in ${city}`} />
    </div>
  </div>
</BaseLayout>
