---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const city = 'Redington Beach';
const citySlug = 'redington-beach';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: `How much does tree removal cost in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Tree removal in ${city} typically ranges from $400 to $2,500 depending on tree size, species, and property access. ${city}'s mature Live Oak canopy means many jobs involve large-diameter trees — these require more crew time and equipment. Pinellas County permit fees may also apply. Free on-site estimates available.` } },
    { '@type': 'Question', name: `Do you offer emergency tree service in ${city} after a storm?`, acceptedAnswer: { '@type': 'Answer', text: `Yes — we provide 24/7 emergency tree service in ${city} after hurricanes and tropical storms. ${city}'s mature Live Oaks, while generally storm-resistant when healthy, can drop large limbs or uproot in saturated soil. Trees on structures or blocking access get priority response. Call as soon as conditions are safe.` } },
    { '@type': 'Question', name: `How do you prune Live Oaks in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `We follow ISA pruning standards for Live Oak structural pruning: deadwood removal, crossing branch elimination, and weight reduction on extended limbs. We never top Live Oaks — it creates decay entry points and structurally weakens the tree. Properly pruned Live Oaks are more hurricane-resistant, not less.` } },
    { '@type': 'Question', name: `Can you trim trees before hurricane season in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Yes — book 6–8 weeks before June 1st. For ${city}'s mature Live Oaks and larger trees, crown cleaning and deadwood removal are the key pre-season services. We recommend April appointments to ensure coverage before summer storm season.` } },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: `${SITE_CONFIG.domain}/cities/` },
    { '@type': 'ListItem', position: 3, name: city, item: `${SITE_CONFIG.domain}/cities/${citySlug}/` },
  ],
};
---

<BaseLayout
  title={`Tree Service ${city} FL | Live Oak Pruning & Storm Tree Removal`}
  description={`Professional tree removal, Live Oak pruning, and emergency storm tree service in ${city}, FL. ISA-certified arborists. Structural pruning for mature coastal trees. Free estimates.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Hero
    headline={`Tree Service in ${city}, FL — Live Oak Specialists`}
    subheadline={`Tree removal, structural pruning, and emergency storm service for ${city}'s mature canopy. ISA-certified arborists who know how to keep Live Oaks healthy and hurricane-resistant.`}
    ctaText="Get a Free Estimate"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">{city}</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>Tree Service in {city}, FL</h2>
      <p>
        {city} is one of the quieter residential communities on the Gulf Boulevard corridor — and
        home to some of the most mature Live Oak canopy on the barrier island chain. These trees
        are an asset: properly maintained Live Oaks are among the most hurricane-resistant trees
        in Florida and significantly increase property values. Neglected, they become liabilities.
      </p>
      <p>
        Structural pruning is the most important investment {city} homeowners can make in their
        Live Oaks. Deadwood removal, crossing branch elimination, and weight reduction on extended
        limbs before storm season dramatically reduces the risk of catastrophic failure.
      </p>

      <h2>Live Oak Pruning in {city}</h2>
      <p>
        Live Oak pruning done wrong does more harm than no pruning at all. Over-trimming, topping,
        and lion's tailing all create weak branch structure, decay entry points, and long-term
        tree health problems. Our ISA-certified arborists follow the ANSI A300 pruning standard:
        no more than 25% canopy removal in a single session, no topping, crown cleaning and
        deadwood removal as the primary tools.
      </p>

      <h2>Services Available in {city}</h2>
      <ul>
        <li><a href="/services/tree-removal">Tree Removal</a> — Large-diameter mature tree removal with proper equipment</li>
        <li><a href="/services/tree-trimming">Tree Trimming</a> — Crown cleaning and deadwood removal before storm season</li>
        <li><a href="/services/tree-pruning">Tree Pruning</a> — ISA-certified structural pruning for Live Oak and Sabal Palm</li>
        <li><a href="/services/stump-grinding">Stump Grinding</a> — Full stump removal, 6–12 inches below grade</li>
        <li><a href="/services/emergency-tree-service">Emergency Tree Service</a> — 24/7 storm response for mature tree failures</li>
        <li><a href="/services/tree-planting">Tree Planting</a> — Salt-tolerant FL natives to complement your existing canopy</li>
      </ul>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-6">Our Services</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {SITE_CONFIG.services.slice(0, 6).map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-8">Frequently Asked Questions — {city}</h2>
      <div class="space-y-4">
        {[
          { q: `How much does tree removal cost in ${city}?`, a: `Tree removal in ${city} ranges from $400 to $2,500. Mature Live Oaks can require more crew time and equipment. Pinellas County permit fees may apply. Free on-site estimates available.` },
          { q: `Do you offer emergency tree service in ${city} after a storm?`, a: `Yes — 24/7 emergency service after hurricanes and tropical storms. ${city}'s mature Live Oaks can drop large limbs in saturated soil. Trees on structures get priority response.` },
          { q: `How do you prune Live Oaks in ${city}?`, a: `ISA standards: deadwood removal, crossing branch elimination, weight reduction on extended limbs. We never top Live Oaks — it creates decay and weakens structure. Properly pruned Live Oaks are more hurricane-resistant.` },
          { q: `Can you trim trees before hurricane season in ${city}?`, a: `Yes — book 6–8 weeks before June 1st. Crown cleaning and deadwood removal are key for ${city}'s mature Live Oaks. April appointments recommended.` },
        ].map(({ q, a }) => (
          <details class="border border-gray-200 rounded-xl overflow-hidden group">
            <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold text-primary hover:bg-gray-50 list-none">
              {q}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">{a}</div>
          </details>
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading={`Get a Free Estimate in ${city}`} />
    </div>
  </div>
</BaseLayout>
