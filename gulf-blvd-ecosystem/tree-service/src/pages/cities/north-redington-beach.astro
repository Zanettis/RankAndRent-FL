---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const city = 'North Redington Beach';
const citySlug = 'north-redington-beach';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: `How much does tree removal cost in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Tree removal in ${city} typically ranges from $400 to $2,500 depending on tree size, species, and property access. ${city} has tight residential lots where rigging is frequently required. Pinellas County permit fees may also apply. Free on-site estimates available.` } },
    { '@type': 'Question', name: `Do you offer emergency tree service in ${city} after a hurricane?`, acceptedAnswer: { '@type': 'Answer', text: `Yes — we provide 24/7 emergency tree service in ${city} after hurricanes and tropical storms. Trees on structures or blocking access get priority response. We work the full Gulf Blvd corridor and typically reach ${city} within 24–48 hours after a named storm.` } },
    { '@type': 'Question', name: `Do I need a permit to remove a tree in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Yes. ${city} is governed by Pinellas County's unified tree ordinance, which requires permits for most removals — especially for protected species like Live Oak and Sabal Palm. We handle all permit paperwork as part of our service. No navigating the county process yourself.` } },
    { '@type': 'Question', name: `Can you trim trees before hurricane season in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Yes — book 6–8 weeks before June 1st. Crown reduction and dead limb removal reduce wind resistance significantly. Contact us in April to secure a May pre-season appointment before the schedule fills.` } },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: `${SITE_CONFIG.domain}/cities/` },
    { '@type': 'ListItem', position: 3, name: city, item: `${SITE_CONFIG.domain}/cities/${citySlug}/` },
  ],
};
---

<BaseLayout
  title={`Tree Service ${city} FL | Tree Removal, Trimming & Permit Experts`}
  description={`Professional tree removal, trimming, and emergency storm tree service in ${city}, FL. Small-lot specialists. Pinellas County permit navigation included. ISA-certified arborists. Free estimates.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Hero
    headline={`Tree Service in ${city}, FL — Small-Lot Specialists`}
    subheadline={`Tree removal, trimming, and 24/7 emergency storm service in ${city}. We know tight residential lots and Pinellas County permits — you won't get surprised by either.`}
    ctaText="Get a Free Estimate"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">{city}</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>Tree Service in {city}, FL</h2>
      <p>
        {city} is a compact residential community where the density of homes and trees means
        almost every tree job requires planning. Tight lots leave little room for error — trees
        are close to structures, neighboring properties, pool cages, and utilities. Rigging is
        the rule, not the exception.
      </p>
      <p>
        We specialize in this kind of work. Our rigging-first approach means we safely remove
        trees from spaces that would be impossible to fell, with no damage to your property or
        your neighbors'.
      </p>

      <h2>Permit Navigation in {city}</h2>
      <p>
        {city} homeowners run into two common problems: they don't know a permit is required,
        or they start the process and get stuck in Pinellas County's bureaucracy. We've handled
        hundreds of removal permits in this corridor. When you hire us, the permit is included
        — we file, we wait, we coordinate the inspection if required. You just get the result.
      </p>

      <h2>Services Available in {city}</h2>
      <ul>
        <li><a href="/services/tree-removal">Tree Removal</a> — Rigging specialists for tight residential lots</li>
        <li><a href="/services/tree-trimming">Tree Trimming</a> — Pre-hurricane season crown reduction for barrier island homes</li>
        <li><a href="/services/tree-pruning">Tree Pruning</a> — ISA-certified structural and health pruning</li>
        <li><a href="/services/stump-grinding">Stump Grinding</a> — Complete below-grade stump removal in sandy coastal soil</li>
        <li><a href="/services/emergency-tree-service">Emergency Tree Service</a> — 24/7 storm response</li>
        <li><a href="/services/tree-planting">Tree Planting</a> — Salt-tolerant FL-native replacement species</li>
      </ul>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-6">Our Services</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {SITE_CONFIG.services.slice(0, 6).map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-8">Frequently Asked Questions — {city}</h2>
      <div class="space-y-4">
        {[
          { q: `How much does tree removal cost in ${city}?`, a: `Tree removal in ${city} ranges from $400 to $2,500. Tight residential lots frequently require rigging. Pinellas County permit fees may apply. Free on-site estimates available.` },
          { q: `Do you offer emergency tree service in ${city} after a hurricane?`, a: `Yes — 24/7 emergency service after storms. Trees on structures get priority response. We typically reach ${city} within 24–48 hours after a named storm.` },
          { q: `Do I need a permit to remove a tree in ${city}?`, a: `Yes. Pinellas County requires permits for most removals, especially for Live Oak and Sabal Palm. We handle all permit paperwork — no navigating the county process yourself.` },
          { q: `Can you trim trees before hurricane season in ${city}?`, a: `Yes — book 6–8 weeks before June 1st. Crown reduction and dead limb removal reduce wind resistance. April appointments recommended to secure May pre-season scheduling.` },
        ].map(({ q, a }) => (
          <details class="border border-gray-200 rounded-xl overflow-hidden group">
            <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold text-primary hover:bg-gray-50 list-none">
              {q}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">{a}</div>
          </details>
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading={`Get a Free Estimate in ${city}`} />
    </div>
  </div>
</BaseLayout>
