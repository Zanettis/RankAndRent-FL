---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const city = 'Indian Rocks Beach';
const citySlug = 'indian-rocks-beach';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: `How much does tree removal cost in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Tree removal in ${city} typically ranges from $400 to $2,500 depending on tree size, species, and property access. Narrow lots near pools and seawalls often require rigging rather than felling, which affects cost. Pinellas County permit fees ($100–$250) may also apply. Free on-site estimates available.` } },
    { '@type': 'Question', name: `Do you offer 24/7 emergency tree service in ${city} after a hurricane?`, acceptedAnswer: { '@type': 'Answer', text: `Yes — we prioritize emergency calls in ${city} after storms. Trees fallen on structures or blocking access get first response, typically within 2–4 hours during daylight. For storm debris and non-structural damage, we work the full Gulf Blvd corridor. Call as soon as conditions are safe.` } },
    { '@type': 'Question', name: `Do I need a permit to remove a tree in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Yes. Pinellas County's tree ordinance requires permits for most tree removals in ${city}, especially for protected species like Live Oak and Sabal Palm. We handle the permit paperwork as part of our service so you don't need to navigate the county process yourself.` } },
    { '@type': 'Question', name: `Can you trim trees before hurricane season in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Yes — we recommend booking 6–8 weeks before June 1st. We perform crown reduction and dead limb removal to reduce wind resistance. ${city}'s high concentration of vacation rental properties means we book up early for pre-season inspections — contact us in April to secure a May appointment.` } },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: `${SITE_CONFIG.domain}/cities/` },
    { '@type': 'ListItem', position: 3, name: city, item: `${SITE_CONFIG.domain}/cities/${citySlug}/` },
  ],
};
---

<BaseLayout
  title={`Tree Service ${city} FL | Tree Removal, Trimming & Storm Response`}
  description={`Professional tree removal, trimming, stump grinding, and 24/7 emergency storm service in ${city}, FL. ISA-certified arborists. Rigging specialists for tight coastal lots. Free estimates.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Hero
    headline={`Tree Service in ${city}, FL — Rigging Specialists for Coastal Lots`}
    subheadline={`Tree removal, trimming, and 24/7 emergency storm service for ${city} homeowners and rental properties. ISA-certified arborists familiar with barrier island conditions.`}
    ctaText="Get a Free Estimate"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">{city}</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>Tree Service in {city}, FL</h2>
      <p>
        {city} sits at the northern end of the Gulf Boulevard corridor — a beautiful but demanding
        environment for trees. Salt spray, shallow sandy soils, and direct hurricane exposure
        create conditions where proper tree care isn't optional. It's the difference between
        trees that become assets to your property and trees that become storm liabilities.
      </p>
      <p>
        {city} has a high concentration of vacation rental properties with narrow lots, pool cages,
        and structures just feet apart. Our rigging-first approach is built for exactly these
        conditions — we never fell a tree when rigging is the safer choice.
      </p>

      <h2>Why {city} Homeowners Choose Us</h2>
      <p>
        We're the tree service that {city} property owners call because we do three things other
        contractors don't: we answer the phone, we show up when scheduled, and our arborists are
        actually ISA-certified — not just guys with a chainsaw. We know the difference between
        crown cleaning and lion's tailing, and we know that over-trimming a Sabal Palm is how
        you kill it.
      </p>

      <h2>Services Available in {city}</h2>
      <ul>
        <li><a href="/services/tree-removal">Tree Removal</a> — Rigging specialists for tight coastal lots near pools and seawalls</li>
        <li><a href="/services/tree-trimming">Tree Trimming</a> — Pre-hurricane season crown reduction — book early in April</li>
        <li><a href="/services/tree-pruning">Tree Pruning</a> — ISA-certified structural and health pruning for Live Oak and Sabal Palm</li>
        <li><a href="/services/stump-grinding">Stump Grinding</a> — Sandy coastal soil makes grinding fast — same-day available for most stumps</li>
        <li><a href="/services/emergency-tree-service">Emergency Tree Service</a> — 24/7 response for storm-downed trees</li>
        <li><a href="/services/tree-planting">Tree Planting</a> — Salt-tolerant FL-native species: Sabal Palm, Live Oak, Sea Grape</li>
      </ul>

      <h2>Vacation Rental & Airbnb Tree Service in {city}</h2>
      <p>
        {city}'s Gulf Blvd corridor has one of the highest vacation rental densities on the
        barrier island chain. We offer priority scheduling for property managers — storm cleanup
        between guest stays and pre-season tree inspections before summer rental season.
      </p>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-6">Our Services</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {SITE_CONFIG.services.slice(0, 6).map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-8">Frequently Asked Questions — {city}</h2>
      <div class="space-y-4">
        {[
          { q: `How much does tree removal cost in ${city}?`, a: `Tree removal in ${city} ranges from $400 to $2,500 depending on tree size and property access. Narrow lots near pools and seawalls often require rigging. Pinellas County permit fees may also apply. Free on-site estimates available.` },
          { q: `Do you offer emergency tree service in ${city} after a hurricane?`, a: `Yes — we prioritize emergency calls in ${city} after storms. Trees on structures get first response within 2–4 hours. Call as soon as conditions are safe.` },
          { q: `Do I need a permit to remove a tree in ${city}?`, a: `Yes. Pinellas County requires permits for most tree removals, especially for protected species like Live Oak and Sabal Palm. We handle the permit paperwork as part of our service.` },
          { q: `Can you trim trees before hurricane season in ${city}?`, a: `Yes — book 6–8 weeks before June 1st. ${city} books up early for pre-season work — contact us in April to secure a May appointment.` },
        ].map(({ q, a }) => (
          <details class="border border-gray-200 rounded-xl overflow-hidden group">
            <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold text-primary hover:bg-gray-50 list-none">
              {q}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">{a}</div>
          </details>
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading={`Get a Free Estimate in ${city}`} />
    </div>
  </div>
</BaseLayout>
