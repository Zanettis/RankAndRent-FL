---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const city = 'Madeira Beach';
const citySlug = 'madeira-beach';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: `How much does tree removal cost in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Tree removal in ${city} typically ranges from $400 to $2,500 depending on tree size and property access. ${city}'s John's Pass area has tight lots with structures close together — rigging is common. Pinellas County permits required for most removals. Free on-site estimates available.` } },
    { '@type': 'Question', name: `Do you offer emergency tree service in ${city} after a hurricane?`, acceptedAnswer: { '@type': 'Answer', text: `Yes — ${city} is one of our priority emergency service areas. We work the corridor south from Indian Rocks Beach and typically reach ${city} within 24–48 hours after a named storm. Trees on structures get same-day priority. Call as soon as it is safe.` } },
    { '@type': 'Question', name: `Do you serve vacation rental and Airbnb properties in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Yes — ${city} has one of the highest vacation rental densities on Gulf Blvd. We offer priority scheduling for property managers and Airbnb hosts. Storm cleanup between guest stays and pre-season tree inspections before summer are our most common services for rental property managers here.` } },
    { '@type': 'Question', name: `Can you trim trees before hurricane season in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Yes — book 6–8 weeks before June 1st. Crown reduction and dead limb removal are the key pre-season services. We recommend getting on the schedule in April for a May pre-season appointment in ${city}.` } },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: `${SITE_CONFIG.domain}/cities/` },
    { '@type': 'ListItem', position: 3, name: city, item: `${SITE_CONFIG.domain}/cities/${citySlug}/` },
  ],
};
---

<BaseLayout
  title={`Tree Service ${city} FL | Storm Response & Vacation Rental Tree Care`}
  description={`Professional tree removal, trimming, and 24/7 emergency storm tree service in ${city}, FL. Priority scheduling for vacation rental property managers. ISA-certified arborists. Free estimates.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Hero
    headline={`Tree Service in ${city}, FL — Fast, Reliable, After Every Storm`}
    subheadline={`Tree removal, trimming, and 24/7 emergency storm service in ${city}. Priority scheduling for rental property managers. ISA-certified arborists you can count on.`}
    ctaText="Get a Free Estimate"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">{city}</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>Tree Service in {city}, FL</h2>
      <p>
        {city} is one of the busiest communities on the Gulf Blvd barrier island chain — home
        to John's Pass Village & Boardwalk and one of the highest vacation rental densities on
        the corridor. After every named storm, we get more calls from {city} property managers
        than any other community on the stretch.
      </p>
      <p>
        Post-storm tree cleanup timing is critical for rental properties: a fallen tree or
        dangerous hanging limb means a cancelled booking and a bad review. Our priority
        scheduling for rental properties in {city} is designed to get your property cleared
        and safe between guest stays.
      </p>

      <h2>Services Available in {city}</h2>
      <ul>
        <li><a href="/services/tree-removal">Tree Removal</a> — Tight John's Pass area lots with rigging specialists</li>
        <li><a href="/services/tree-trimming">Tree Trimming</a> — Pre-hurricane season crown reduction for rental properties</li>
        <li><a href="/services/tree-pruning">Tree Pruning</a> — ISA-certified structural pruning for coastal species</li>
        <li><a href="/services/stump-grinding">Stump Grinding</a> — Fast sandy-soil stump removal for yard and rental property maintenance</li>
        <li><a href="/services/emergency-tree-service">Emergency Tree Service</a> — 24/7 storm response, priority for rental properties</li>
        <li><a href="/services/tree-planting">Tree Planting</a> — Salt-tolerant FL natives for landscaping replacement</li>
      </ul>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-6">Our Services</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {SITE_CONFIG.services.slice(0, 6).map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-8">Frequently Asked Questions — {city}</h2>
      <div class="space-y-4">
        {[
          { q: `How much does tree removal cost in ${city}?`, a: `Tree removal in ${city} ranges from $400 to $2,500. John's Pass area tight lots commonly require rigging. Pinellas County permits required for most removals. Free on-site estimates available.` },
          { q: `Do you offer emergency tree service in ${city} after a hurricane?`, a: `Yes — ${city} is a priority emergency service area. We typically reach ${city} within 24–48 hours after a named storm. Trees on structures get same-day priority.` },
          { q: `Do you serve vacation rental properties in ${city}?`, a: `Yes — ${city} has one of the highest rental densities on Gulf Blvd. We offer priority scheduling for property managers. Storm cleanup between guest stays is our most common service here.` },
          { q: `Can you trim trees before hurricane season in ${city}?`, a: `Yes — book 6–8 weeks before June 1st. Crown reduction and dead limb removal are key pre-season services. Get on the schedule in April for a May appointment.` },
        ].map(({ q, a }) => (
          <details class="border border-gray-200 rounded-xl overflow-hidden group">
            <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold text-primary hover:bg-gray-50 list-none">
              {q}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">{a}</div>
          </details>
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading={`Get a Free Estimate in ${city}`} />
    </div>
  </div>
</BaseLayout>
