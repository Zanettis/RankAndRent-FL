---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import LeadForm from '../../components/LeadForm.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE_CONFIG } from '../../config';

const city = 'St. Pete Beach';
const citySlug = 'st-pete-beach';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: `How much does tree removal cost in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Tree removal in ${city} typically ranges from $400 to $2,500 for residential properties. Commercial properties — hotels, restaurants, and retail — often have larger trees or complex access requiring more equipment and crew time, which can push costs higher. Free on-site estimates available. Pinellas County permit fees may also apply.` } },
    { '@type': 'Question', name: `Do you serve hotels and restaurants in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Yes — commercial tree service for hotels, restaurants, and beach properties is a significant part of our ${city} work. We schedule around business operations to minimize disruption: early morning start times, work completed before open, cleanup done before guests arrive. We provide the insurance documentation that commercial property managers require.` } },
    { '@type': 'Question', name: `Can you manage Sea Grape trees at commercial properties in ${city}?`, acceptedAnswer: { '@type': 'Answer', text: `Yes — Sea Grape management is one of the most common commercial tree services we provide in ${city}. Sea Grapes are protected in Florida and cannot be removed from beachfront properties without a DEP coastal permit. We provide the permitted pruning and shaping that keeps Sea Grapes attractive, at the right height for Gulf views, and compliant with Florida's coastal vegetation regulations.` } },
    { '@type': 'Question', name: `Do you offer emergency tree service in ${city} after a hurricane?`, acceptedAnswer: { '@type': 'Answer', text: `Yes — 24/7 emergency tree service in ${city} after hurricanes and tropical storms. Commercial properties with trees on structures or blocking parking lots and access drives get priority. We provide written damage assessments for insurance claims. Call as soon as it is safe.` } },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_CONFIG.domain },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: `${SITE_CONFIG.domain}/cities/` },
    { '@type': 'ListItem', position: 3, name: city, item: `${SITE_CONFIG.domain}/cities/${citySlug}/` },
  ],
};
---

<BaseLayout
  title={`Tree Service ${city} FL | Commercial, Sea Grape & Hurricane Prep`}
  description={`Professional tree removal, Sea Grape management, and emergency storm service in ${city}, FL. Commercial specialists for hotels, restaurants, and beach properties. ISA-certified arborists. Free estimates.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Hero
    headline={`Tree Service in ${city}, FL — Commercial & Beachfront Specialists`}
    subheadline={`Tree removal, Sea Grape management, and hurricane prep for ${city} hotels, restaurants, and vacation properties. ISA-certified arborists. Scheduled around your business operations.`}
    ctaText="Get a Free Estimate"
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-500 mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-primary">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">{city}</span>
    </nav>

    <div class="prose prose-lg max-w-none prose-headings:text-primary">
      <h2>Tree Service in {city}, FL</h2>
      <p>
        {city} anchors the southern end of the Gulf Boulevard corridor — the most commercially
        active stretch of the barrier island chain. Hotels, restaurants, beach bars, and resort
        properties line Gulf Blvd and the beachfront. Commercial tree service here has different
        requirements than residential work: scheduling around business hours, fast cleanup,
        proper insurance documentation, and the permits that come with beachfront vegetation.
      </p>
      <p>
        We work commercial schedules. Early morning start times, work completed before business
        opens, staging and cleanup before the first guest or customer arrives. We also carry the
        commercial general liability coverage that hotel and restaurant operators require before
        any contractor touches their property.
      </p>

      <h2>Sea Grape Management in {city}</h2>
      <p>
        {city}'s beachfront properties are lined with Sea Grape — Florida's signature coastal
        tree. Sea Grape is a protected species in Florida coastal zones and cannot be removed
        without a DEP coastal construction permit. But it can be shaped and maintained.
      </p>
      <p>
        Regular Sea Grape pruning keeps the canopy at the right height for Gulf views, prevents
        the tree from blocking sight lines or signage, and maintains the attractive beach
        aesthetic that guests expect. We perform permitted Sea Grape pruning in compliance with
        Florida DEP's coastal vegetation regulations — the right work, done legally.
      </p>

      <h2>Pre-Hurricane Season Tree Service in {city}</h2>
      <p>
        {city}'s commercial properties face maximum hurricane exposure at the southern end of
        the barrier island. Pre-season crown reduction for trees near buildings, parking lots,
        and outdoor dining areas is especially important. We book pre-season commercial work
        in April and May for June readiness — contact us in March to get on the schedule.
      </p>

      <h2>Services Available in {city}</h2>
      <ul>
        <li><a href="/services/tree-removal">Tree Removal</a> — Commercial and residential removal with proper permitting</li>
        <li><a href="/services/tree-trimming">Tree Trimming</a> — Pre-hurricane season crown reduction for commercial properties</li>
        <li><a href="/services/tree-pruning">Tree Pruning</a> — Sea Grape permitted pruning, ISA-certified coastal tree care</li>
        <li><a href="/services/stump-grinding">Stump Grinding</a> — Complete stump removal, parking lots and grounds cleared same-day</li>
        <li><a href="/services/emergency-tree-service">Emergency Tree Service</a> — 24/7 commercial storm response with insurance documentation</li>
        <li><a href="/services/land-clearing">Land Clearing</a> — Pre-construction clearing with DEP and Pinellas County permits</li>
      </ul>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-6">Our Services</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {SITE_CONFIG.services.slice(0, 6).map((s) => (
          <ServiceCard title={s.title} description={s.description} href={s.href} />
        ))}
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-primary mb-8">Frequently Asked Questions — {city}</h2>
      <div class="space-y-4">
        {[
          { q: `How much does tree removal cost in ${city}?`, a: `Residential removal: $400 to $2,500. Commercial properties with larger trees or complex access may cost more. Free on-site estimates available. Pinellas County permit fees may apply.` },
          { q: `Do you serve hotels and restaurants in ${city}?`, a: `Yes — commercial tree service is a major part of our ${city} work. We schedule around business hours, provide commercial insurance documentation, and offer early morning start times to finish before guests arrive.` },
          { q: `Can you manage Sea Grape trees at ${city} beachfront properties?`, a: `Yes — Sea Grape is protected and cannot be removed without a DEP coastal permit. We provide permitted pruning and shaping that keeps Sea Grapes attractive and compliant with Florida's coastal vegetation regulations.` },
          { q: `Do you offer emergency tree service in ${city} after a hurricane?`, a: `Yes — 24/7 emergency service. Commercial properties with trees on structures or blocking access get priority. We provide written damage assessments for insurance claims.` },
        ].map(({ q, a }) => (
          <details class="border border-gray-200 rounded-xl overflow-hidden group">
            <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold text-primary hover:bg-gray-50 list-none">
              {q}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">{a}</div>
          </details>
        ))}
      </div>
    </div>

    <div class="mt-12">
      <LeadForm heading={`Get a Free Estimate in ${city}`} />
    </div>
  </div>
</BaseLayout>
