{
  "name": "gulf-blvd-ecosystem",
  "private": true,
  "workspaces": [
    "gulf-blvd-ecosystem/screen-repair",
    "gulf-blvd-ecosystem/concrete",
    "gulf-blvd-ecosystem/tree-service",
    "gulf-blvd-ecosystem/landscaping"
  ],
  "dependencies": {
    "zod": "^3.25.28"
  },
  "scripts": {
    "dev:screen": "npm run dev --workspace=gulf-blvd-ecosystem/screen-repair",
    "dev:concrete": "npm run dev --workspace=gulf-blvd-ecosystem/concrete",
    "dev:tree": "npm run dev --workspace=gulf-blvd-ecosystem/tree-service",
    "dev:landscaping": "npm run dev --workspace=gulf-blvd-ecosystem/landscaping",
    "build:all": "npm run build --workspaces --if-present"
  }
